---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

const posts = await getCollection("blog", ({ data }) => data.draft !== true);
const sortedPosts = posts.sort(
    (a: CollectionEntry<"blog">, b: CollectionEntry<"blog">) =>
        b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
) as CollectionEntry<"blog">[];

// Get unique categories
const categories = [
    ...new Set(sortedPosts.map((p) => p.data.category).filter(Boolean)),
] as string[];
---

<Layout
    title="Blog"
    description="Onze nieuwste inzichten en kennis over webdevelopment, marketing en AI."
>
    <Navbar />
    <main class="min-h-screen pt-40 pb-20">
        <div class="max-w-7xl mx-auto px-6">
            <div class="mb-16">
                <h1
                    class="text-5xl md:text-7xl font-display font-bold text-dark tracking-tight mb-4"
                >
                    Onze <span class="text-indigo">Inzichten</span>.
                </h1>
                <p class="text-xl text-dark/70 max-w-2xl font-sans">
                    Ontdek de laatste trends, tips en verhalen over webdesign,
                    AI en online marketing.
                </p>
            </div>

            <!-- Category Filter -->
            {
                categories.length > 0 && (
                    <div class="flex flex-wrap gap-2 mb-12">
                        <button
                            data-filter="all"
                            class="filter-btn active px-4 py-2 text-xs font-bold uppercase tracking-widest rounded-full border border-indigo bg-indigo text-white transition-all"
                        >
                            Alles
                        </button>
                        {categories.map((cat) => (
                            <button
                                data-filter={cat}
                                class="filter-btn px-4 py-2 text-xs font-bold uppercase tracking-widest rounded-full border border-dark/10 text-dark/50 hover:border-indigo hover:text-indigo transition-all"
                            >
                                {cat}
                            </button>
                        ))}
                    </div>
                )
            }

            <div
                class="grid md:grid-cols-2 lg:grid-cols-3 gap-8"
                id="posts-grid"
            >
                {
                    sortedPosts.map((post) => (
                        <a
                            href={`/blog/${post.id}`}
                            class="blog-card group relative bg-white/50 backdrop-blur-sm border border-white rounded-3xl p-8 hover:-translate-y-2 transition-all duration-500 hover:shadow-xl hover:shadow-indigo/5 flex flex-col h-full"
                            data-category={post.data.category || ""}
                        >
                            <div class="absolute -inset-px bg-gradient-to-br from-indigo/20 to-transparent opacity-0 group-hover:opacity-100 rounded-3xl transition-opacity duration-500 pointer-events-none" />

                            <div class="flex items-center gap-3 mb-4">
                                <time
                                    datetime={post.data.pubDate.toISOString()}
                                    class="text-xs font-bold text-indigo uppercase tracking-widest"
                                >
                                    {post.data.pubDate.toLocaleDateString(
                                        "nl-NL",
                                        {
                                            year: "numeric",
                                            month: "short",
                                            day: "numeric",
                                        },
                                    )}
                                </time>
                                {post.data.category && (
                                    <>
                                        <span class="w-1 h-1 rounded-full bg-dark/20" />
                                        <span class="text-[10px] font-bold text-dark/40 uppercase tracking-widest">
                                            {post.data.category}
                                        </span>
                                    </>
                                )}
                            </div>

                            <h2 class="text-2xl font-display font-bold text-dark mb-4 group-hover:text-indigo transition-colors duration-300">
                                {post.data.title}
                            </h2>

                            <p class="text-dark/70 font-sans line-clamp-3 mb-8 text-sm leading-relaxed">
                                {post.data.excerpt || post.data.description}
                            </p>

                            {post.data.tags && post.data.tags.length > 0 && (
                                <div class="flex flex-wrap gap-1.5 mb-6">
                                    {post.data.tags.slice(0, 3).map((tag) => (
                                        <span class="text-[10px] font-medium text-dark/40 bg-dark/[0.03] px-2 py-0.5 rounded-full">
                                            {tag}
                                        </span>
                                    ))}
                                </div>
                            )}

                            <div class="mt-auto flex items-center gap-2 text-sm font-bold text-dark group-hover:text-indigo transition-colors uppercase tracking-widest">
                                Lees verder
                                <svg
                                    width="16"
                                    height="16"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="3"
                                    class="group-hover:translate-x-1 transition-transform"
                                >
                                    <path d="M5 12h14" />
                                    <path d="m12 5 7 7-7 7" />
                                </svg>
                            </div>
                        </a>
                    ))
                }
            </div>
        </div>
    </main>
    <Footer />
</Layout>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const buttons = document.querySelectorAll(".filter-btn");
        const cards = document.querySelectorAll(".blog-card");

        buttons.forEach((btn) => {
            btn.addEventListener("click", () => {
                const filter = (btn as HTMLElement).dataset.filter;

                // Update active state
                buttons.forEach((b) => {
                    b.classList.remove(
                        "active",
                        "bg-indigo",
                        "text-white",
                        "border-indigo",
                    );
                    b.classList.add("border-dark/10", "text-dark/50");
                });
                btn.classList.add(
                    "active",
                    "bg-indigo",
                    "text-white",
                    "border-indigo",
                );
                btn.classList.remove("border-dark/10", "text-dark/50");

                // Filter cards
                cards.forEach((card) => {
                    const cardEl = card as HTMLElement;
                    const cat = cardEl.dataset.category;
                    if (filter === "all" || cat === filter) {
                        cardEl.style.display = "";
                        cardEl.style.opacity = "1";
                    } else {
                        cardEl.style.display = "none";
                    }
                });
            });
        });
    });
</script>
