---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import BlogCard from "../../components/blog/BlogCard.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

const posts = await getCollection("blog", ({ data }) => data.draft !== true);
const sortedPosts = posts.sort(
    (a: CollectionEntry<"blog">, b: CollectionEntry<"blog">) =>
        b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
) as CollectionEntry<"blog">[];

// Pillar-gidsen data (single source, makkelijk te onderhouden).
const guides = [
    {
        href: "/gids/geo",
        badge: "Marketing · SEO",
        accent: "indigo",
        title: "GEO",
        titleAccent: "Generative Engine Optimization",
        description:
            "Zo word je gevonden in ChatGPT, Perplexity en Gemini.",
        readingTime: "±15 min",
    },
    {
        href: "/gids/ai-automation",
        badge: "Software · Automation",
        accent: "violet",
        title: "AI-automation",
        titleAccent: "voor MKB",
        description:
            "Van Zapier + LLM tot custom agents. Welk type past wanneer.",
        readingTime: "±18 min",
    },
    {
        href: "/gids/ai-first-websites",
        badge: "Websites",
        accent: "indigo",
        title: "AI-first",
        titleAccent: "websites",
        description:
            "Bouwstenen, stack-keuzes en AI-features in modern web.",
        readingTime: "±16 min",
    },
    {
        href: "/gids/ai-marketing",
        badge: "Marketing",
        accent: "violet",
        title: "AI-marketing",
        titleAccent: "voor MKB",
        description:
            "Content, ads en personalisatie. Welke workflows leveren ROI?",
        readingTime: "±17 min",
    },
    {
        href: "/gids/ai-strategie",
        badge: "Directie",
        accent: "indigo",
        title: "AI-strategie",
        titleAccent: "voor MKB",
        description:
            "Readiness, governance, budget en roadmap voor directies.",
        readingTime: "±19 min",
    },
];

// Tel posts per categorie om top-5 te bepalen.
const categoryCounts = sortedPosts.reduce<Record<string, number>>((acc, p) => {
    const cat = p.data.category;
    if (cat) acc[cat] = (acc[cat] || 0) + 1;
    return acc;
}, {});

// Toon alleen de 5 meest-gebruikte categorieën — rest wordt bereikbaar via "Alles".
const topCategories = Object.entries(categoryCounts)
    .sort((a, b) => b[1] - a[1])
    .slice(0, 5)
    .map(([cat]) => cat);
---

<Layout
    title="Kennisbank"
    description="Onze nieuwste inzichten en kennis over webdevelopment, marketing en AI."
>
    <script slot="head" type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://agensea.nl/" },
        { "@type": "ListItem", "position": 2, "name": "Kennisbank", "item": "https://agensea.nl/kennisbank/" }
      ]
    })} />
    <Navbar />

    <main id="main-content" class="bg-cream min-h-screen pt-32 md:pt-40 pb-20 overflow-hidden relative">
        <!-- Subtle background decor matching site-style -->
        <div class="absolute inset-0 pointer-events-none overflow-hidden">
            <div class="mesh-blob w-[600px] h-[600px] bg-indigo/10 top-[-10%] right-[-10%] blur-[120px]"></div>
            <div class="mesh-blob w-[500px] h-[500px] bg-violet/10 bottom-[30%] left-[-10%] blur-[100px]"></div>
        </div>

        <div class="max-w-7xl mx-auto px-6 lg:px-10 relative z-10">
            <!-- Hero -->
            <div class="mb-20 md:mb-24 max-w-3xl">
                <span class="inline-flex items-center gap-2 text-xs font-bold text-indigo uppercase tracking-[0.2em] mb-6">
                    <span class="w-8 h-[2px] bg-indigo"></span>
                    Kennisbank
                </span>
                <h1 class="font-display font-bold text-5xl md:text-6xl lg:text-7xl text-dark tracking-tight leading-[1.05] mb-6">
                    Onze <span class="text-indigo">inzichten</span>.
                </h1>
                <p class="text-lg md:text-xl text-text-secondary leading-relaxed">
                    Gidsen en artikelen over AI, websites, marketing en strategie.
                    Gebouwd voor mkb-ondernemers die verder willen dan de hype.
                </p>
            </div>

            <!-- Featured pillar-gidsen — light huisstijl cards -->
            <section class="mb-20 md:mb-28">
                <div class="flex items-end justify-between mb-8 flex-wrap gap-3">
                    <div>
                        <span class="inline-flex items-center gap-2 text-[10px] font-bold text-indigo uppercase tracking-[0.25em] mb-2">
                            <span class="w-6 h-[1px] bg-indigo"></span>
                            Complete overzichten
                        </span>
                        <h2 class="font-display font-bold text-2xl md:text-3xl text-dark">
                            Gidsen
                        </h2>
                    </div>
                    <a href="/gids" class="text-xs font-bold text-dark/50 hover:text-indigo uppercase tracking-widest transition-colors inline-flex items-center gap-1.5">
                        Alle gidsen
                        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                    </a>
                </div>

                <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">
                    {guides.map((g) => (
                        <a
                            href={g.href}
                            class="group relative block bg-white border border-dark/[0.08] rounded-3xl p-7 shadow-[0_2px_12px_rgba(13,13,13,0.04)] transition-all duration-500 hover:-translate-y-1 hover:border-indigo/25 hover:shadow-[0_20px_40px_-12px_rgba(67,83,255,0.12)] overflow-hidden"
                        >
                            {/* Hover-revealing blob in accent color */}
                            <div class:list={[
                                "absolute -top-10 -right-10 w-40 h-40 rounded-full blur-3xl opacity-0 group-hover:opacity-60 transition-opacity duration-700 pointer-events-none",
                                g.accent === "indigo" ? "bg-indigo/30" : "bg-violet/30",
                            ]}></div>

                            <div class="relative z-10 flex flex-col h-full">
                                {/* Meta row: badge + reading time */}
                                <div class="flex items-center justify-between gap-2 mb-5">
                                    <span class:list={[
                                        "inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-[0.2em]",
                                        g.accent === "indigo"
                                            ? "bg-indigo/10 text-indigo"
                                            : "bg-violet/10 text-violet",
                                    ]}>
                                        {g.badge}
                                    </span>
                                    <span class="text-[10px] text-dark/40 font-medium">
                                        {g.readingTime}
                                    </span>
                                </div>

                                {/* Title */}
                                <h3 class="font-display font-bold text-2xl md:text-[1.65rem] text-dark leading-[1.1] mb-3 group-hover:text-indigo transition-colors duration-300">
                                    {g.title}{" "}
                                    <span class:list={[
                                        g.accent === "indigo" ? "text-indigo" : "text-violet",
                                    ]}>{g.titleAccent}</span>
                                </h3>

                                {/* Description */}
                                <p class="text-dark/60 text-sm leading-relaxed mb-8">
                                    {g.description}
                                </p>

                                {/* Footer */}
                                <div class="flex items-center justify-between pt-5 mt-auto border-t border-dark/5">
                                    <span class="text-[10px] font-bold text-dark/40 uppercase tracking-widest">
                                        Lees gids
                                    </span>
                                    <svg class="w-4 h-4 text-dark/30 group-hover:text-indigo group-hover:translate-x-1 transition-all" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                                </div>
                            </div>
                        </a>
                    ))}
                </div>
            </section>

            <!-- Artikelen header + categorieën -->
            <section>
                <div class="flex items-end justify-between mb-8 flex-wrap gap-3">
                    <div>
                        <span class="inline-flex items-center gap-2 text-[10px] font-bold text-indigo uppercase tracking-[0.25em] mb-2">
                            <span class="w-6 h-[1px] bg-indigo"></span>
                            Verdiepende stukken
                        </span>
                        <h2 class="font-display font-bold text-2xl md:text-3xl text-dark">
                            Alle artikelen
                        </h2>
                    </div>
                    <span class="text-xs text-dark/40 font-medium">
                        {sortedPosts.length} artikelen
                    </span>
                </div>

                <!-- Category filter — cleaner, top-5 + "alles" -->
                {topCategories.length > 0 && (
                    <div class="flex flex-wrap gap-2 mb-10" id="filter-row">
                        <button
                            data-filter="all"
                            class="filter-btn filter-btn--active"
                        >
                            Alles
                        </button>
                        {topCategories.map((cat) => (
                            <button
                                data-filter={cat}
                                class="filter-btn"
                            >
                                {cat}
                            </button>
                        ))}
                    </div>
                )}

                <div
                    class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8"
                    id="posts-grid"
                >
                    {sortedPosts.map((post) => <BlogCard post={post} />)}
                </div>
            </section>
        </div>
    </main>
    <Footer />
</Layout>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const buttons = document.querySelectorAll<HTMLButtonElement>(".filter-btn");
        const cards = document.querySelectorAll<HTMLElement>(".blog-card");

        buttons.forEach((btn) => {
            btn.addEventListener("click", () => {
                const filter = btn.dataset.filter;

                buttons.forEach((b) => b.classList.remove("filter-btn--active"));
                btn.classList.add("filter-btn--active");

                cards.forEach((card) => {
                    const cat = card.dataset.category;
                    if (filter === "all" || cat === filter) {
                        card.style.display = "";
                    } else {
                        card.style.display = "none";
                    }
                });
            });
        });
    });
</script>

<style>
    /* ── Category filter — clean & geen blauw-op-blauw ──
       Niet-actieve chips: subtiel grijs, bij hover een zachte bg-tint
       (geen kleurverandering in tekst). Actieve chip: indigo bg + witte
       tekst, blijft zo ook tijdens hover. */
    .filter-btn {
        padding: 0.5rem 1rem;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        border-radius: 9999px;
        border: 1px solid rgba(13, 13, 13, 0.08);
        background: transparent;
        color: rgba(13, 13, 13, 0.55);
        transition:
            background-color 0.2s ease,
            color 0.2s ease,
            border-color 0.2s ease;
        cursor: pointer;
    }

    .filter-btn:hover {
        background: rgba(13, 13, 13, 0.04);
        border-color: rgba(13, 13, 13, 0.15);
        color: rgba(13, 13, 13, 0.9);
    }

    .filter-btn--active,
    .filter-btn--active:hover {
        background: rgb(67, 83, 255);
        color: #fff;
        border-color: rgb(67, 83, 255);
    }
</style>
