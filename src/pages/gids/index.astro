---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const guides = [
  {
    href: '/gids/geo',
    badge: 'Marketing · SEO',
    badgeColor: 'indigo',
    title: 'GEO',
    titleAccent: 'Generative Engine Optimization',
    description: 'Complete gids over gevonden worden in ChatGPT, Perplexity, Gemini en Claude. Van technisch fundament tot 30-60-90 dagen roadmap.',
    readingTime: '±15 min',
    sections: 10,
    clusterPosts: 8,
    service: '/diensten/marketing',
    serviceName: 'Marketing',
  },
  {
    href: '/gids/ai-automation',
    badge: 'Software · Automation',
    badgeColor: 'violet',
    title: 'AI-automation voor MKB',
    titleAccent: '',
    description: 'Van Zapier + LLM tot custom agents. Welk type past wanneer, wat kost het, en hoe begin je zonder half miljoen te verbranden.',
    readingTime: '±18 min',
    sections: 10,
    clusterPosts: 8,
    service: '/diensten/software',
    serviceName: 'Software',
  },
  {
    href: '/gids/ai-first-websites',
    badge: 'Websites',
    badgeColor: 'indigo',
    title: 'AI-first websites',
    titleAccent: '',
    description: 'Wat betekent AI-first concreet? Bouwstenen, tech-stack, welke AI-features écht werken en wat het kost.',
    readingTime: '±16 min',
    sections: 10,
    clusterPosts: 8,
    service: '/diensten/websites',
    serviceName: 'Websites',
  },
  {
    href: '/gids/ai-marketing',
    badge: 'Marketing',
    badgeColor: 'violet',
    title: 'AI-marketing voor MKB',
    titleAccent: '',
    description: 'Content, ads, personalisatie en analytics met AI. Welke workflows leveren écht ROI, en welke zijn hype?',
    readingTime: '±17 min',
    sections: 10,
    clusterPosts: 8,
    service: '/diensten/marketing',
    serviceName: 'Marketing',
  },
  {
    href: '/gids/ai-strategie',
    badge: 'Directie · Strategie',
    badgeColor: 'indigo',
    title: 'AI-strategie voor MKB',
    titleAccent: '',
    description: 'Niet tactisch maar strategisch. Readiness, governance, eerste projecten en 12-maand roadmap voor mkb-directies.',
    readingTime: '±19 min',
    sections: 10,
    clusterPosts: 9,
    service: '/contact',
    serviceName: 'Sparring',
  },
];
---

<Layout
  title="Gidsen"
  description="Onze complete gidsen over AI-first websites, GEO, AI-automation en AI-marketing. Diepgaande overzichten voor mkb-ondernemers, updated voor 2026."
  seoTitle="Gidsen — GEO, AI-automation, websites, marketing | Agensea"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    'itemListElement': [
      { '@type': 'ListItem', 'position': 1, 'name': 'Home', 'item': 'https://agensea.nl/' },
      { '@type': 'ListItem', 'position': 2, 'name': 'Gidsen', 'item': 'https://agensea.nl/gids/' }
    ]
  })} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    'name': 'Gidsen',
    'description': 'Complete gidsen voor AI-first ondernemers',
    'url': 'https://agensea.nl/gids/',
    'hasPart': guides.map(g => ({
      '@type': 'Article',
      'headline': g.title + (g.titleAccent ? ': ' + g.titleAccent : ''),
      'url': `https://agensea.nl${g.href}/`,
      'description': g.description,
    }))
  })} />

  <Navbar />

  <main id="main-content" class="bg-cream min-h-screen pt-28 md:pt-36 pb-20 overflow-hidden relative">
    <!-- Background -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
      <div class="mesh-blob w-[600px] h-[600px] bg-indigo/10 top-[-10%] right-[-10%] blur-[120px]"></div>
      <div class="mesh-blob w-[500px] h-[500px] bg-violet/10 bottom-[10%] left-[-10%] blur-[100px]"></div>
    </div>

    <!-- Hero -->
    <section class="max-w-6xl mx-auto px-6 lg:px-10 relative z-10 mb-16 md:mb-20">
      <nav aria-label="Breadcrumb" class="mb-8 text-sm text-text-secondary">
        <a href="/" class="hover:text-indigo transition-colors">Home</a>
        <span class="mx-2 text-warm-grey">/</span>
        <span class="text-dark">Gidsen</span>
      </nav>

      <div>
        <span class="inline-flex items-center gap-2 text-xs font-bold text-indigo uppercase tracking-[0.2em] mb-6">
          <span class="w-8 h-[2px] bg-indigo"></span>
          Gidsen
        </span>
        <h1 class="font-display font-bold text-4xl md:text-5xl lg:text-6xl leading-[1.05] tracking-tight text-dark mb-6">
          Complete overzichten voor <span class="text-indigo">AI-first</span> ondernemers
        </h1>
        <p class="text-lg md:text-xl text-text-secondary leading-relaxed max-w-3xl">
          Diepgaande gidsen per kerngebied — AI-automation, websites, marketing, strategie en GEO. Elk met een 30-60-90 dagen roadmap en bijbehorende <a href="/kennisbank" class="text-indigo hover:text-dark underline underline-offset-4 decoration-indigo/30 hover:decoration-indigo">verdiepende artikelen</a>.
        </p>
      </div>
    </section>

    <!-- Guides Grid -->
    <section class="max-w-6xl mx-auto px-6 lg:px-10 relative z-10 mb-24">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">
        {guides.map((g) => (
          <a
            href={g.href}
            class="group relative block bg-white rounded-3xl p-7 border border-dark/[0.08] shadow-[0_2px_12px_rgba(13,13,13,0.04)] hover:border-indigo/25 hover:shadow-[0_20px_40px_-12px_rgba(67,83,255,0.12)] hover:-translate-y-1 transition-all duration-500 overflow-hidden flex flex-col h-full"
          >
            <div class:list={[
              "absolute -top-16 -right-16 w-56 h-56 rounded-full blur-3xl pointer-events-none opacity-0 group-hover:opacity-60 transition-opacity duration-700",
              g.badgeColor === 'indigo' ? 'bg-indigo/30' : 'bg-violet/30',
            ]}></div>

            <div class="relative z-10 flex flex-col h-full">
              {/* Meta-rij */}
              <div class="flex items-center justify-between gap-2 mb-5">
                <span class:list={[
                  "inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-[0.2em]",
                  g.badgeColor === 'indigo' ? 'bg-indigo/10 text-indigo' : 'bg-violet/10 text-violet',
                ]}>
                  {g.badge}
                </span>
                <span class="text-[10px] text-dark/40 font-medium">{g.readingTime}</span>
              </div>

              {/* Titel */}
              <h2 class="font-display font-bold text-2xl text-dark leading-[1.15] mb-3 group-hover:text-indigo transition-colors">
                {g.title}{g.titleAccent && (<> <span class:list={[g.badgeColor === 'indigo' ? 'text-indigo' : 'text-violet']}>{g.titleAccent}</span></>)}
              </h2>

              {/* Omschrijving */}
              <p class="text-dark/60 text-sm leading-relaxed mb-6">
                {g.description}
              </p>

              {/* Inhoud-indicator */}
              <div class="flex items-center gap-4 mb-6 text-[11px] text-dark/50">
                <span class="flex items-center gap-1.5">
                  <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 3v18M3 9h6"/></svg>
                  {g.sections} secties
                </span>
                <span class="flex items-center gap-1.5">
                  <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
                  {g.clusterPosts} artikelen
                </span>
              </div>

              {/* Footer */}
              <div class="mt-auto pt-5 border-t border-dark/5 flex items-center justify-between">
                <span class="text-[10px] font-bold text-dark/40 uppercase tracking-widest">
                  Lees gids
                </span>
                <svg class="w-4 h-4 text-dark/30 group-hover:text-indigo group-hover:translate-x-1 transition-all" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <section class="max-w-6xl mx-auto px-6 lg:px-10 relative z-10">
      <div class="bg-dark text-white rounded-[2rem] p-10 md:p-16 relative overflow-hidden">
        <div class="absolute top-0 right-0 w-80 h-80 bg-indigo/20 rounded-full blur-3xl"></div>
        <div class="relative z-10 max-w-2xl">
          <span class="inline-flex items-center gap-2 text-xs font-bold text-indigo uppercase tracking-[0.2em] mb-6">
            <span class="w-8 h-[2px] bg-indigo"></span>
            Een gids niet genoeg?
          </span>
          <h2 class="font-display font-bold text-3xl md:text-5xl leading-[1.05] mb-6">
            Laat ons meedenken over jouw specifieke situatie
          </h2>
          <p class="text-lg text-white/70 leading-relaxed mb-10">
            Gidsen geven richting, maar je situatie is uniek. Een scan, een gesprek, een tweede mening — we denken graag mee.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/contact" class="px-8 py-4 bg-indigo text-white rounded-xl font-medium hover:bg-white hover:text-dark transition-colors duration-300 inline-flex items-center gap-2">
              Neem contact op
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="/kennisbank" class="px-8 py-4 border border-white/20 rounded-xl font-medium text-white hover:border-white transition-all duration-300">
              Bekijk alle artikelen
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
