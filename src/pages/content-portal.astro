<script>
  // Demo tab switching
  const tabColors: Record<string, string[]> = {
    social: ['bg-indigo', 'text-white'],
    nieuws: ['bg-violet-500', 'text-white'],
    website: ['bg-emerald-600', 'text-white']
  };

  document.querySelectorAll('.demo-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      const target = (tab as HTMLElement).dataset.tab!;

      // Reset all tabs
      document.querySelectorAll('.demo-tab').forEach(t => {
        t.className = 'demo-tab px-4 py-2 rounded-full text-xs font-bold transition-all duration-300 bg-slate-100 text-slate-500 hover:bg-slate-200';
      });
      // Activate clicked tab
      const colors = tabColors[target];
      tab.className = `demo-tab active px-4 py-2 rounded-full text-xs font-bold transition-all duration-300 ${colors[0]} ${colors[1]}`;

      // Switch panels
      document.querySelectorAll('.demo-panel').forEach(p => p.classList.add('hidden'));
      document.getElementById(`demo-panel-${target}`)?.classList.remove('hidden');
    });
  });

  // Hero submit animation
  const heroSubmit = document.getElementById('hero-submit');
  heroSubmit?.addEventListener('click', () => {
    const text = document.getElementById('hero-submit-text')!;
    const arrow = document.getElementById('hero-submit-arrow')!;
    const check = document.getElementById('hero-submit-check')!;
    heroSubmit.classList.add('bg-emerald-600');
    heroSubmit.classList.remove('bg-indigo');
    text.textContent = 'Verstuurd!';
    arrow.classList.add('hidden');
    check.classList.remove('hidden');
    setTimeout(() => {
      heroSubmit.classList.remove('bg-emerald-600');
      heroSubmit.classList.add('bg-indigo');
      text.textContent = 'Versturen';
      arrow.classList.remove('hidden');
      check.classList.add('hidden');
    }, 2000);
  });

  // Demo submit animation (social form)
  const demoSubmit = document.getElementById('demo-submit');
  demoSubmit?.addEventListener('click', () => {
    const text = document.getElementById('demo-submit-text')!;
    const arrow = document.getElementById('demo-submit-arrow')!;
    const check = document.getElementById('demo-submit-check')!;

    demoSubmit.classList.add('bg-emerald-600', 'shadow-emerald-600/20');
    demoSubmit.classList.remove('bg-indigo', 'shadow-indigo/20');
    text.textContent = 'Verstuurd!';
    arrow.classList.add('hidden');
    check.classList.remove('hidden');

    setTimeout(() => {
      demoSubmit.classList.remove('bg-emerald-600', 'shadow-emerald-600/20');
      demoSubmit.classList.add('bg-indigo', 'shadow-indigo/20');
      text.textContent = 'Versturen';
      arrow.classList.remove('hidden');
      check.classList.add('hidden');
    }, 2000);
  });

  // FAQ toggle
  document.querySelectorAll('.faq-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const answer = btn.nextElementSibling as HTMLElement;
      const icon = btn.querySelector('.faq-icon') as HTMLElement;
      const isOpen = answer.style.maxHeight && answer.style.maxHeight !== '0px';

      if (isOpen) {
        answer.style.maxHeight = '0px';
        icon?.classList.remove('rotate-180');
      } else {
        answer.style.maxHeight = answer.scrollHeight + 'px';
        icon?.classList.add('rotate-180');
      }
    });
  });
</script>
