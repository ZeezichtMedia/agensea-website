---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const features = [
  {
    icon: `<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>`,
    title: "Social content",
    desc: "Collega's leveren social posts aan met timing, doelgroep en media. Jij beheert alles vanuit één dashboard.",
    color: "indigo"
  },
  {
    icon: `<path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2z"/><path d="M2 6h4"/><path d="M2 10h4"/><path d="M2 14h4"/>`,
    title: "Nieuwsartikelen",
    desc: "Volledige artikelen indienen met tekst, media en doelgroep. Klaar om te reviewen en publiceren.",
    color: "violet"
  },
  {
    icon: `<path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 1 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>`,
    title: "Website wijzigingen",
    desc: "Tekstaanpassingen, nieuwe pagina's of structurele wijzigingen — netjes gedocumenteerd met screenshots.",
    color: "emerald"
  }
];

// Prijzen tijdelijk verborgen — origineel: Starter "149"/maand, Professional "299"/maand, Enterprise "Op maat".
// Zet `price` terug naar het originele bedrag (en pas evt. de CTA aan) zodra de definitieve prijzen vaststaan.
const plans = [
  {
    name: "Starter",
    price: "Op aanvraag", // origineel: "149"
    desc: "Voor kleine teams die hun content workflow willen stroomlijnen.",
    features: [
      "Tot 3 teamleden",
      "Alle 3 de modules",
      "Admin dashboard",
      "E-mail notificaties",
      "Jouw eigen branding"
    ],
    cta: "Neem contact op",
    highlighted: false
  },
  {
    name: "Professional",
    price: "Op aanvraag", // origineel: "299"
    desc: "Voor groeiende organisaties met meerdere afdelingen.",
    features: [
      "Tot 15 teamleden",
      "Alle 3 de modules",
      "Admin dashboard",
      "Prioriteit support",
      "Custom branding & domein",
      "Voice-to-text invoer",
      "Exporteer naar CSV"
    ],
    cta: "Neem contact op",
    highlighted: true
  },
  {
    name: "Enterprise",
    price: "Op aanvraag", // origineel: "Op maat"
    desc: "Voor grote organisaties met specifieke wensen en integraties.",
    features: [
      "Onbeperkt teamleden",
      "Alle Professional features",
      "Dedicated onboarding",
      "Custom integraties",
      "SLA & uptime garantie",
      "SSO / SAML login"
    ],
    cta: "Neem contact op",
    highlighted: false
  }
];

const steps = [
  { num: "01", title: "Portal aanmaken", desc: "Binnen 5 minuten staat je eigen portal live. Upload je logo, kies je kleuren en nodig je team uit." },
  { num: "02", title: "Team uitnodigen", desc: "Deel de link met je collega's. Zij kunnen direct content aanleveren — zonder account, zonder gedoe." },
  { num: "03", title: "Content beheren", desc: "Bekijk alle inzendingen in je dashboard. Filter, kopieer en verwerk ze in je eigen tempo." }
];
---

<Layout
  title="Content Portal — Alle interne content op één plek"
  description="Centraliseer social posts, nieuwsartikelen en website-wijzigingen van je hele team in één overzichtelijk portaal. White-label, eenvoudig en snel."
>
  <Navbar />

  <main id="main-content" class="bg-cream min-h-screen pt-32 md:pt-48 pb-0 overflow-hidden relative">
    <!-- Background Decor -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
      <div class="mesh-blob w-[600px] h-[600px] bg-indigo/10 top-[-10%] right-[-10%] blur-[120px]"></div>
      <div class="mesh-blob w-[500px] h-[500px] bg-violet/10 bottom-[20%] left-[-10%] blur-[100px]"></div>
    </div>

    <!-- ─── Hero ─────────────────────────────────────────── -->
    <section class="max-w-7xl mx-auto px-6 lg:px-10 relative z-10 mb-20 md:mb-32">
      <div class="grid lg:grid-cols-12 gap-12 lg:gap-20 items-center">
        <div class="lg:col-span-7">
          <div class="reveal">
            <span class="inline-flex items-center gap-2 text-xs font-bold text-indigo uppercase tracking-[0.2em] mb-6">
              <span class="w-8 h-[2px] bg-indigo"></span>
              SaaS Tool
            </span>
            <h1 class="font-display font-bold text-4xl sm:text-5xl md:text-6xl lg:text-7xl leading-[1.05] tracking-tight text-dark mb-8">
              Alle interne content op <span class="text-indigo">één plek.</span>
            </h1>
            <p class="text-lg md:text-xl text-text-secondary leading-relaxed mb-10 max-w-xl">
              Stop met zoeken in e-mails, Slack en gedeelde mappen. Het Content Portal centraliseert social posts, nieuwsartikelen en website-wijzigingen van je hele team in één overzichtelijk dashboard.
            </p>
            <div class="flex flex-wrap gap-4">
              <a href="#prijzen" class="px-8 py-4 bg-dark text-white rounded-xl font-medium hover:bg-indigo transition-colors duration-300">
                Bekijk de prijzen
              </a>
              <a href="#hoe-het-werkt" class="px-8 py-4 border border-warm-grey/50 rounded-xl font-medium text-dark hover:border-indigo transition-all duration-300">
                Hoe het werkt
              </a>
            </div>
          </div>
        </div>

        <!-- Right: Product Preview — actual tool UI -->
        <div class="lg:col-span-5 reveal" style="transition-delay: 200ms;">
          <div class="w-full bg-white rounded-[2rem] shadow-2xl overflow-hidden border border-white relative">
            <!-- Browser Chrome -->
            <div class="h-9 bg-[#f5f3ef] flex items-center px-4 gap-1.5 border-b border-warm-grey/15">
              <div class="w-2.5 h-2.5 rounded-full bg-[#FF5F57]"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-[#FEBC2E]"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-[#28C840]"></div>
              <div class="ml-3 flex-1 h-5 bg-white/80 rounded-md border border-warm-grey/15 flex items-center px-2">
                <svg class="w-2.5 h-2.5 text-text-secondary/30 mr-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                <span class="text-[8px] text-text-secondary/40 font-mono">portal.jouwbedrijf.nl/social</span>
              </div>
            </div>
            <!-- Portal UI (interactive) -->
            <div class="bg-slate-50">
              <!-- Portal Header -->
              <div class="bg-white border-b border-slate-100 px-4 py-3 flex items-center justify-between">
                <div class="flex items-center gap-2">
                  <div class="w-6 h-6 rounded-md bg-indigo flex items-center justify-center">
                    <span class="text-white text-[8px] font-bold">A</span>
                  </div>
                  <span class="font-display font-bold text-dark text-[11px]">Content Portal</span>
                </div>
                <div class="flex items-center gap-1 text-[8px] text-emerald-600 font-medium">
                  <span class="w-1 h-1 rounded-full bg-emerald-500"></span>
                  Online
                </div>
              </div>
              <!-- Form -->
              <div class="p-4">
                <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
                  <div class="h-1 bg-gradient-to-r from-indigo to-cyan-500"></div>
                  <div class="p-4 space-y-3">
                    <!-- Title -->
                    <div class="text-center mb-1">
                      <p class="font-display font-bold text-dark text-sm">Social content aanleveren</p>
                      <p class="text-[9px] text-slate-400">Vul het formulier in en wij regelen de rest</p>
                    </div>
                    <!-- Field: Wat -->
                    <div>
                      <label class="block text-[9px] font-semibold text-slate-700 mb-1">Wat wil je delen? <span class="text-indigo">*</span></label>
                      <input type="text" placeholder="Bijv: Lancering nieuwe website" value="Lancering nieuwe website ADRZ" class="w-full px-3 py-2 rounded-lg bg-slate-50 border border-slate-200 text-[10px] text-slate-900 focus:bg-white focus:outline-none focus:border-indigo/50 focus:ring-2 focus:ring-indigo/10 transition-all placeholder-slate-400" />
                    </div>
                    <!-- Fields: Waar + Waarom -->
                    <div class="grid grid-cols-2 gap-2">
                      <div>
                        <label class="block text-[9px] font-semibold text-slate-700 mb-1">Waar?</label>
                        <input type="text" placeholder="Bijv: Instagram" value="Instagram, LinkedIn" class="w-full px-3 py-2 rounded-lg bg-slate-50 border border-slate-200 text-[10px] text-slate-900 focus:bg-white focus:outline-none focus:border-indigo/50 focus:ring-2 focus:ring-indigo/10 transition-all placeholder-slate-400" />
                      </div>
                      <div>
                        <label class="block text-[9px] font-semibold text-slate-700 mb-1">Waarom?</label>
                        <input type="text" placeholder="Bijv: Zichtbaarheid" class="w-full px-3 py-2 rounded-lg bg-slate-50 border border-slate-200 text-[10px] text-slate-900 focus:bg-white focus:outline-none focus:border-indigo/50 focus:ring-2 focus:ring-indigo/10 transition-all placeholder-slate-400" />
                      </div>
                    </div>
                    <!-- Timing -->
                    <div>
                      <label class="block text-[9px] font-semibold text-slate-700 mb-1">Wanneer plaatsen?</label>
                      <div class="grid grid-cols-3 gap-1.5" id="hero-timing">
                        <label class="cursor-pointer">
                          <input type="radio" name="hero-timing" value="spoed" class="peer sr-only" />
                          <div class="flex items-center justify-center gap-1 px-2 py-1.5 rounded-lg border-2 border-slate-200 bg-slate-50 peer-checked:border-orange-400 peer-checked:bg-orange-50 transition-all text-center">
                            <span class="text-[10px]">&#128293;</span>
                            <span class="text-[8px] font-semibold text-slate-500 peer-checked:text-orange-600">Spoed</span>
                          </div>
                        </label>
                        <label class="cursor-pointer">
                          <input type="radio" name="hero-timing" value="week" class="peer sr-only" checked />
                          <div class="flex items-center justify-center gap-1 px-2 py-1.5 rounded-lg border-2 border-slate-200 bg-slate-50 peer-checked:border-indigo peer-checked:bg-indigo/5 transition-all text-center">
                            <span class="text-[10px]">&#128197;</span>
                            <span class="text-[8px] font-semibold text-slate-500">Deze week</span>
                          </div>
                        </label>
                        <label class="cursor-pointer">
                          <input type="radio" name="hero-timing" value="rustig" class="peer sr-only" />
                          <div class="flex items-center justify-center gap-1 px-2 py-1.5 rounded-lg border-2 border-slate-200 bg-slate-50 peer-checked:border-slate-400 peer-checked:bg-slate-100 transition-all text-center">
                            <span class="text-[10px]">&#9749;</span>
                            <span class="text-[8px] font-semibold text-slate-500">Geen haast</span>
                          </div>
                        </label>
                      </div>
                    </div>
                    <!-- Toelichting -->
                    <div>
                      <label class="block text-[9px] font-semibold text-slate-700 mb-1">Toelichting</label>
                      <textarea rows="2" placeholder="Geef extra context..." class="w-full px-3 py-2 rounded-lg bg-slate-50 border border-slate-200 text-[10px] text-slate-900 focus:bg-white focus:outline-none focus:border-indigo/50 focus:ring-2 focus:ring-indigo/10 transition-all placeholder-slate-400 resize-none"></textarea>
                    </div>
                    <!-- Upload zone -->
                    <div class="border border-dashed border-slate-200 rounded-lg p-3 text-center hover:bg-slate-100/50 hover:border-indigo/30 transition-all cursor-pointer">
                      <div class="flex items-center justify-center gap-1.5">
                        <svg class="w-3.5 h-3.5 text-indigo/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                        <span class="text-[8px] text-slate-400">Sleep bestanden hierheen</span>
                      </div>
                    </div>
                    <!-- Submit -->
                    <button type="button" id="hero-submit" class="w-full bg-indigo hover:brightness-95 rounded-lg py-2.5 text-center transition-all duration-300 cursor-pointer flex items-center justify-center gap-1.5 group">
                      <span id="hero-submit-text" class="text-white text-[10px] font-bold">Versturen</span>
                      <svg id="hero-submit-arrow" class="w-3 h-3 text-white transition-transform duration-300 group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                      <svg id="hero-submit-check" class="w-3.5 h-3.5 text-white hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                    </button>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── Features ─────────────────────────────────────── -->
    <section class="max-w-7xl mx-auto px-6 lg:px-10 relative z-10 mb-20 md:mb-32">
      <div class="text-center mb-12 md:mb-16 reveal">
        <span class="inline-flex items-center gap-2 text-xs font-bold text-indigo uppercase tracking-[0.2em] mb-4">
          <span class="w-8 h-[2px] bg-indigo"></span>
          Modules
          <span class="w-8 h-[2px] bg-indigo"></span>
        </span>
        <h2 class="font-display text-3xl md:text-5xl font-bold text-dark">
          Drie kanalen, <span class="text-indigo">één dashboard.</span>
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {features.map((f, i) => (
          <div class="reveal bg-white/60 backdrop-blur-sm border border-white rounded-2xl p-8 hover:shadow-xl hover:border-indigo/20 transition-all duration-500" style={`transition-delay: ${i * 100}ms`}>
            <div class={`w-14 h-14 rounded-2xl bg-${f.color}/10 flex items-center justify-center mb-6`}>
              <svg class={`w-6 h-6 text-${f.color}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <Fragment set:html={f.icon} />
              </svg>
            </div>
            <h3 class="font-display font-bold text-xl text-dark mb-3">{f.title}</h3>
            <p class="text-text-secondary leading-relaxed text-sm">{f.desc}</p>
          </div>
        ))}
      </div>

      <!-- Extra feature highlights -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 mt-8">
        {[
          { icon: `<path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/>`, text: "White-label branding" },
          { icon: `<path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/>`, text: "Voice-to-text invoer" },
          { icon: `<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/>`, text: "Drag & drop uploads" },
          { icon: `<rect x="8" y="2" width="8" height="4" rx="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/>`, text: "One-click kopieer" }
        ].map(item => (
          <div class="reveal flex items-center gap-3 bg-white/40 border border-white rounded-xl px-5 py-4">
            <svg class="w-5 h-5 text-indigo shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><Fragment set:html={item.icon} /></svg>
            <span class="text-sm font-medium text-dark">{item.text}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- ─── Hoe het werkt ────────────────────────────────── -->
    <section id="hoe-het-werkt" class="max-w-7xl mx-auto px-6 lg:px-10 relative z-10 mb-20 md:mb-32">
      <div class="text-center mb-12 md:mb-16 reveal">
        <span class="inline-flex items-center gap-2 text-xs font-bold text-indigo uppercase tracking-[0.2em] mb-4">
          <span class="w-8 h-[2px] bg-indigo"></span>
          Werkwijze
          <span class="w-8 h-[2px] bg-indigo"></span>
        </span>
        <h2 class="font-display text-3xl md:text-5xl font-bold text-dark">
          Live in <span class="text-indigo">5 minuten.</span>
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        {steps.map((s, i) => (
          <div class="reveal relative" style={`transition-delay: ${i * 150}ms`}>
            <span class="font-display text-7xl md:text-8xl font-bold text-indigo/10 leading-none">{s.num}</span>
            <div class="mt-[-1rem] relative z-10">
              <h3 class="font-display font-bold text-xl text-dark mb-3">{s.title}</h3>
              <p class="text-text-secondary leading-relaxed text-sm">{s.desc}</p>
            </div>
            {i < steps.length - 1 && (
              <div class="hidden md:block absolute top-8 right-0 translate-x-1/2 w-12 text-indigo/20">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </div>
            )}
          </div>
        ))}
      </div>
    </section>

    <!-- ─── Interactive Demo ────────────────────────────── -->
    <section id="demo" class="max-w-5xl mx-auto px-6 lg:px-10 relative z-10 mb-20 md:mb-32">
      <div class="text-center mb-12 md:mb-16 reveal">
        <span class="inline-flex items-center gap-2 text-xs font-bold text-indigo uppercase tracking-[0.2em] mb-4">
          <span class="w-8 h-[2px] bg-indigo"></span>
          Probeer het zelf
          <span class="w-8 h-[2px] bg-indigo"></span>
        </span>
        <h2 class="font-display text-3xl md:text-5xl font-bold text-dark">
          Ervaar het <span class="text-indigo">live.</span>
        </h2>
        <p class="text-text-secondary mt-4 max-w-lg mx-auto">Vul het formulier in zoals je collega's dat zouden doen. Zo simpel is het.</p>
      </div>

      <div class="reveal">
        <!-- Browser Frame -->
        <div class="w-full bg-white rounded-[1.5rem] md:rounded-[2rem] shadow-2xl overflow-hidden border border-warm-grey/30">
          <!-- Chrome -->
          <div class="h-10 md:h-11 bg-[#f5f3ef] flex items-center px-4 gap-1.5 border-b border-warm-grey/15">
            <div class="w-2.5 h-2.5 rounded-full bg-[#FF5F57]"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-[#FEBC2E]"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-[#28C840]"></div>
            <div class="ml-3 flex-1 h-6 bg-white/80 rounded-lg border border-warm-grey/15 flex items-center px-3">
              <svg class="w-3 h-3 text-text-secondary/30 mr-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              <span class="text-[10px] md:text-xs text-text-secondary/40 font-mono">portal.jouwbedrijf.nl/social</span>
            </div>
          </div>

          <!-- Portal Content -->
          <div class="bg-slate-50">
            <!-- Portal Header -->
            <div class="bg-white border-b border-slate-200 px-5 md:px-8 py-4 flex items-center justify-between">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-indigo flex items-center justify-center">
                  <span class="text-white text-xs font-bold">A</span>
                </div>
                <span class="font-display font-bold text-dark text-sm md:text-base">Content Portal</span>
              </div>
              <div class="flex items-center gap-1.5 text-[10px] text-emerald-600 font-medium">
                <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                Online
              </div>
            </div>

            <!-- Tab Navigation -->
            <div class="px-5 md:px-8 pt-5 flex gap-2" id="demo-tabs">
              <button class="demo-tab active px-4 py-2 rounded-full text-xs font-bold transition-all duration-300 bg-indigo text-white" data-tab="social">Social content</button>
              <button class="demo-tab px-4 py-2 rounded-full text-xs font-bold transition-all duration-300 bg-slate-100 text-slate-500 hover:bg-slate-200" data-tab="nieuws">Nieuws</button>
              <button class="demo-tab px-4 py-2 rounded-full text-xs font-bold transition-all duration-300 bg-slate-100 text-slate-500 hover:bg-slate-200" data-tab="website">Website</button>
            </div>

            <!-- Form Panels -->
            <div class="p-5 md:p-8">
              <!-- Social Form -->
              <div id="demo-panel-social" class="demo-panel">
                <div class="bg-white rounded-2xl border border-slate-200 shadow-[0_8px_30px_rgb(0,0,0,0.04)] overflow-hidden">
                  <div class="h-1.5 bg-gradient-to-r from-indigo to-cyan-500"></div>
                  <div class="p-5 md:p-8 space-y-5">
                    <div>
                      <label class="block font-display font-semibold text-slate-800 mb-2 text-sm">Wat wil je delen? <span class="text-indigo">*</span></label>
                      <input type="text" placeholder="Bijv: Lancering nieuwe website klant X" class="demo-input w-full px-4 py-3 rounded-xl bg-slate-50 border border-slate-200 text-sm text-slate-900 focus:bg-white focus:outline-none focus:border-indigo/50 focus:ring-4 focus:ring-indigo/10 transition-all duration-300 placeholder-slate-400" />
                    </div>
                    <div class="grid md:grid-cols-2 gap-4">
                      <div>
                        <label class="block font-display font-semibold text-slate-800 mb-2 text-sm">Waar? <span class="text-slate-400 font-normal text-xs">(optioneel)</span></label>
                        <input type="text" placeholder="Bijv: Instagram, LinkedIn" class="demo-input w-full px-4 py-3 rounded-xl bg-slate-50 border border-slate-200 text-sm text-slate-900 focus:bg-white focus:outline-none focus:border-indigo/50 focus:ring-4 focus:ring-indigo/10 transition-all duration-300 placeholder-slate-400" />
                      </div>
                      <div>
                        <label class="block font-display font-semibold text-slate-800 mb-2 text-sm">Waarom?</label>
                        <input type="text" placeholder="Bijv: Nieuwe klanten aantrekken" class="demo-input w-full px-4 py-3 rounded-xl bg-slate-50 border border-slate-200 text-sm text-slate-900 focus:bg-white focus:outline-none focus:border-indigo/50 focus:ring-4 focus:ring-indigo/10 transition-all duration-300 placeholder-slate-400" />
                      </div>
                    </div>
                    <div>
                      <label class="block font-display font-semibold text-slate-800 mb-2 text-sm">Wanneer plaatsen?</label>
                      <div class="grid grid-cols-3 gap-2">
                        <label class="demo-timing relative cursor-pointer">
