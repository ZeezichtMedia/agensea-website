---
---

<div id="ai-search-modal" data-lenis-prevent role="dialog" aria-modal="true" aria-label="Agensea AI zoeken" aria-hidden="true" class="fixed inset-0 z-[2000] opacity-0 pointer-events-none hidden transition-all duration-500 overflow-hidden">
  <!-- Backdrop -->
  <div class="absolute inset-0 bg-dark/40 backdrop-blur-xl" id="ai-modal-backdrop"></div>
  
  <!-- Content Area -->
  <div class="relative h-full flex items-center justify-center p-4 sm:p-6 md:p-20">
    <div class="w-full max-w-4xl h-full max-h-[90vh] sm:max-h-[800px] bg-white rounded-[2rem] sm:rounded-[40px] shadow-2xl overflow-hidden flex flex-col md:flex-row translate-y-20 transition-all duration-700">

      <!-- Left: Sidebar / Personality -->
      <div class="w-full md:w-80 bg-indigo px-5 py-4 md:p-10 flex flex-col justify-between text-white relative md:max-h-none overflow-hidden">
        <!-- Mobile: compact header row -->
        <div class="relative z-10 flex md:block items-center gap-4">
          <div class="w-10 h-10 md:w-16 md:h-16 rounded-xl md:rounded-2xl bg-white/20 backdrop-blur-md flex items-center justify-center md:mb-8 border border-white/30 shrink-0">
            <svg class="w-5 h-5 md:w-8 md:h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41" />
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <h3 class="font-display text-lg md:text-3xl font-bold leading-tight md:mb-4">Vraag het ons</h3>
            <p class="hidden md:block text-white/60 text-sm leading-relaxed">
              Benieuwd wat we voor je kunnen betekenen? Stel je vraag en we helpen je direct verder.
            </p>
          </div>
          <!-- Close button integrated on mobile -->
          <button id="close-ai-search" type="button" aria-label="Sluit AI zoeken" class="md:hidden w-10 h-10 rounded-full bg-white/20 hover:bg-white/30 flex items-center justify-center transition-all interactive shrink-0">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path d="M18 6L6 18M6 6l12 12" />
            </svg>
          </button>
        </div>

        <div class="relative z-10 mt-3 md:mt-0 md:space-y-4">
          <div class="hidden md:block text-[10px] font-bold uppercase tracking-[0.2em] text-white/40">Suggesties</div>
          <div class="flex flex-wrap gap-1.5 md:gap-2">
            <button class="suggestion-btn px-3 md:px-4 py-1.5 md:py-2 rounded-full bg-white/10 hover:bg-white/20 border border-white/20 text-[11px] md:text-xs transition-colors interactive">Over Agensea</button>
            <button class="suggestion-btn px-3 md:px-4 py-1.5 md:py-2 rounded-full bg-white/10 hover:bg-white/20 border border-white/20 text-[11px] md:text-xs transition-colors interactive">Bekijk ons werk</button>
            <button class="suggestion-btn px-3 md:px-4 py-1.5 md:py-2 rounded-full bg-white/10 hover:bg-white/20 border border-white/20 text-[11px] md:text-xs transition-colors interactive">Onze diensten</button>
          </div>
        </div>

      </div>

      <!-- Right: Search/Chat Area -->
      <div class="flex-1 flex flex-col bg-white min-h-0">
        <!-- Close Button (desktop only) -->
        <div class="hidden md:flex justify-end p-6">
          <button id="close-ai-search-desktop" type="button" aria-label="Sluit AI zoeken" class="w-12 h-12 rounded-full bg-cream hover:bg-warm-grey flex items-center justify-center transition-all interactive">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M18 6L6 18M6 6l12 12" />
            </svg>
          </button>
        </div>

        <!-- Messages Area -->
        <div id="ai-chat-history" data-lenis-prevent class="flex-1 min-h-0 overflow-y-auto px-8 md:px-12 py-4 space-y-8 scroll-smooth">
          <!-- Welcome Message -->
          <div class="flex gap-4">
            <div class="w-8 h-8 rounded-lg bg-indigo flex-shrink-0 flex items-center justify-center text-white">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41" />
              </svg>
            </div>
            <div class="max-w-[80%]">
              <div class="bg-cream rounded-2xl rounded-tl-none p-5 text-dark leading-relaxed">
                Hey! Ik kan je alles vertellen over wat we doen, hoe we werken en wat we voor anderen hebben gebouwd. Vraag maar raak.
              </div>
              <span class="text-[10px] text-text-secondary/50 mt-2 block font-bold uppercase tracking-widest">Agensea AI • Nu</span>
            </div>
          </div>
        </div>

        <!-- Input Area -->
        <div class="p-4 sm:p-8 md:p-12 border-t border-warm-grey bg-cream/30">
          <div class="relative group">
            <input 
              type="text" 
              id="ai-search-input"
              placeholder="Stel je vraag..."
              class="w-full bg-white border-2 border-warm-grey rounded-2xl px-5 py-4 pr-14 md:px-8 md:py-5 md:pr-16 focus:border-indigo outline-none transition-all text-base md:text-lg shadow-sm group-hover:shadow-md"
            />
            <button id="ai-send-btn" class="absolute right-3 top-1/2 -translate-y-1/2 w-12 h-12 rounded-xl bg-indigo text-white flex items-center justify-center hover:scale-105 active:scale-95 transition-all shadow-lg interactive">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M5 12h14M12 5l7 7-7 7" />
              </svg>
            </button>
          </div>
          <div class="mt-4 flex items-center gap-2 text-[10px] text-text-secondary/40 font-bold uppercase tracking-widest">
            <span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"></span>
            Online
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Floating AI Button (Humanized) -->
<button
  id="ai-fab"
  type="button"
  aria-label="Open Agensea AI assistent"
  aria-controls="ai-search-modal"
  aria-expanded="false"
  class="fixed bottom-6 right-6 md:bottom-10 md:right-10 z-[1900] h-16 bg-white/80 backdrop-blur-xl text-dark shadow-2xl flex items-center gap-0 px-1 pr-6 rounded-full hover:gap-3 transition-all duration-500 interactive pointer-events-auto group overflow-hidden border border-warm-grey"
  title="Hulp nodig?"
>
  <!-- Avatar Trigger -->
  <div class="flex-shrink-0 w-14 h-14 rounded-full border-2 border-indigo bg-indigo overflow-hidden relative">
    <div 
      class="w-full h-full bg-cover bg-center transition-transform duration-500 group-hover:scale-110" 
      style="background-image: url('/team/ruben.webp');"
    ></div>
    <!-- Sparkle/AI badge -->
    <div class="absolute bottom-0 right-0 w-4 h-4 bg-indigo rounded-full flex items-center justify-center border border-white">
      <svg width="8" height="8" viewBox="0 0 24 24" fill="white">
        <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41" />
      </svg>
    </div>
  </div>
  
  <!-- Label -->
  <div class="flex flex-col items-start pl-3 transition-all duration-500 overflow-hidden max-w-[120px] opacity-100" id="fab-label">
    <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-indigo leading-none mb-1 whitespace-nowrap">Agensea AI</span>
    <span class="text-xs font-bold text-dark whitespace-nowrap">Hulp nodig?</span>
  </div>

  <!-- Active Indicator -->
  <span class="absolute top-2 right-2 w-2 h-2 bg-green-500 rounded-full animate-pulse transition-opacity duration-500" id="fab-indicator"></span>
</button>

<script>
  const modal = document.getElementById('ai-search-modal');
  const input = (document.getElementById('ai-search-input') as HTMLInputElement);
  const sendBtn = document.getElementById('ai-send-btn');
  const chatHistory = document.getElementById('ai-chat-history');
  const closeBtn = document.getElementById('close-ai-search');
  const closeBtnDesktop = document.getElementById('close-ai-search-desktop');
  const backdrop = document.getElementById('ai-modal-backdrop');
  const suggestionBtns = document.querySelectorAll('.suggestion-btn');
  const aiFab = document.getElementById('ai-fab');

  function openModal() {
    modal.classList.remove('hidden');
    modal.setAttribute('aria-hidden', 'false');
    aiFab?.setAttribute('aria-expanded', 'true');
    // Small delay so the transition can play after display changes
    requestAnimationFrame(() => {
      modal.classList.remove('opacity-0', 'pointer-events-none');
      modal.querySelector('.relative > div').classList.remove('translate-y-20');
    });
    document.body.style.overflow = 'hidden';
    if (window.lenis) window.lenis.stop();
    setTimeout(() => input.focus(), 500);
  }

  function closeModal() {
    modal.classList.add('opacity-0', 'pointer-events-none');
    modal.setAttribute('aria-hidden', 'true');
    aiFab?.setAttribute('aria-expanded', 'false');
    modal.querySelector('.relative > div').classList.add('translate-y-20');
    document.body.style.overflow = '';
    if (window.lenis) window.lenis.start();
    // Wait for transition to finish, then hide completely
    setTimeout(() => modal.classList.add('hidden'), 500);
  }

  // Sluit AI modal met Escape voor toetsenbordgebruikers.
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal && !modal.classList.contains('hidden')) {
      closeModal();
    }
  });

  function formatMessage(text) {
    // Markdown links [text](url) → clickable HTML
    let formatted = text.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" class="text-indigo underline underline-offset-2 hover:text-indigo-light transition-colors" target="_blank" rel="noopener">$1</a>');
    // Bold **text**
    formatted = formatted.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
    // Line breaks
    formatted = formatted.replace(/\n/g, '<br>');
    return formatted;
  }

  function addMessage(text, isUser = false) {
    const msg = document.createElement('div');
    msg.className = `flex gap-4 ${isUser ? 'flex-row-reverse' : ''}`;
    const displayText = isUser ? text : formatMessage(text);

    msg.innerHTML = `
      <div class="w-8 h-8 rounded-lg ${isUser ? 'bg-indigo text-white' : 'bg-indigo text-white'} flex-shrink-0 flex items-center justify-center">
        ${isUser ?
          `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>` :
          `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41" /></svg>`
        }
      </div>
      <div class="max-w-[80%] ${isUser ? 'text-right' : ''}">
        <div class="${isUser ? 'bg-indigo text-white rounded-tr-none' : 'bg-cream text-dark rounded-tl-none'} rounded-2xl p-5 shadow-sm leading-relaxed">
          ${displayText}
        </div>
        <span class="text-[10px] text-text-secondary/50 mt-2 block font-bold uppercase tracking-widest">
          ${isUser ? 'Jij' : 'Agensea AI'} • Nu
        </span>
      </div>
    `;
    
    chatHistory.appendChild(msg);
    chatHistory.scrollTop = chatHistory.scrollHeight;
  }

  let internalHistory = [];

  async function fetchResponse(query) {
    const thinking = document.createElement('div');
    thinking.className = "flex gap-4 thinking-msg";
    thinking.innerHTML = `
      <div class="w-8 h-8 rounded-lg bg-indigo text-white flex-shrink-0 flex items-center justify-center">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41" />
        </svg>
      </div>
      <div>
        <div class="bg-cream rounded-2xl rounded-tl-none p-5 flex gap-1">
          <span class="w-1.5 h-1.5 rounded-full bg-indigo/40 animate-bounce"></span>
          <span class="w-1.5 h-1.5 rounded-full bg-indigo/40 animate-bounce [animation-delay:0.2s]"></span>
          <span class="w-1.5 h-1.5 rounded-full bg-indigo/40 animate-bounce [animation-delay:0.4s]"></span>
        </div>
      </div>
    `;
    chatHistory.appendChild(thinking);
    chatHistory.scrollTop = chatHistory.scrollHeight;

    try {
      const res = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: query, history: internalHistory })
      });
      
      const data = await res.json();

      if (!res.ok) {
        throw new Error(data.error || "Server Error");
      }

      const responseText = data.response;
      
      thinking.remove();
      addMessage(responseText, false);
      
      internalHistory.push({ role: 'user', content: query });
      internalHistory.push({ role: 'assistant', content: responseText });
    } catch (err) {
      console.error("Agensea AI error:", err);
      thinking.remove();
      addMessage("Oeps, ik kon even geen verbinding maken. Neem gerust contact op via het contactformulier!", false);
    }
  }

  function handleSend() {
    const val = input.value.trim();
    if (!val) return;
    
    addMessage(val, true);
    input.value = '';
    fetchResponse(val);
  }

  // Force native scroll on chat by stopping event propagation to Lenis
  if (chatHistory) {
    chatHistory.addEventListener('wheel', (e) => e.stopPropagation(), { passive: false });
    chatHistory.addEventListener('touchstart', (e) => e.stopPropagation(), { passive: true });
    chatHistory.addEventListener('touchmove', (e) => e.stopPropagation(), { passive: true });
  }

  // Listeners
  window.addEventListener('open-ai-search', openModal);
  closeBtn?.addEventListener('click', closeModal);
  closeBtnDesktop?.addEventListener('click', closeModal);
  backdrop?.addEventListener('click', closeModal);
  aiFab?.addEventListener('click', openModal);
  
  sendBtn?.addEventListener('click', handleSend);
  input?.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') handleSend();
  });

  suggestionBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const text = btn.textContent;
      addMessage(text, true);
      fetchResponse(text);
    });
  });

  // Global trigger for testing
  (window as any).triggerAI = openModal;

  // Shrink FAB to avatar-only on mobile when scrolling
  if (aiFab && window.innerWidth < 768) {
    const fabLabel = document.getElementById('fab-label');
    const fabIndicator = document.getElementById('fab-indicator');
    let fabShrunk = false;
    let fabTicking = false;

    function updateFab() {
      const shouldShrink = window.pageYOffset > 100;
      if (shouldShrink && !fabShrunk) {
        fabShrunk = true;
        aiFab.classList.remove('pr-6');
        aiFab.classList.add('pr-1');
        if (fabLabel) { fabLabel.style.maxWidth = '0'; fabLabel.style.opacity = '0'; fabLabel.style.paddingLeft = '0'; }
        if (fabIndicator) fabIndicator.style.opacity = '0';
      } else if (!shouldShrink && fabShrunk) {
        fabShrunk = false;
        aiFab.classList.add('pr-6');
        aiFab.classList.remove('pr-1');
        if (fabLabel) { fabLabel.style.maxWidth = '120px'; fabLabel.style.opacity = '1'; fabLabel.style.paddingLeft = ''; }
        if (fabIndicator) fabIndicator.style.opacity = '1';
      }
      fabTicking = false;
    }

    window.addEventListener('scroll', () => {
      if (!fabTicking) {
        requestAnimationFrame(updateFab);
        fabTicking = true;
      }
    }, { passive: true });
  }
</script>

