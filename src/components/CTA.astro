<section id="contact" class="pt-12 pb-24 md:pt-24 md:pb-40 px-6 lg:px-10">
  <div class="max-w-7xl mx-auto">
    <div class="reveal max-w-3xl mx-auto text-center">
      <span class="inline-flex items-center gap-2 text-xs font-medium text-text-secondary uppercase tracking-[0.2em] mb-6">
        <span class="w-8 h-[1px] bg-indigo"></span>
        Ontdek de mogelijkheden
        <span class="w-8 h-[1px] bg-indigo"></span>
      </span>

      <h2 class="font-display text-4xl md:text-6xl font-bold leading-[1.1] mb-8">
        Zet de volgende stap in uw <span class="text-indigo">digitale groei.</span>
      </h2>

      <p class="text-lg text-text-secondary leading-relaxed mb-12 max-w-xl mx-auto">
        Neem contact op om strategisch te sparren over uw vraagstuk. Wij denken graag mee over de best passende oplossing voor uw organisatie.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="mailto:hallo@agensea.agency" class="magnetic-btn px-10 py-4 bg-indigo text-white rounded-xl font-medium text-base hover:bg-indigo-light transition-colors duration-300">
          Neem direct contact op
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M17 7H7M17 7V17"/></svg>
        </a>
        <a href="tel:+31612345678" class="magnetic-btn px-10 py-4 border border-warm-grey rounded-xl font-medium text-base text-text-secondary hover:border-dark hover:text-dark transition-all duration-300">
          +31 (0)6 12345678
        </a>
      </div>
    </div>
  </div>
</section>
