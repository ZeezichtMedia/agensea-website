---
---

<div 
  id="case-modal" 
  class="fixed inset-0 z-[1000] flex items-center justify-center p-6 md:p-12 opacity-0 pointer-events-none transition-all duration-500"
>
  <!-- Backdrop -->
  <div class="absolute inset-0 bg-dark/20 backdrop-blur-md" id="case-modal-close"></div>
  
  <!-- Modal Container -->
  <div class="relative bg-white rounded-3xl w-full max-w-5xl max-h-[85vh] overflow-hidden shadow-2xl translate-y-8 transition-all duration-500 flex flex-col md:flex-row">
    
    <!-- Left: Image/Visual -->
    <div class="w-full md:w-1/2 h-64 md:h-auto bg-warm-grey relative overflow-hidden">
      <img id="case-image" src="" alt="" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-t from-dark/40 to-transparent md:bg-gradient-to-r"></div>
    </div>
    
    <!-- Right: Content -->
    <div class="w-full md:w-1/2 p-8 md:p-12 overflow-y-auto">
      <button 
        id="case-modal-close-btn"
        class="absolute top-6 right-6 w-10 h-10 rounded-full bg-cream hover:bg-warm-grey flex items-center justify-center transition-colors interactive"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M18 6L6 18M6 6l12 12" />
        </svg>
      </button>

      <div class="mt-4">
        <span id="case-category" class="text-xs font-bold uppercase tracking-widest text-indigo mb-4 block"></span>
        <h2 id="case-title" class="font-display text-3xl md:text-5xl font-bold leading-tight mb-6"></h2>
        <div id="case-description" class="text-text-secondary text-lg leading-relaxed space-y-4"></div>
        
        <div class="mt-12">
          <a id="case-link" href="#" class="inline-flex items-center gap-2 group text-dark font-bold interactive">
            Bekijk volledige case
            <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M5 12h14M12 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  const cases = {
    adrz: {
      category: "Adrz Kniepolikliniek",
      title: "Doelgroepgerichte Patiëntencampagne",
      description: `
        <h4 class="font-bold text-dark mb-2">Vraagstuk</h4>
        <p class="mb-6">Het vergroten van de naamsbekendheid van de gespecialiseerde kniepolikliniek en het duidelijk informeren van patiënten om de instroom van relevante afspraken te verhogen.</p>
        
        <h4 class="font-bold text-dark mb-2">Wat Agensea heeft gedaan</h4>
        <p class="mb-6">Agensea verzorgde een strategische online campagne, specifiek ingericht op laagdrempeligheid en toegankelijke informatie. De boodschap en kanalen werden nauwkeurig afgestemd op de doelgroep.</p>
        
        <h4 class="font-bold text-dark mb-2">Resultaat</h4>
        <p>Een verhoogde bereikbaarheid van kwalitatieve medische informatie en een kwantificeerbare toename in het aantal gerichte afspraken bij de kniepolikliniek.</p>
      `,
      image: "https://images.unsplash.com/photo-1519494026892-80bbd2d6fd0d?q=80&w=2000",
    },
    dockwise: {
      category: "Dockwise",
      title: "Wereldwijde zichtbaarheid voor Dockwise",
      description: `
        <h4 class="font-bold text-dark mb-2">Vraagstuk</h4>
        <p class="mb-6">Wereldwijde positionering en effectieve employer branding voor de maritieme leider Dockwise.</p>
        
        <h4 class="font-bold text-dark mb-2">Wat Agensea heeft gedaan</h4>
        <p class="mb-6">Agensea ontwierp en implementeerde diverse marketingcampagnes gericht op de zakelijke propositie, waarbij data-gedreven advertenties gecombineerd werden met doelgerichte content.</p>

        <h4 class="font-bold text-dark mb-2">Resultaat</h4>
        <p>Een verstevigde internationale naamsbekendheid en een toename in gekwalificeerd bereik voor hun gespecialiseerde diensten.</p>
      `,
      image: "https://images.unsplash.com/photo-1494412519320-aa613dfb7738?q=80&w=2000",
    },
    kaap: {
      category: "De Kaap",
      title: "Digitaal Platform voor Innovatiehub",
      description: `
        <h4 class="font-bold text-dark mb-2">Vraagstuk</h4>
        <p class="mb-6">De Kaap zocht naar een centraal platform om diensten en ruimtes overzichtelijk te presenteren voor diverse doelgroepen, met strikte eisen voor toekomstige schaalbaarheid.</p>
        
        <h4 class="font-bold text-dark mb-2">Wat Agensea heeft gedaan</h4>
        <p class="mb-6">Agensea ontwikkelde een heldere, moderne website met een directe, op maat gemaakte integratie naar Bizner. Bezoekers vinden nu eenvoudig informatie en boeken ruimtes centraal.</p>
        
        <h4 class="font-bold text-dark mb-2">Resultaat</h4>
        <p>Een beheersbaar en modern platform dat de administratieve last verlaagt, de gebruikerservaring aanzienlijk verbetert en meegroeit met de hub.</p>
      `,
      image: "https://images.unsplash.com/photo-1497366216548-37526070297c?q=80&w=2000",
    }
  };

  const modal = document.getElementById('case-modal');
  const closeTriggers = [
    document.getElementById('case-modal-close'),
    document.getElementById('case-modal-close-btn')
  ];

  function openCase(id) {
    const caseData = cases[id];
    if (!caseData) return;

    // Update content
    document.getElementById('case-title').textContent = caseData.title;
    document.getElementById('case-category').textContent = caseData.category;
    document.getElementById('case-description').innerHTML = caseData.description;
    document.getElementById('case-image').src = caseData.image;

    // Show modal
    modal.classList.remove('opacity-0', 'pointer-events-none');
    modal.querySelector('.relative').classList.remove('translate-y-8');
    document.body.style.overflow = 'hidden';
  }

  function closeCase() {
    modal.classList.add('opacity-0', 'pointer-events-none');
    modal.querySelector('.relative').classList.add('translate-y-8');
    document.body.style.overflow = '';
  }

  // Event Listeners
  window.addEventListener('open-case', (e: any) => openCase(e.detail.id));
  closeTriggers.forEach(t => t?.addEventListener('click', closeCase));
</script>
