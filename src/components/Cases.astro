---
interface Props {
  categoryFilter?: string;
}

const { categoryFilter } = Astro.props;

const cases = [
  {
    id: "arieke",
    title: "Arieke van Liere",
    tag: "LinkedIn Campagne",
    category: "marketing",
    image: "/portfolio/arieke-van-liere.png",
  },
  {
    id: "adrz",
    title: "Adrz",
    tag: "Imago Campagne",
    category: "marketing",
    image: "/portfolio/adrz.png",
  },
  {
    id: "kaap",
    title: "Innovatiepunt KAAP",
    tag: "Awareness Campagne",
    category: "marketing",
    image: "/portfolio/innovatiepunt-kaap.png",
  },
  {
    id: "rd",
    title: "Bouwgroep R&D",
    tag: "Website",
    category: "website",
    image: "/portfolio/bouwgroep-rd.png",
  },
  {
    id: "boogaard",
    title: "Minicamping Boogaard",
    tag: "Website",
    category: "website",
    image: "/portfolio/minicamping-boogaard.webp",
  },
  {
    id: "assieraden",
    title: "Assieraden Specialist",
    tag: "Website",
    category: "website",
    image: "/portfolio/assieraden-specialist.webp",
  },
  {
    id: "bb",
    title: "B&B Voorste Eng",
    tag: "Website",
    category: "website",
    image: "/portfolio/bb-voorste-eng.png",
  },
  {
    id: "contentportal",
    title: "Content Portal",
    tag: "Software op maat",
    category: "software",
    image: "/portfolio/content-portal.png",
  },
  {
    id: "offertegenerator",
    title: "Offerte Generator",
    tag: "Software op maat",
    category: "software",
    image: "/portfolio/offerte-generator.png",
  },
  {
    id: "aikennisbank",
    title: "AI Kennisbank",
    tag: "Software op maat",
    category: "software",
    image: "/portfolio/ai-kennisbank.png",
  },
  {
    id: "dashboardtool",
    title: "Dashboard & Rapportage",
    tag: "Software op maat",
    category: "software",
    image: "/portfolio/dashboard-tool.png",
  },
];

const categories = [
  { id: 'all', label: 'Alles' },
  { id: 'website', label: 'Websites' },
  { id: 'marketing', label: 'Marketing' },
  { id: 'software', label: 'Software' },
];

const displayCases = categoryFilter 
  ? cases.filter(c => c.category === categoryFilter)
  : cases;
---

<section id="cases" class="pt-12 pb-16 md:pt-24 md:pb-24 px-6 lg:px-10 overflow-hidden">
  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="reveal flex flex-col lg:flex-row lg:items-end lg:justify-between gap-8 mb-16">
      <div class="max-w-xl">
        <span class="inline-flex items-center gap-2 text-xs font-medium text-text-secondary uppercase tracking-[0.2em] mb-4">
          <span class="w-8 h-[1px] bg-indigo"></span>
          Portfolio
        </span>
        <h2 class="font-display text-3xl md:text-5xl font-bold leading-tight">
          Recent werk
        </h2>
      </div>

      <!-- Filters (Only show if no strict categoryFilter is applied) -->
      {!categoryFilter && (
        <div class="flex flex-wrap gap-2 md:gap-4 p-1 bg-dark-lighter/30 rounded-full border border-white/5 w-fit">
          {categories.map((cat) => (
            <button
              class={`filter-btn px-5 py-2 rounded-full text-xs font-bold uppercase tracking-widest transition-all duration-300 interactive ${cat.id === 'all' ? 'active bg-white text-dark shadow-lg' : 'text-text-secondary hover:bg-white hover:text-dark'}`}
              data-filter={cat.id}
              aria-label={`Filter by ${cat.label}`}
            >
              {cat.label}
            </button>
          ))}
        </div>
      )}
    </div>
  </div>

  <!-- Horizontal Scroll Gallery -->
  <div class="relative group/gallery">
    <!-- Nav Arrows -->
    <button id="cases-prev" class="hidden md:flex absolute left-2 top-1/2 -translate-y-1/2 z-20 w-12 h-12 rounded-full bg-white shadow-lg border border-warm-grey/30 items-center justify-center hover:bg-indigo hover:text-white hover:border-indigo transition-all duration-300 opacity-0 group-hover/gallery:opacity-100 cursor-pointer" aria-label="Vorige">
      <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
    </button>
    <button id="cases-next" class="hidden md:flex absolute right-2 top-1/2 -translate-y-1/2 z-20 w-12 h-12 rounded-full bg-white shadow-lg border border-warm-grey/30 items-center justify-center hover:bg-indigo hover:text-white hover:border-indigo transition-all duration-300 opacity-0 group-hover/gallery:opacity-100 cursor-pointer" aria-label="Volgende">
      <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </button>
    <div id="cases-grid" class="flex gap-6 md:gap-8 px-6 lg:px-10 overflow-x-auto pb-8 scrollbar-hide scroll-smooth select-none">
      {displayCases.map((item, i) => (
        <div 
          class="reveal case-card group block w-[280px] md:w-[380px] shrink-0 interactive" 
          data-category={item.category}
          data-id={item.id}
          style={`animation-delay: ${i * 0.1}s;`}
        >
          <!-- Image Card -->
          <div class="relative aspect-[3/4] rounded-2xl overflow-hidden mb-5 bg-dark cursor-pointer case-trigger">
            <img
              src={item.image}
              alt={item.title}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" style="image-rendering: -webkit-optimize-contrast;"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent"></div>
            <span class="absolute top-4 left-4 px-4 py-1.5 rounded-full bg-black/40 backdrop-blur-lg text-[10px] font-bold text-white uppercase tracking-widest shadow-lg">
              {item.tag}
            </span>
            <!-- Expand hint -->
            <div class="absolute bottom-4 right-4 w-8 h-8 rounded-full bg-white/10 backdrop-blur-md border border-white/10 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <svg class="w-3.5 h-3.5 text-white transition-transform duration-300 group-hover:scale-110" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg>
            </div>
          </div>
          
          <!-- Title -->
          <h3 class="font-display text-lg md:text-xl font-bold group-hover:text-indigo transition-colors flex items-center justify-between cursor-pointer case-trigger">
            {item.title}
            <svg class="w-4 h-4 opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </h3>
        </div>
      ))}
    </div>
    
    <!-- Gradient Overlays -->
    <div class="absolute left-0 top-0 bottom-0 w-32 bg-gradient-to-r from-cream to-transparent pointer-events-none z-10 opacity-0 md:opacity-100"></div>
    <div class="absolute right-0 top-0 bottom-0 w-32 bg-gradient-to-l from-cream to-transparent pointer-events-none z-10 opacity-0 md:opacity-100"></div>
  </div>
</section>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .case-card {
    transition: opacity 0.4s ease, transform 0.4s ease;
    max-width: 380px;
  }

  .case-card.filtered-out {
    opacity: 0;
    transform: scale(0.95);
    pointer-events: none;
    position: absolute;
    width: 0;
    height: 0;
    overflow: hidden;
    margin: 0;
    padding: 0;
  }

  @media (max-width: 767px) {
    .case-card {
      max-width: 280px;
    }
  }

  .case-detail {
    transition: max-height 0.5s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.4s ease;
  }

  .case-card.expanded .expand-icon {
    transform: rotate(180deg);
  }
</style>

<script>
  // Filter logic
  const filterBtns = document.querySelectorAll('.filter-btn');
  const caseCards = document.querySelectorAll('.case-card');
  const grid = document.getElementById('cases-grid');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.getAttribute('data-filter');

      filterBtns.forEach(b => {
        b.classList.remove('active', 'bg-white', 'text-dark', 'shadow-lg');
        b.classList.add('text-text-secondary');
      });
      btn.classList.add('active', 'bg-white', 'text-dark', 'shadow-lg');
      btn.classList.remove('text-text-secondary');

      caseCards.forEach((card: any) => {
        const category = card.getAttribute('data-category');
        if (filter === 'all' || category === filter) {
          card.classList.remove('filtered-out');
        } else {
          card.classList.add('filtered-out');
        }
      });
      
      if (grid) grid.scrollLeft = 0;
    });
  });

  // Drag to scroll logic
  let isDown = false;
  let startX: number;
  let scrollLeft: number;
  let isDragging = false;

  if (grid) {
    grid.style.cursor = 'grab';

    grid.addEventListener('mousedown', (e) => {
      isDown = true;
      isDragging = false;
      grid.style.cursor = 'grabbing';
      startX = e.pageX - grid.offsetLeft;
      scrollLeft = grid.scrollLeft;
      // Prevent text selection while dragging
      e.preventDefault();
    });
    
    grid.addEventListener('mouseleave', () => {
      isDown = false;
      grid.style.cursor = 'grab';
    });
    
    grid.addEventListener('mouseup', () => {
      isDown = false;
      grid.style.cursor = 'grab';
    });
    
    grid.addEventListener('mousemove', (e) => {
      if (!isDown) return;
      e.preventDefault();
      const x = e.pageX - grid.offsetLeft;
      const walk = (x - startX) * 2;
      
      if (Math.abs(walk) > 5) {
        isDragging = true;
      }
      grid.scrollLeft = scrollLeft - walk;
    });
  }

  // Arrow navigation
  const prevBtn = document.getElementById('cases-prev');
  const nextBtn = document.getElementById('cases-next');
  const scrollAmount = 400;
  prevBtn?.addEventListener('click', () => {
    grid?.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
  });
  nextBtn?.addEventListener('click', () => {
    grid?.scrollBy({ left: scrollAmount, behavior: 'smooth' });
  });

  // Open Modal logic
  document.querySelectorAll('.case-trigger').forEach(trigger => {
    trigger.addEventListener('click', (e) => {
      e.preventDefault();
      
      // Prevent click if we were dragging the carousel
      if (isDragging) return;

      const card = (trigger as HTMLElement).closest('.case-card');
      if (!card) return;

      const caseId = card.getAttribute('data-id');
      if (caseId) {
        window.dispatchEvent(new CustomEvent('open-case', { detail: { id: caseId } }));
      }
    });
  });
</script>
