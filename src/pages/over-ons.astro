---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
import TeamPopup from '../components/TeamPopup.astro';
import jorikFoto from '../assets/team/Jorik_foto.webp';
import jorianFoto from '../assets/team/Jorian_foto.webp';
import rubenFoto from '../assets/team/Ruben_foto.webp';
import alineFoto from '../assets/team/Aline_foto.webp';
---

<Layout
  title="Over Ons"
  description="Maak kennis met het team achter Agensea. Een nuchter Zeeuws bureau met passie voor techniek, design en resultaat. Gevestigd op de Edisonweg in Vlissingen."
>
  <Navbar />
  
  <main id="main-content" class="pt-32 pb-16 md:pt-48 md:pb-24 overflow-hidden">
    
    <!-- Hero Section -->
    <section class="px-6 lg:px-10 max-w-7xl mx-auto mb-20 md:mb-32">
      <div class="max-w-4xl">
        <span class="reveal inline-flex items-center gap-2 text-xs font-bold text-indigo uppercase tracking-[0.2em] mb-6">
          <span class="w-8 h-[2px] bg-indigo"></span>
          Het bureau
        </span>
        <h1 class="reveal font-display text-4xl sm:text-5xl md:text-7xl lg:text-8xl font-bold leading-[1.05] text-dark mb-8 tracking-tight">
          Dit is <span class="text-indigo">Agensea.</span>
        </h1>
        <p class="reveal text-lg md:text-xl text-text-secondary leading-relaxed max-w-2xl font-light delay-200">
          Agensea is een digitaal bureau uit Zeeland. We bouwen websites, doen online marketing en denken mee over strategie. Korte lijnen, eerlijk advies en werk waar je iets aan hebt. Niet meer, niet minder.
        </p>
      </div>
    </section>

    <!-- The Team Section -->
    <section class="px-6 lg:px-10 max-w-7xl mx-auto mb-20 md:mb-32">
      <div class="reveal mb-12 flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div>
          <h2 class="font-display text-4xl md:text-5xl font-bold text-dark mb-4 group cursor-pointer">
            Ontmoet de <span class="text-indigo transition-colors duration-300">gezichten.</span>
          </h2>
          <p class="text-text-secondary text-base md:text-lg max-w-xl leading-relaxed">
            Dit is het team achter Agensea. Klik op een profiel om meer te weten te komen.
          </p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
        
        <!-- Jorik -->
        <button 
          class="reveal flex flex-col interactive text-left group"
          onclick="window.dispatchEvent(new CustomEvent('open-team-member', { detail: { id: 'jorik' } }))"
        >
          <div class="w-full aspect-[4/5] bg-warm-grey rounded-2xl mb-6 overflow-hidden relative border border-warm-grey/50">
            <Image src={jorikFoto} alt="Jorik Schut" widths={[400, 600, 800]} sizes="(min-width: 768px) 33vw, 100vw" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />

            <!-- Overlay hover effect -->
            <div class="absolute inset-x-0 bottom-0 top-1/2 bg-gradient-to-t from-dark/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <div class="absolute bottom-6 right-6 w-12 h-12 bg-white text-dark rounded-full flex items-center justify-center opacity-0 translate-y-4 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-500 shadow-xl">
              <svg class="w-5 h-5 -rotate-45" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
          </div>
          <h3 class="font-display text-2xl font-bold text-dark group-hover:text-indigo transition-colors">Jorik Schut</h3>
          <span class="text-sm font-medium text-text-secondary mt-1">Online marketing specialist</span>
        </button>

        <!-- Jorian -->
        <button 
          class="reveal flex flex-col interactive text-left group delay-100"
          onclick="window.dispatchEvent(new CustomEvent('open-team-member', { detail: { id: 'jorian' } }))"
        >
          <div class="w-full aspect-[4/5] bg-warm-grey rounded-2xl mb-6 overflow-hidden relative border border-warm-grey/50">
            <Image src={jorianFoto} alt="Jorian Wientjens" widths={[400, 600, 800]} sizes="(min-width: 768px) 33vw, 100vw" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />

            <div class="absolute inset-x-0 bottom-0 top-1/2 bg-gradient-to-t from-dark/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <div class="absolute bottom-6 right-6 w-12 h-12 bg-white text-dark rounded-full flex items-center justify-center opacity-0 translate-y-4 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-500 shadow-xl">
              <svg class="w-5 h-5 -rotate-45" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
          </div>
          <h3 class="font-display text-2xl font-bold text-dark group-hover:text-indigo transition-colors">Jorian Wientjens</h3>
          <span class="text-sm font-medium text-text-secondary mt-1">Developer / Technical specialist</span>
        </button>

        <!-- Ruben -->
        <button 
          class="reveal flex flex-col interactive text-left group delay-200"
          onclick="window.dispatchEvent(new CustomEvent('open-team-member', { detail: { id: 'ruben' } }))"
        >
          <div class="w-full aspect-[4/5] bg-warm-grey rounded-2xl mb-6 overflow-hidden relative border border-warm-grey/50">
            <Image src={rubenFoto} alt="Ruben Boogaard" widths={[400, 600, 800]} sizes="(min-width: 768px) 33vw, 100vw" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />

            <div class="absolute inset-x-0 bottom-0 top-1/2 bg-gradient-to-t from-dark/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <div class="absolute bottom-6 right-6 w-12 h-12 bg-white text-dark rounded-full flex items-center justify-center opacity-0 translate-y-4 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-500 shadow-xl">
              <svg class="w-5 h-5 -rotate-45" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
          </div>
          <h3 class="font-display text-2xl font-bold text-dark group-hover:text-indigo transition-colors">Ruben Boogaard</h3>
          <span class="text-sm font-medium text-text-secondary mt-1">Account Manager</span>
        </button>

      </div>
    </section>

    <!-- Freelancers / Flex-schil -->
    <section class="px-6 lg:px-10 max-w-7xl mx-auto mb-10">
      <div class="bg-indigo text-white rounded-[3rem] p-10 md:p-16 lg:p-20 relative overflow-hidden">
        
        <!-- Abstract background elements -->
        <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-white/5 rounded-full blur-[100px] translate-x-1/3 -translate-y-1/3"></div>
        <div class="absolute -bottom-20 -left-20 w-[400px] h-[400px] bg-[#4353FF]/50 rounded-full blur-[80px]"></div>

        <div class="relative z-10 grid md:grid-cols-2 gap-12 items-start mb-20">
          <div class="reveal">
            <span class="inline-flex items-center gap-2 text-xs font-bold text-white/70 uppercase tracking-[0.2em] mb-4">
              <span class="w-6 h-[2px] bg-white/50"></span>
              Onze specialisten
            </span>
            <h2 class="font-display text-4xl md:text-5xl lg:text-5xl font-bold leading-[1.1] mb-6">
              Vaste <span class="text-white/60">freelancers.</span>
            </h2>
            <p class="text-white/80 text-lg leading-relaxed mb-8 max-w-md">
              Voor grotere projecten werken we samen met vaste freelancers die we goed kennen. Denk aan copywriters, designers en ontwikkelaars met specifieke expertise. Zo houden we het team klein, maar kunnen we opschalen wanneer het nodig is.
            </p>
          </div>

          <!-- Highlighted Freelancers Grid -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 md:gap-8 reveal delay-200">
            <!-- Aline -->
            <div class="flex flex-col text-left group">
              <div class="w-full aspect-[4/5] bg-white/10 backdrop-blur-sm rounded-2xl mb-4 overflow-hidden relative border border-white/20">
                <Image src={alineFoto} alt="Aline Bijleveld" widths={[300, 500]} sizes="(min-width: 768px) 25vw, 50vw" class="w-full h-full object-cover" />
              </div>
              <h4 class="font-display text-lg font-bold text-white">Aline Bijleveld</h4>
              <span class="text-xs font-medium text-white/60 mt-0.5">Communicatie Strategist</span>
            </div>

            <!-- Phaedra -->
            <div class="flex flex-col text-left group">
              <div class="w-full aspect-[4/5] bg-white/10 backdrop-blur-sm rounded-2xl mb-4 overflow-hidden relative border border-white/20">
                <div class="w-full h-full bg-cover bg-center" style="background-image: url('/team/phaedra.png');"></div>
              </div>
              <h4 class="font-display text-lg font-bold text-white">Phaedra Tenu</h4>
              <span class="text-xs font-medium text-white/60 mt-0.5">Communicatie specialist</span>
            </div>
          </div>
        </div>

        <div class="relative z-10 border-t border-white/10 pt-10 flex flex-col md:flex-row items-center justify-between gap-8">
          <div class="flex items-center gap-6">
            <div class="flex -space-x-3">
              <div class="w-12 h-12 rounded-full border-2 border-indigo bg-white/20 backdrop-blur flex items-center justify-center">
                 <svg class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              </div>
              <div class="w-12 h-12 rounded-full border-2 border-indigo bg-white/20 backdrop-blur flex items-center justify-center">
                 <svg class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15.05 5A5 5 0 0 1 19 8.95M15.05 1A9 9 0 0 1 23 8.94m-1 7.98v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              </div>
              <div class="w-12 h-12 rounded-full border-2 border-indigo bg-white/20 backdrop-blur flex items-center justify-center">
                 <svg class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="M2 2l7.586 7.586"/><circle cx="11" cy="11" r="2"/></svg>
              </div>
            </div>
            <div>
              <p class="text-sm font-medium text-white">Toegang tot een breed netwerk</p>
              <p class="text-xs text-white/60">Gespecialiseerde experts voor elke uitdaging</p>
            </div>
          </div>
          
          <div class="inline-flex items-center gap-3 px-6 py-3 bg-white/10 backdrop-blur-md rounded-2xl border border-white/10">
            <div class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></div>
            <span class="text-xs font-bold uppercase tracking-widest text-white/90">Ready to scale</span>
          </div>
        </div>

      </div>
    </section>

    <CTA />
  </main>

  <Footer />
  <TeamPopup />
</Layout>
