---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import BlogCard from "../../components/blog/BlogCard.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

const posts = await getCollection("blog", ({ data }) => data.draft !== true);
const sortedPosts = posts.sort(
    (a: CollectionEntry<"blog">, b: CollectionEntry<"blog">) =>
        b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
) as CollectionEntry<"blog">[];

// Get unique categories
const categories = [
    ...new Set(sortedPosts.map((p) => p.data.category).filter(Boolean)),
] as string[];
---

<Layout
    title="Kennisbank"
    description="Onze nieuwste inzichten en kennis over webdevelopment, marketing en AI."
>
    <script slot="head" type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://agensea.nl/" },
        { "@type": "ListItem", "position": 2, "name": "Kennisbank", "item": "https://agensea.nl/kennisbank/" }
      ]
    })} />
    <Navbar />
    <main id="main-content" class="min-h-screen pt-40 pb-20">
        <div class="max-w-7xl mx-auto px-6">
            <div class="mb-16">
                <h1
                    class="text-5xl md:text-7xl font-display font-bold text-dark tracking-tight mb-4"
                >
                    Onze <span class="text-indigo">Inzichten</span>.
                </h1>
                <p class="text-xl text-dark/70 max-w-2xl font-sans">
                    Ontdek de laatste trends, tips en verhalen over webdesign,
                    AI en online marketing.
                </p>
            </div>

            <!-- Featured guides -->
            <div class="mb-16">
                <div class="flex items-baseline justify-between mb-6">
                    <h2 class="font-display font-bold text-2xl md:text-3xl text-dark">Gidsen</h2>
                    <span class="text-xs text-dark/40 uppercase tracking-widest font-bold">Pillar-content</span>
                </div>
                <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
                    <a href="/gids/geo" class="group block bg-dark text-white rounded-[2rem] p-8 relative overflow-hidden hover:scale-[1.01] transition-transform duration-300">
                        <div class="absolute top-0 right-0 w-72 h-72 bg-indigo/30 rounded-full blur-3xl pointer-events-none"></div>
                        <div class="relative z-10">
                            <div class="flex items-center gap-2 mb-4">
                                <span class="inline-flex items-center gap-2 px-2.5 py-1 bg-indigo/20 border border-indigo/40 rounded-full text-[10px] font-bold text-indigo uppercase tracking-[0.2em]">
                                    <span class="w-1.5 h-1.5 rounded-full bg-indigo animate-pulse"></span>
                                    Marketing · SEO
                                </span>
                            </div>
                            <h3 class="font-display font-bold text-xl md:text-2xl leading-[1.15] mb-3">
                                GEO: <span class="text-indigo">Generative Engine Optimization</span>
                            </h3>
                            <p class="text-white/70 leading-relaxed mb-6 text-sm">
                                Zo word je gevonden in ChatGPT, Perplexity en Gemini.
                            </p>
                            <span class="inline-flex items-center gap-2 text-sm font-bold text-indigo group-hover:text-white transition-colors">
                                Lees gids
                                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                            </span>
                        </div>
                    </a>
                    <a href="/gids/ai-automation" class="group block bg-dark text-white rounded-[2rem] p-8 relative overflow-hidden hover:scale-[1.01] transition-transform duration-300">
                        <div class="absolute top-0 right-0 w-72 h-72 bg-violet/30 rounded-full blur-3xl pointer-events-none"></div>
                        <div class="relative z-10">
                            <div class="flex items-center gap-2 mb-4">
                                <span class="inline-flex items-center gap-2 px-2.5 py-1 bg-violet/20 border border-violet/40 rounded-full text-[10px] font-bold text-violet uppercase tracking-[0.2em]">
                                    <span class="w-1.5 h-1.5 rounded-full bg-violet animate-pulse"></span>
                                    Software · Automation
                                </span>
                            </div>
                            <h3 class="font-display font-bold text-xl md:text-2xl leading-[1.15] mb-3">
                                AI-automation voor <span class="text-violet">MKB</span>
                            </h3>
                            <p class="text-white/70 leading-relaxed mb-6 text-sm">
                                Van Zapier + LLM tot custom agents. Welk type past wanneer, wat kost het.
                            </p>
                            <span class="inline-flex items-center gap-2 text-sm font-bold text-violet group-hover:text-white transition-colors">
                                Lees gids
                                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                            </span>
                        </div>
                    </a>
                    <a href="/gids/ai-first-websites" class="group block bg-dark text-white rounded-[2rem] p-8 relative overflow-hidden hover:scale-[1.01] transition-transform duration-300">
                        <div class="absolute top-0 right-0 w-72 h-72 bg-indigo/20 rounded-full blur-3xl pointer-events-none"></div>
                        <div class="absolute bottom-0 left-0 w-56 h-56 bg-violet/20 rounded-full blur-3xl pointer-events-none"></div>
                        <div class="relative z-10">
                            <div class="flex items-center gap-2 mb-4">
                                <span class="inline-flex items-center gap-2 px-2.5 py-1 bg-indigo/20 border border-indigo/40 rounded-full text-[10px] font-bold text-indigo uppercase tracking-[0.2em]">
                                    <span class="w-1.5 h-1.5 rounded-full bg-indigo animate-pulse"></span>
                                    Websites
                                </span>
                            </div>
                            <h3 class="font-display font-bold text-xl md:text-2xl leading-[1.15] mb-3">
                                AI-first <span class="text-indigo">websites</span>
                            </h3>
                            <p class="text-white/70 leading-relaxed mb-6 text-sm">
                                Bouwstenen, stack-keuzes, AI-features en kosten van AI-first websites.
                            </p>
                            <span class="inline-flex items-center gap-2 text-sm font-bold text-indigo group-hover:text-white transition-colors">
                                Lees gids
                                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                            </span>
                        </div>
                    </a>
                    <a href="/gids/ai-marketing" class="group block bg-dark text-white rounded-[2rem] p-8 relative overflow-hidden hover:scale-[1.01] transition-transform duration-300">
                        <div class="absolute top-0 right-0 w-72 h-72 bg-violet/25 rounded-full blur-3xl pointer-events-none"></div>
                        <div class="absolute bottom-0 right-0 w-56 h-56 bg-indigo/20 rounded-full blur-3xl pointer-events-none"></div>
                        <div class="relative z-10">
                            <div class="flex items-center gap-2 mb-4">
                                <span class="inline-flex items-center gap-2 px-2.5 py-1 bg-violet/20 border border-violet/40 rounded-full text-[10px] font-bold text-violet uppercase tracking-[0.2em]">
                                    <span class="w-1.5 h-1.5 rounded-full bg-violet animate-pulse"></span>
                                    Marketing
                                </span>
                            </div>
                            <h3 class="font-display font-bold text-xl md:text-2xl leading-[1.15] mb-3">
                                AI-marketing voor <span class="text-violet">MKB</span>
                            </h3>
                            <p class="text-white/70 leading-relaxed mb-6 text-sm">
                                Content, ads, personalisatie. Welke AI-workflows leveren echt ROI?
                            </p>
                            <span class="inline-flex items-center gap-2 text-sm font-bold text-violet group-hover:text-white transition-colors">
                                Lees gids
                                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                            </span>
                        </div>
                    </a>
                    <a href="/gids/ai-strategie" class="group block bg-dark text-white rounded-[2rem] p-8 relative overflow-hidden hover:scale-[1.01] transition-transform duration-300">
                        <div class="absolute top-0 right-0 w-72 h-72 bg-indigo/25 rounded-full blur-3xl pointer-events-none"></div>
                        <div class="absolute bottom-0 left-0 w-56 h-56 bg-violet/15 rounded-full blur-3xl pointer-events-none"></div>
                        <div class="relative z-10">
                            <div class="flex items-center gap-2 mb-4">
                                <span class="inline-flex items-center gap-2 px-2.5 py-1 bg-indigo/20 border border-indigo/40 rounded-full text-[10px] font-bold text-indigo uppercase tracking-[0.2em]">
                                    <span class="w-1.5 h-1.5 rounded-full bg-indigo animate-pulse"></span>
                                    Directie · Strategie
                                </span>
                            </div>
                            <h3 class="font-display font-bold text-xl md:text-2xl leading-[1.15] mb-3">
                                AI-strategie voor <span class="text-indigo">MKB</span>
                            </h3>
                            <p class="text-white/70 leading-relaxed mb-6 text-sm">
                                Readiness, governance, budget en roadmap — voor mkb-directies.
                            </p>
                            <span class="inline-flex items-center gap-2 text-sm font-bold text-indigo group-hover:text-white transition-colors">
                                Lees gids
                                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                            </span>
                        </div>
                    </a>
                </div>
            </div>

            <!-- Category Filter -->
            {
                categories.length > 0 && (
                    <div class="flex flex-wrap gap-2 mb-12">
                        <button
                            data-filter="all"
                            class="filter-btn active px-4 py-2 text-xs font-bold uppercase tracking-widest rounded-full border border-indigo bg-indigo text-white transition-all"
                        >
                            Alles
                        </button>
                        {categories.map((cat) => (
                            <button
                                data-filter={cat}
                                class="filter-btn px-4 py-2 text-xs font-bold uppercase tracking-widest rounded-full border border-dark/10 text-dark/50 hover:border-indigo hover:text-indigo transition-all"
                            >
                                {cat}
                            </button>
                        ))}
                    </div>
                )
            }

            <div
                class="grid md:grid-cols-2 lg:grid-cols-3 gap-8"
                id="posts-grid"
            >
                {sortedPosts.map((post) => <BlogCard post={post} />)}
            </div>
        </div>
    </main>
    <Footer />
</Layout>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const buttons = document.querySelectorAll(".filter-btn");
        const cards = document.querySelectorAll(".blog-card");

        buttons.forEach((btn) => {
            btn.addEventListener("click", () => {
                const filter = (btn as HTMLElement).dataset.filter;

                // Update active state
                buttons.forEach((b) => {
                    b.classList.remove(
                        "active",
                        "bg-indigo",
                        "text-white",
                        "border-indigo",
                    );
                    b.classList.add("border-dark/10", "text-dark/50");
                });
                btn.classList.add(
                    "active",
                    "bg-indigo",
                    "text-white",
                    "border-indigo",
                );
                btn.classList.remove("border-dark/10", "text-dark/50");

                // Filter cards
                cards.forEach((card) => {
                    const cardEl = card as HTMLElement;
                    const cat = cardEl.dataset.category;
                    if (filter === "all" || cat === filter) {
                        cardEl.style.display = "";
                        cardEl.style.opacity = "1";
                    } else {
                        cardEl.style.display = "none";
                    }
                });
            });
        });
    });
</script>
