---
---

<div
  id="case-modal"
  class="fixed inset-0 z-[1000] flex items-center justify-center p-6 md:p-12 pointer-events-none overscroll-none"
  role="dialog"
  aria-modal="true"
  aria-labelledby="case-title"
  aria-hidden="true"
>
  <!-- Backdrop — snelle fade (150ms) zodat blur direct beschikbaar is -->
  <div
    id="case-modal-close"
    class="absolute inset-0 bg-dark/20 backdrop-blur-md opacity-0 transition-opacity duration-150"
    aria-hidden="true"
  ></div>

  <!-- Modal Container — eigen slower slide+fade voor soepele entry -->
  <div class="relative bg-white rounded-3xl w-full max-w-5xl max-h-[85vh] shadow-2xl opacity-0 translate-y-8 transition-all duration-500 flex flex-col md:flex-row overflow-hidden">

    <!-- Left: Image/Visual -->
    <div class="w-full md:w-1/2 h-48 sm:h-64 md:h-auto bg-warm-grey relative overflow-hidden shrink-0">
      <img id="case-image" src="" alt="" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-t from-dark/40 to-transparent md:bg-gradient-to-r" aria-hidden="true"></div>
    </div>

    <!-- Right: Content -->
    <div id="case-content-scroll" class="w-full md:w-1/2 p-6 md:p-12 relative overflow-y-auto overscroll-contain" style="-webkit-overflow-scrolling: touch; touch-action: pan-y;">
      <button
        id="case-modal-close-btn"
        type="button"
        aria-label="Sluit case"
        class="absolute top-6 right-6 w-10 h-10 rounded-full bg-cream hover:bg-warm-grey flex items-center justify-center transition-colors interactive"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M18 6L6 18M6 6l12 12" />
        </svg>
      </button>

      <div class="mt-4">
        <span id="case-category" class="text-xs font-bold uppercase tracking-widest text-indigo mb-4 block"></span>
        <h2 id="case-title" class="font-display text-3xl md:text-5xl font-bold leading-tight mb-6"></h2>
        <div id="case-description" class="text-text-secondary text-lg leading-relaxed space-y-4"></div>
        
        <div id="case-link-container" class="mt-10 hidden">
          <a id="case-link" href="#" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 group text-white bg-dark px-6 py-3 rounded-full font-bold hover:bg-indigo transition-colors interactive">
            Bekijk live website
            <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>

    </div>
    <!-- Scroll indicator -->
    <div id="case-scroll-hint" class="absolute bottom-0 left-1/2 md:left-3/4 -translate-x-1/2 flex justify-center py-3 px-4 bg-gradient-to-t from-white via-white/95 to-transparent pointer-events-none w-full md:w-1/2 z-10">
      <div class="flex flex-col items-center gap-1 animate-bounce">
        <svg class="w-5 h-5 text-indigo/50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
        <span class="text-[10px] font-bold text-text-secondary/40 uppercase tracking-widest">Scroll</span>
      </div>
    </div>
  </div>
</div>

<script>
  // Lenis types staan globaal in src/env.d.ts
  // Cases data komt uit één centrale bron — gedeeld met Cases.astro.
  import { casesById } from "../data/cases";

  const modal = document.getElementById('case-modal');
  const closeTriggers = [
    document.getElementById('case-modal-close'),
    document.getElementById('case-modal-close-btn')
  ];
  const closeBtn = document.getElementById('case-modal-close-btn') as HTMLButtonElement | null;

  // Onthoud welk element focus had vóór de modal opende, zodat we 'm
  // kunnen herstellen bij sluiten — vereiste voor WCAG focus management.
  let lastFocusedEl: HTMLElement | null = null;

  // Focus-trap: vang Tab in en houd focus binnen de modal.
  function getFocusable(container: HTMLElement): HTMLElement[] {
    return Array.from(
      container.querySelectorAll<HTMLElement>(
        'a[href], button:not([disabled]), textarea, input, select, [tabindex]:not([tabindex="-1"])'
      )
    ).filter((el) => !el.hasAttribute('aria-hidden') && el.offsetParent !== null);
  }

  function trapFocus(e: KeyboardEvent) {
    if (!modal || e.key !== 'Tab') return;
    const focusables = getFocusable(modal);
    if (focusables.length === 0) return;
    const first = focusables[0];
    const last = focusables[focusables.length - 1];
    const active = document.activeElement as HTMLElement | null;
    if (e.shiftKey && active === first) {
      e.preventDefault();
      last.focus();
    } else if (!e.shiftKey && active === last) {
      e.preventDefault();
      first.focus();
    }
  }

  function onKeyDown(e: KeyboardEvent) {
    if (e.key === 'Escape') {
      closeCase();
    } else if (e.key === 'Tab') {
      trapFocus(e);
    }
  }

  function openCase(id: string) {
    const caseData = casesById[id];
    if (!caseData || !modal) return;

    lastFocusedEl = document.activeElement as HTMLElement | null;

    const titleEl = document.getElementById('case-title');
    const catEl = document.getElementById('case-category');
    const descEl = document.getElementById('case-description');
    const imgEl = document.getElementById('case-image') as HTMLImageElement | null;

    if (titleEl) titleEl.textContent = caseData.title;
    if (catEl) catEl.textContent = caseData.tag;
    // description bevat trusted, ontwikkelaar-geschreven HTML — geen user input.
    if (descEl) descEl.innerHTML = caseData.description;
    if (imgEl) {
      imgEl.src = caseData.image;
      // Vul alt dynamisch met tag + titel zodat screen readers context krijgen.
      imgEl.alt = caseData.imageAlt || `${caseData.tag} — ${caseData.title}`;
    }

    // Handle optional external link
    const linkContainer = document.getElementById('case-link-container');
    const linkBtn = document.getElementById('case-link');
    if (caseData.link) {
      linkContainer?.classList.remove('hidden');
      linkBtn?.setAttribute('href', caseData.link);
    } else {
      linkContainer?.classList.add('hidden');
    }

    // Show modal — backdrop en content animeren los van elkaar:
    // backdrop flitst er in (150ms) zodat de blur direct "staat",
    // content slide't met fade over 500ms.
    modal.classList.remove('pointer-events-none');
    modal.setAttribute('aria-hidden', 'false');
    const backdrop = document.getElementById('case-modal-close');
    backdrop?.classList.remove('opacity-0');
    const inner = modal.querySelector('.relative') as HTMLElement | null;
    inner?.classList.remove('opacity-0', 'translate-y-8');
    // Destroy Lenis completely so it doesn't intercept scroll events
    if (window.lenis) {
      window.lenis.destroy();
      window.lenis = null;
    }
    document.body.classList.add('modal-open');

    // Reset scroll position to top
    const scrollArea = document.getElementById('case-content-scroll');
    if (scrollArea) scrollArea.scrollTop = 0;

    // Show/hide scroll hint based on whether content overflows
    const hint = document.getElementById('case-scroll-hint');
    if (hint && scrollArea) {
      requestAnimationFrame(() => {
        if (scrollArea.scrollHeight > scrollArea.clientHeight) {
          hint.style.display = '';
          scrollArea.addEventListener('scroll', () => {
            hint.style.display = 'none';
          }, { once: true });
        } else {
          hint.style.display = 'none';
        }
      });
    }

    // Focus-trap activeren en initiale focus naar close-knop verplaatsen.
    document.addEventListener('keydown', onKeyDown);
    requestAnimationFrame(() => closeBtn?.focus());
  }

  function closeCase() {
    if (!modal) return;
    modal.classList.add('pointer-events-none');
    modal.setAttribute('aria-hidden', 'true');
    document.getElementById('case-modal-close')?.classList.add('opacity-0');
    const inner = modal.querySelector('.relative') as HTMLElement | null;
    inner?.classList.add('opacity-0', 'translate-y-8');
    document.body.classList.remove('modal-open');
    document.removeEventListener('keydown', onKeyDown);
    // Recreate Lenis
    if (typeof Lenis !== 'undefined' && !window.lenis) {
      const l = new Lenis();
      window.lenis = l;
      function raf(time: number) { l.raf(time); requestAnimationFrame(raf); }
      requestAnimationFrame(raf);
    }
    // Restore focus naar het element dat de modal opende.
    lastFocusedEl?.focus();
    lastFocusedEl = null;
  }

  // Event Listeners
  window.addEventListener('open-case', (e: Event) => {
    const id = (e as CustomEvent<{ id: string }>).detail?.id;
    if (id) openCase(id);
  });
  closeTriggers.forEach(t => t?.addEventListener('click', closeCase));
</script>
