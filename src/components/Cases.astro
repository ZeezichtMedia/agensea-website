---
const cases = [
  {
    title: "De Kaap",
    tag: "Digitaal Platform",
    image: "https://images.unsplash.com/photo-1497366216548-37526070297c?q=80&w=600",
  },
  {
    title: "Adrz Kniepoli",
    tag: "Campagne",
    image: "https://images.unsplash.com/photo-1519494026892-80bbd2d6fd0d?q=80&w=600",
  },
  {
    title: "Dockwise",
    tag: "Branding & SEA",
    image: "https://images.unsplash.com/photo-1494412519320-aa613dfb7738?q=80&w=600",
  },
  {
    title: "Tilly Rose",
    tag: "Branding",
    image: "https://placehold.co/600x800/0D0D0D/6C63FF?text=Brand+Identity&font=inter",
  },
  {
    title: "DeMol Events",
    tag: "Webshop",
    image: "https://placehold.co/600x800/0D0D0D/FAF9F6?text=Webshop&font=inter",
  },
];
---

<section id="cases" class="py-24 md:py-40 px-6 lg:px-10 overflow-hidden">
  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="reveal flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-12">
      <div>
        <span class="inline-flex items-center gap-2 text-xs font-medium text-text-secondary uppercase tracking-[0.2em] mb-4">
          <span class="w-8 h-[1px] bg-indigo"></span>
          Portfolio
        </span>
        <h2 class="font-display text-3xl md:text-5xl font-bold leading-tight">
          Recent werk
        </h2>
      </div>
      <a href="#" class="magnetic-btn text-sm font-medium text-text-secondary hover:text-indigo transition-colors interactive">
        Alle cases bekijken
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M17 7H7M17 7V17"/></svg>
      </a>
    </div>
  </div>

  <!-- Horizontal Scroll Gallery -->
  <div class="horizontal-scroll px-6 lg:px-10">
    {cases.map((item, i) => (
      <a href="#" class="reveal group block w-[300px] md:w-[380px] shrink-0 interactive" style={`animation-delay: ${i * 0.1}s;`}>
        <div class="relative aspect-[3/4] rounded-2xl overflow-hidden mb-5 bg-dark">
          <img
            src={item.image}
            alt={item.title}
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
          <span class="absolute top-4 left-4 px-3 py-1 rounded-full bg-white/10 backdrop-blur-sm text-xs font-medium text-white uppercase tracking-wider">
            {item.tag}
          </span>
        </div>
        <h3 class="font-display text-lg font-bold group-hover:text-indigo transition-colors">{item.title}</h3>
      </a>
    ))}
  </div>
</section>
