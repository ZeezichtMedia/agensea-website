                    <span class="font-bold text-dark pr-4">{f.q}</span>
                    <svg class="w-5 h-5 text-indigo shrink-0 group-open:rotate-45 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg>
                  </summary>
                  <div class="px-6 pb-6 text-text-secondary leading-relaxed">
                    {f.a}
                  </div>
                </details>
              ))}
            </div>
          </section>
        </article>

        <aside class="hidden lg:block">
