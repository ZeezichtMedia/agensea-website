---
const clients = [
  { name: 'Dockwize', src: '/Kopie van Unlocked  Logo Partner/Dockwize wit.svg', result: 'Centraal community platform' },
  { name: 'Innovatiepunt KAAP', src: '/Kopie van Unlocked  Logo Partner/Innovatiepunt KAAP.svg', result: 'Strategisch redesign & leads' },
  { name: 'ADRZ', src: '/Kopie van Unlocked  Logo Partner/Logo_Adrz_RGB.png', result: 'Digitale optimalisaties' },
  { name: 'HZ University of Applied Sciences', src: '/Kopie van Unlocked  Logo Partner/HZ.svg', result: 'Datagedreven applicaties' },
  { name: 'Widea', src: '/Kopie van Unlocked  Logo Partner/Widea.svg', result: 'B2B Leadgeneratie & Website' },
  { name: 'Bouwgroep R&D', src: '/Kopie van Unlocked  Logo Partner/Bouwgroep R&D.svg', result: 'Nieuwe corporate website' },
  { name: 'Zeeland Podcasts', src: '/Kopie van Unlocked  Logo Partner/Zeeland podcasts.svg', result: 'Branding & Platform' },
  { name: 'Buurtteams', src: '/Kopie van Unlocked  Logo Partner/Buurtteams.svg', result: 'Toegankelijk zorgportaal' }
];
---

<div class="relative w-full py-16 lg:py-24 bg-dark/40 border-t border-white/5">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <div class="flex items-center gap-4 mb-10 reveal">
      <div class="w-1.5 h-1.5 rounded-full bg-indigo animate-pulse"></div>
      <span class="text-[10px] font-bold uppercase tracking-[0.3em] text-white/40">Tastbaar resultaat voor ambitieuze merken</span>
    </div>

    <!-- The Proof Grid -->
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6">
      {clients.map((client, index) => (
        <div class="group relative bg-dark-lighter/50 border border-white/5 rounded-2xl p-6 md:p-8 flex flex-col items-start justify-between min-h-[160px] md:min-h-[180px] hover:bg-dark-lighter hover:border-white/10 transition-all duration-500 reveal" style={`transition-delay: ${index * 50}ms`}>
          <!-- Hover Ambient Glow -->
          <div class="absolute inset-0 bg-indigo/5 blur-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
          
          <!-- Logo -->
          <div class="h-8 md:h-10 w-full mb-8 relative z-10 flex items-center justify-start">
            <img 
              src={client.src} 
              alt={client.name} 
              class="max-h-full max-w-[120px] md:max-w-[140px] w-auto object-contain brightness-0 invert opacity-40 group-hover:opacity-100 transition-opacity duration-300"
            />
          </div>

          <!-- Proof / Result -->
          <div class="relative z-10 w-full">
            <div class="w-8 h-[1px] bg-white/10 mb-3 group-hover:w-12 group-hover:bg-indigo/50 transition-all duration-500"></div>
            <p class="text-xs md:text-sm text-white/50 group-hover:text-white/80 font-medium tracking-wide transition-colors duration-300">
              {client.result}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</div>
