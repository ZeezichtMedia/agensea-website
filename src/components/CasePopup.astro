        <h4 class="font-bold text-dark mb-2">Wat Agensea heeft gedaan</h4>
        <p class="mb-6">We bouwden een centraal dashboard dat automatisch data ophaalt uit alle relevante bronnen. Omzet, leads, websiteverkeer en conversies staan overzichtelijk bij elkaar. Met realtime updates en een activiteitenfeed mis je nooit meer een belangrijk moment.</p>
      `,
      image: "/portfolio/dashboard-tool.png",
    }
  };

  const modal = document.getElementById('case-modal');
  const closeTriggers = [
    document.getElementById('case-modal-close'),
    document.getElementById('case-modal-close-btn')
  ];

  function openCase(id) {
    const caseData = cases[id];
    if (!caseData) return;

    // Update content
    document.getElementById('case-title').textContent = caseData.title;
    document.getElementById('case-category').textContent = caseData.category;
    document.getElementById('case-description').innerHTML = caseData.description;
    document.getElementById('case-image').src = caseData.image;

    // Handle optional external link
    const linkContainer = document.getElementById('case-link-container');
    const linkBtn = document.getElementById('case-link');
    if (caseData.link) {
      linkContainer.classList.remove('hidden');
      linkBtn.setAttribute('href', caseData.link);
    } else {
      linkContainer.classList.add('hidden');
    }

    // Show modal
    modal.classList.remove('opacity-0', 'pointer-events-none');
    modal.querySelector('.relative').classList.remove('translate-y-8');
    document.body.style.overflow = 'hidden';
    document.documentElement.style.overflow = 'hidden';
    // Stop Lenis smooth scroll
    if (window.lenis) window.lenis.stop();

    // Reset scroll position to top
    const scrollArea = document.getElementById('case-content-scroll');
    if (scrollArea) scrollArea.scrollTop = 0;

    // Show/hide scroll hint based on whether content overflows
    const hint = document.getElementById('case-scroll-hint');
    if (hint && scrollArea) {
      requestAnimationFrame(() => {
        if (scrollArea.scrollHeight > scrollArea.clientHeight) {
          hint.style.display = '';
          scrollArea.addEventListener('scroll', () => {
            hint.style.display = 'none';
          }, { once: true });
        } else {
          hint.style.display = 'none';
        }
      });
    }
  }

  function closeCase() {
    modal.classList.add('opacity-0', 'pointer-events-none');
    modal.querySelector('.relative').classList.add('translate-y-8');
    document.body.style.overflow = '';
    document.documentElement.style.overflow = '';
    if (window.lenis) window.lenis.start();
  }

  // Event Listeners
  window.addEventListener('open-case', (e: any) => openCase(e.detail.id));
  closeTriggers.forEach(t => t?.addEventListener('click', closeCase));
</script>
