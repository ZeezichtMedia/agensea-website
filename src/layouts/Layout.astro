---
import "../styles/global.css";
import AISearch from "../components/AISearch.astro";
import CookieBanner from "../components/CookieBanner.astro";

interface Props {
  title: string;
  description?: string;
  seoTitle?: string;
  seoDescription?: string;
  ogImage?: string;
  ogType?: "website" | "article";
  noindex?: boolean;
}

const {
  title,
  description = "Agensea. Voor ambitieuze ondernemers bouwen wij moderne websites, AI-oplossingen en online marketingcampagnes. Slim, snel en zonder poespas.",
  seoTitle,
  seoDescription,
  ogImage,
  ogType = "website",
  noindex = false,
} = Astro.props;

const finalTitle = seoTitle || `${title} | Agensea`;
const finalDescription = seoDescription || description;

// Canonical URL вҖ” gebaseerd op de huidige request URL t.o.v. de site origin.
// Voorkomt duplicate-content issues met query-strings en trailing slashes.
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// Default OG-image: gebruik het Agensea brand-logo zodat alle pagina's
// een fallback share-preview hebben. Pages kunnen dit overrulen via prop.
const finalOgImage = new URL(ogImage || "/brand/agensea-logo-512.png", Astro.site).toString();

// Organization JSON-LD: alleen op de homepage (Astro.url.pathname === "/")
// om duplicate structured data te voorkomen.
const isHome = Astro.url.pathname === "/";
const orgJsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Agensea",
  url: "https://agensea.nl",
  logo: "https://agensea.nl/brand/agensea-logo-512.png",
  description,
  sameAs: [
    "https://www.linkedin.com/company/agensea",
  ],
  contactPoint: {
    "@type": "ContactPoint",
    telephone: "+31-6-81383601",
    contactType: "customer service",
    areaServed: "NL",
    availableLanguage: ["Dutch", "English"],
  },
};
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{finalTitle}</title>
    <meta name="description" content={finalDescription} />
    <link rel="canonical" href={canonicalURL.toString()} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:title" content={finalTitle} />
    <meta property="og:description" content={finalDescription} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL.toString()} />
    <meta property="og:image" content={finalOgImage} />
    <meta property="og:locale" content="nl_NL" />
    <meta property="og:site_name" content="Agensea" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={finalTitle} />
    <meta name="twitter:description" content={finalDescription} />
    <meta name="twitter:image" content={finalOgImage} />

    {isHome && (
      <script type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} />
    )}

    <slot name="head" />

    <!-- Preconnect to unpkg for Lenis -->
    <link rel="preconnect" href="https://unpkg.com" crossorigin />

    <!-- Lenis smooth scroll CSS (non-render-blocking) -->
    <link rel="stylesheet" href="https://unpkg.com/lenis@1/dist/lenis.css" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://unpkg.com/lenis@1/dist/lenis.css" /></noscript>

    <!-- Fonts: Inter (body, self-hosted) + Outfit (display, Google Fonts) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" href="/fonts/UcC73FwrK3iLTeHuS_nVMrMxCp50SjIa1ZL7.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&display=swap" />
    <style is:inline>
      @font-face{font-family:'Inter';font-style:normal;font-weight:400;font-display:swap;src:url(/fonts/UcC73FwrK3iLTeHuS_nVMrMxCp50SjIa1ZL7.woff2) format('woff2')}
      @font-face{font-family:'Inter';font-style:normal;font-weight:500;font-display:swap;src:url(/fonts/UcC73FwrK3iLTeHuS_nVMrMxCp50SjIa1ZL7.woff2) format('woff2')}
      @font-face{font-family:'Inter';font-style:normal;font-weight:600;font-display:swap;src:url(/fonts/UcC73FwrK3iLTeHuS_nVMrMxCp50SjIa1ZL7.woff2) format('woff2')}
      @font-face{font-family:'Inter';font-style:normal;font-weight:700;font-display:swap;src:url(/fonts/UcC73FwrK3iLTeHuS_nVMrMxCp50SjIa1ZL7.woff2) format('woff2')}
    </style>
  </head>
  <body class="grain bg-cream min-h-screen overflow-x-hidden">
    <slot />
    <AISearch />
    <CookieBanner />

    <!-- Custom Cursor -->
    <div id="cursor-dot" aria-hidden="true"></div>

    <style is:global>
      @media (hover: hover) and (pointer: fine) {
        #cursor-dot {
          position: fixed;
          top: 0;
          left: 0;
          width: 6px;
          height: 6px;
          background: rgba(45, 63, 224, 0.4);
          border-radius: 50%;
          pointer-events: none;
          z-index: 99999;
          transform: translate(-50%, -50%);
          transition: transform 0.2s ease, opacity 0.25s ease, background 0.2s ease;
          mix-blend-mode: darken;
        }

        #cursor-dot.is-hover {
          transform: translate(-50%, -50%) scale(3);
          background: rgba(45, 63, 224, 0.15);
        }

        #cursor-dot.is-hidden {
          opacity: 0;
        }
      }

      @media (hover: none), (pointer: coarse) {
        #cursor-dot { display: none !important; }
      }
    </style>

    <script>
      // в”Җв”Җ Console Easter Egg в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
      console.log(
        "%c\n" +
        " в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв•—   в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— \n" +
        "в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қ в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—\n" +
        "в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв•”в–Ҳв–Ҳв•— в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘\n" +
        "в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•қ  в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘в•ҡв•җв•җв•җв•җв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•қ  в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•‘\n" +
        "в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘ в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘\n" +
        "в•ҡв•җв•қ  в•ҡв•җв•қ в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•җв•җв•җв•җв•җв•қв•ҡв•җв•қ  в•ҡв•җв•җв•җв•қв•ҡв•җв•җв•җв•җв•җв•җв•қв•ҡв•җв•җв•җв•җв•җв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қ\n" +
        "гҖ°гҖ°гҖ°гҖ°гҖ°гҖ°гҖ°гҖ°гҖ°гҖ°гҖ°гҖ°гҖ°гҖ°гҖ°гҖ°гҖ°гҖ°гҖ°гҖ°гҖ°гҖ°гҖ°гҖ°гҖ°гҖ°гҖ°гҖ°\n",
        "color: #2D3FE0; font-family: monospace;"
      );
      console.log(
        "%cHГ©, wat doe jij hier?\n\n%cOnze code is niet voor jouw ogen bedoeld. Maar nu je toch hier bent... we zijn altijd op zoek naar scherpe koppen. Stuur een berichtje naar %cinfo@agensea.nl%c вҖ” dan zien we wel of jij ook zo slim bent als je denkt. рҹҳҸ",
        "color: #2D3FE0; font-size: 16px; font-weight: bold;",
        "color: #555; font-size: 13px;",
        "color: #2D3FE0; font-size: 13px; font-weight: bold; text-decoration: underline;",
        "color: #555; font-size: 13px;"
      );

// в”Җв”Җ Scroll Reveal в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
      const revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("visible");
            }
          });
        },
        { threshold: 0.1, rootMargin: "0px 0px -60px 0px" },
      );

      document
        .querySelectorAll(".reveal")
        .forEach((el) => revealObserver.observe(el));

      // в”Җв”Җ Kinetic Text в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
      const kineticObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const words = entry.target.querySelectorAll(".kinetic-word");
              words.forEach((word, i) => {
                setTimeout(() => word.classList.add("visible"), i * 80);
              });
            }
          });
        },
        { threshold: 0.2 },
      );

      document
        .querySelectorAll(".kinetic-container")
        .forEach((el) => kineticObserver.observe(el));

      // в”Җв”Җ Magnetic Buttons в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
      document.querySelectorAll(".magnetic-btn").forEach((btn) => {
        btn.addEventListener("mousemove", (e) => {
          const rect = btn.getBoundingClientRect();
          const x = e.clientX - rect.left - rect.width / 2;
          const y = e.clientY - rect.top - rect.height / 2;
          btn.style.transform = `translate(${x * 0.2}px, ${y * 0.2}px)`;
        });
        btn.addEventListener("mouseleave", () => {
          btn.style.transform = "translate(0, 0)";
        });
      });

      // в”Җв”Җ Animated Counters в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
      const counterObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const el = entry.target;
              const target = parseInt(el.dataset.target || "0");
              const suffix = el.dataset.suffix || "";
              let current = 0;
              const duration = 2000;
              const step = target / (duration / 16);
              const timer = setInterval(() => {
                current += step;
                if (current >= target) {
                  current = target;
                  clearInterval(timer);
                }
                el.textContent = Math.round(current) + suffix;
              }, 16);
              counterObserver.unobserve(el);
            }
          });
        },
        { threshold: 0.5 },
      );

      document
        .querySelectorAll(".counter")
        .forEach((el) => counterObserver.observe(el));
      // в”Җв”Җ Flickering "a" Favicon в”Җв”Җв”Җв”Җв”Җв”Җ
      (function () {
        const canvas = document.createElement("canvas");
        canvas.width = 32;
        canvas.height = 32;
        const ctx = canvas.getContext("2d");
        const favicon = document.querySelector('link[rel="icon"]');
        if (!ctx || !favicon) return;

        function draw(time: number) {
          ctx.clearRect(0, 0, 32, 32);

          // Background вҖ” indigo
          ctx.fillStyle = "#2D3FE0";
          ctx.beginPath();
          ctx.roundRect(0, 0, 32, 32, 7);
          ctx.fill();

          // "a" letter вҖ” static
          ctx.fillStyle = "#FFFFFF";
          ctx.font = 'bold 22px "Space Grotesk", "Inter", sans-serif';
          ctx.textAlign = "center";
          ctx.textBaseline = "middle";
          ctx.fillText("a", 15, 17);

          // The dot вҖ” pulses (breathes)
          const cycle = 2500;
          const t = (time % cycle) / cycle;
          const scale = 1.5 + Math.sin(t * Math.PI * 2) * 1;
          const alpha = 0.6 + Math.sin(t * Math.PI * 2) * 0.4;

          ctx.globalAlpha = alpha;
          ctx.fillStyle = "#FFFFFF";
          ctx.beginPath();
          ctx.arc(27, 24, scale, 0, Math.PI * 2);
          ctx.fill();
          ctx.globalAlpha = 1;

          favicon.setAttribute("href", canvas.toDataURL("image/png"));
          requestAnimationFrame(draw);
        }

        requestAnimationFrame(draw);
      })();

      // в”Җв”Җ Custom Cursor (subtle dot) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
      (function () {
        if (!window.matchMedia("(hover: hover) and (pointer: fine)").matches) return;
        const dot = document.getElementById("cursor-dot");
        if (!dot) return;

        let x = -100, y = -100, dx = -100, dy = -100, visible = false;

        document.addEventListener("mousemove", (e) => {
          x = e.clientX; y = e.clientY;
          if (!visible) { visible = true; dot.classList.remove("is-hidden"); }
        });

        document.addEventListener("mouseleave", () => { dot.classList.add("is-hidden"); visible = false; });
        document.addEventListener("mouseenter", () => { if (x > 0) { dot.classList.remove("is-hidden"); visible = true; } });

        // Smooth follow with lerp
        (function loop() {
          dx += (x - dx) * 0.2;
          dy += (y - dy) * 0.2;
          dot.style.left = dx + "px";
          dot.style.top = dy + "px";
          requestAnimationFrame(loop);
        })();

        // Hover detection
        document.addEventListener("mouseover", (e) => {
          const t = (e.target as HTMLElement)?.closest("a, button, .interactive, input, textarea, select, [role='button']");
          if (t) dot.classList.add("is-hover");
        });
        document.addEventListener("mouseout", (e) => {
          const t = (e.target as HTMLElement)?.closest("a, button, .interactive, input, textarea, select, [role='button']");
          if (t) dot.classList.remove("is-hover");
        });
      })();
    </script>

    <!-- Lenis smooth scroll -->
    <script is:inline src="https://unpkg.com/lenis@1/dist/lenis.min.js" defer></script>
    <script is:inline>
      // Header-offset voor anchor-navigatie. 5px vanaf viewport-top вҖ”
      // heading landt vrijwel tegen de bovenkant.
      function getHeaderOffset() {
        return 5;
      }

      function initLenis() {
        var lenis = new Lenis();
        window.lenis = lenis;
        function raf(time) {
          lenis.raf(time);
          requestAnimationFrame(raf);
        }
        requestAnimationFrame(raf);

        // Delegate click handler: vang interne anchor-links af en laat Lenis
        // scrollen met een negatieve offset, zodat de sectiekop netjes onder
        // de fixed header pill landt i.p.v. erachter te verdwijnen.
        document.addEventListener('click', function (e) {
          var anchor = e.target.closest && e.target.closest('a[href^="#"], a[href*="#"]');
          if (!anchor) return;
          var href = anchor.getAttribute('href');
          if (!href || href === '#') return;

          // Alleen same-page anchors afhandelen вҖ” externe pagina + hash laten we
          // door de browser doen (die honoreert scroll-padding-top vanzelf).
          var hashIndex = href.indexOf('#');
          var path = href.slice(0, hashIndex);
          if (path && path !== window.location.pathname) return;

          var id = href.slice(hashIndex + 1);
          var target = document.getElementById(id);
          if (!target) return;

          e.preventDefault();
          lenis.scrollTo(target, { offset: -getHeaderOffset() });
          // Update URL hash zonder browser-jump.
          history.replaceState(null, '', '#' + id);
        });
      }
      if (typeof Lenis !== 'undefined') {
        initLenis();
      } else {
        document.querySelector('script[src*="lenis"]').addEventListener('load', initLenis);
      }
    </script>
  </body>
</html>
