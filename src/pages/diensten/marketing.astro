---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Cases from '../../components/Cases.astro';
import CTA from '../../components/CTA.astro';
---

<Layout title="Online Marketing & Groei | Agensea">
  <Navbar />
  
  <main class="bg-cream min-h-screen pt-32 md:pt-48 pb-20 overflow-hidden relative">
    <!-- Background Decor -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
      <div class="mesh-blob w-[600px] h-[600px] bg-indigo/10 top-[-10%] right-[-10%] blur-[120px]"></div>
      <div class="mesh-blob w-[500px] h-[500px] bg-violet/10 bottom-[10%] left-[-10%] blur-[100px]"></div>
    </div>

    <!-- Hero Section -->
    <section class="max-w-7xl mx-auto px-6 lg:px-10 relative z-10 mb-24 md:mb-40">
      <div class="grid lg:grid-cols-12 gap-12 lg:gap-20 items-center">
        <!-- Content -->
        <div class="lg:col-span-7">
          <div class="reveal">
            <span class="inline-flex items-center gap-2 text-xs font-bold text-indigo uppercase tracking-[0.2em] mb-6">
              <span class="w-8 h-[2px] bg-indigo"></span>
              Onze diensten
            </span>
            <h1 class="font-display font-bold text-5xl md:text-6xl lg:text-7xl leading-[1.05] tracking-tight text-dark mb-8">
              Meer klanten en <span class="text-indigo">online groei.</span>
            </h1>
            <p class="text-lg md:text-xl text-text-secondary leading-relaxed mb-10 max-w-xl">
              Je wilt beter gevonden worden en structureel meer aanvragen of verkopen realiseren. Met datagedreven campagnes en slimme SEO zorgen we dat jouw ideale klant je direct weet te vinden.
            </p>
            <div class="flex flex-wrap gap-4">
              <a href="/contact" class="magnetic-btn px-8 mx-0 py-4 bg-dark text-white rounded-xl font-medium hover:bg-indigo transition-colors duration-300">
                Laten we sparren
              </a>
              <a href="#aanpak" class="px-8 py-4 border border-warm-grey/50 rounded-xl font-medium text-dark hover:border-indigo transition-all duration-300">
                Ontdek onze aanpak
              </a>
            </div>
          </div>
        </div>
        <!-- Right Graphic area: Bar Chart -->
        <div class="lg:col-span-5 reveal" style="transition-delay: 200ms;">
          <div class="w-full aspect-[4/5] bg-white rounded-[2.5rem] shadow-2xl overflow-hidden border border-white relative flex flex-col justify-end p-8">
             <div class="absolute top-8 left-8">
               <span class="text-xs font-bold uppercase tracking-widest text-text-secondary/50">Groei Conversies (Q3)</span>
               <div class="text-4xl font-display font-bold text-dark mt-1">+142%</div>
             </div>
             
             <div class="flex items-end gap-4 h-48 w-full">
               <div class="w-1/4 bg-cream border border-warm-grey/30 rounded-t-xl h-1/4 relative group hover:bg-indigo/10 transition-colors"></div>
               <div class="w-1/4 bg-cream border border-warm-grey/30 rounded-t-xl h-2/4 relative group hover:bg-indigo/10 transition-colors"></div>
               <div class="w-1/4 bg-cream border border-warm-grey/30 rounded-t-xl h-3/4 relative group hover:bg-indigo/10 transition-colors"></div>
               <div class="w-1/4 bg-indigo shadow-[0_0_20px_rgba(79,70,229,0.3)] rounded-t-xl h-full relative">
                 <div class="absolute -top-10 left-1/2 -translate-x-1/2 bg-dark text-white text-xs font-bold py-1 px-3 rounded shadow-lg">Nu</div>
               </div>
             </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Details Section -->
    <section id="aanpak" class="py-24 bg-white relative z-10 w-full rounded-[3rem] shadow-sm mb-24 md:mb-40">
      <div class="max-w-7xl mx-auto px-6 lg:px-10">
        <h2 class="font-display text-4xl leading-tight font-bold mb-16 text-center max-w-2xl mx-auto">Giswerk eruit, <span class="text-indigo">meetbaar resultaat</span> erin.</h2>
        
        <div class="grid md:grid-cols-3 gap-8 lg:gap-12">
          <!-- Feature 1 -->
          <div class="p-8 rounded-3xl bg-cream border border-warm-grey/30 hover:border-indigo/30 transition-colors">
            <h3 class="font-bold text-xl mb-4">Adverteren (SEA)</h3>
            <p class="text-text-secondary leading-relaxed">We plaatsen jouw bedrijf strak bovenaan in Google en op relevante socials, precies op het moment dat een potentiële klant naar je oplossingen zoekt.</p>
          </div>
          <!-- Feature 2 -->
          <div class="p-8 rounded-3xl bg-cream border border-warm-grey/30 hover:border-indigo/30 transition-colors">
            <h3 class="font-bold text-xl mb-4">Organisch (SEO)</h3>
            <p class="text-text-secondary leading-relaxed">Een lange-termijn strategie om zonder advertentiekosten structureel nieuwe bezoekers en autoriteit op te bouwen.</p>
          </div>
          <!-- Feature 3 -->
          <div class="p-8 rounded-3xl bg-cream border border-warm-grey/30 hover:border-indigo/30 transition-colors">
            <h3 class="font-bold text-xl mb-4">Campagne Optimalisatie</h3>
            <p class="text-text-secondary leading-relaxed">Geen "set and forget". We sturen pro-actief op data, meten de Return On Investment (ROI) doorlopend en scherpen wekelijks aan voor het hoogste rendement.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Werkwijze: Clean Typographic Strips -->
    <section class="relative z-10 py-24 md:py-40">
      <div class="max-w-7xl mx-auto px-6 lg:px-10">
        <div class="reveal mb-16 md:mb-24">
          <span class="inline-flex items-center gap-2 text-xs font-bold text-indigo uppercase tracking-[0.2em] mb-6">
            <span class="w-8 h-[2px] bg-indigo"></span>
            Werkwijze
          </span>
          <h2 class="font-display text-4xl md:text-6xl font-bold leading-[1.05] text-dark max-w-3xl">
            Vier stappen naar <span class="text-indigo">meetbaar resultaat.</span>
          </h2>
        </div>
      </div>

      <div class="border-t border-warm-grey">
        
        <!-- Stap 1 -->
        <a href="/contact" class="reveal group block border-b border-warm-grey transition-colors hover:bg-indigo/[0.03]">
          <div class="max-w-7xl mx-auto px-6 lg:px-10 py-12 md:py-16 grid md:grid-cols-12 gap-6 md:gap-12 items-start">
            <div class="md:col-span-2">
              <span class="font-display text-7xl md:text-8xl font-bold bg-gradient-to-b from-indigo to-indigo/20 bg-clip-text text-transparent leading-none select-none">01</span>
            </div>
            <div class="md:col-span-4">
              <h3 class="font-display font-bold text-2xl md:text-3xl text-dark group-hover:text-indigo transition-colors">Kennismaking</h3>
              <span class="inline-block mt-2 text-xs font-bold text-text-secondary uppercase tracking-widest">Vrijblijvend</span>
            </div>
            <div class="md:col-span-5">
              <p class="text-text-secondary text-base md:text-lg leading-relaxed">
                We duiken in je business, ontleden samen de doelgroep en leveren een transparant voorstel op maat. Inclusief platformkeuze, budgetindicatie en een helder kostenplaatje. Geen verrassingen.
              </p>
            </div>
            <div class="md:col-span-1 hidden md:flex items-center justify-end">
              <div class="w-10 h-10 rounded-full border border-warm-grey/50 flex items-center justify-center group-hover:bg-indigo group-hover:border-indigo group-hover:text-white text-dark/30 transition-all">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </div>
            </div>
          </div>
        </a>

        <!-- Stap 2 -->
        <a href="/contact" class="reveal group block border-b border-warm-grey transition-colors hover:bg-violet/[0.03]">
          <div class="max-w-7xl mx-auto px-6 lg:px-10 py-12 md:py-16 grid md:grid-cols-12 gap-6 md:gap-12 items-start">
            <div class="md:col-span-2">
              <span class="font-display text-7xl md:text-8xl font-bold bg-gradient-to-b from-violet to-violet/20 bg-clip-text text-transparent leading-none select-none">02</span>
            </div>
            <div class="md:col-span-4">
              <h3 class="font-display font-bold text-2xl md:text-3xl text-dark group-hover:text-violet transition-colors">Strategie op maat</h3>
              <span class="inline-block mt-2 text-xs font-bold text-violet bg-violet/10 px-3 py-1 rounded-full uppercase tracking-widest">Na akkoord</span>
            </div>
            <div class="md:col-span-5">
              <p class="text-text-secondary text-base md:text-lg leading-relaxed">
                Van grove schets naar scherp plan. We verfijnen de doelgroep, verdelen het budget over de juiste kanalen en zetten KPI's en meetpunten klaar. Zodat elke euro die je investeert meetbaar is.
              </p>
            </div>
            <div class="md:col-span-1 hidden md:flex items-center justify-end">
              <div class="w-10 h-10 rounded-full border border-warm-grey/50 flex items-center justify-center group-hover:bg-violet group-hover:border-violet group-hover:text-white text-dark/30 transition-all">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </div>
            </div>
          </div>
        </a>

        <!-- Stap 3 -->
        <a href="/contact" class="reveal group block border-b border-warm-grey transition-colors hover:bg-indigo/[0.03]">
          <div class="max-w-7xl mx-auto px-6 lg:px-10 py-12 md:py-16 grid md:grid-cols-12 gap-6 md:gap-12 items-start">
            <div class="md:col-span-2">
              <span class="font-display text-7xl md:text-8xl font-bold bg-gradient-to-b from-indigo to-indigo/20 bg-clip-text text-transparent leading-none select-none">03</span>
            </div>
            <div class="md:col-span-4">
              <h3 class="font-display font-bold text-2xl md:text-3xl text-dark group-hover:text-indigo transition-colors">Lancering</h3>
              <span class="inline-block mt-2 text-xs font-bold text-text-secondary uppercase tracking-widest">Go live</span>
            </div>
            <div class="md:col-span-5">
              <p class="text-text-secondary text-base md:text-lg leading-relaxed">
                Accounts gekoppeld, pixels geplaatst, advertenties vormgegeven, doelgroepen ingesteld. Alles staat klaar. Dan drukken we samen op de knop en gaan jouw campagnes live.
              </p>
            </div>
            <div class="md:col-span-1 hidden md:flex items-center justify-end">
              <div class="w-10 h-10 rounded-full border border-warm-grey/50 flex items-center justify-center group-hover:bg-indigo group-hover:border-indigo group-hover:text-white text-dark/30 transition-all">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </div>
            </div>
          </div>
        </a>

        <!-- Stap 4 -->
        <a href="/contact" class="reveal group block border-b border-warm-grey bg-gradient-to-r from-indigo/[0.04] to-transparent transition-colors hover:from-indigo/[0.08]">
          <div class="max-w-7xl mx-auto px-6 lg:px-10 py-12 md:py-16 grid md:grid-cols-12 gap-6 md:gap-12 items-start">
            <div class="md:col-span-2">
              <span class="font-display text-7xl md:text-8xl font-bold bg-gradient-to-b from-emerald-500 to-emerald-500/20 bg-clip-text text-transparent leading-none select-none">04</span>
            </div>
            <div class="md:col-span-4">
              <h3 class="font-display font-bold text-2xl md:text-3xl text-dark group-hover:text-emerald-600 transition-colors">Optimalisatie</h3>
              <span class="inline-flex items-center gap-2 mt-2 text-xs font-bold text-emerald-600 bg-emerald-50 px-3 py-1 rounded-full uppercase tracking-widest">
                <span class="relative flex h-1.5 w-1.5">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-emerald-500"></span>
                </span>
                Doorlopend
              </span>
            </div>
            <div class="md:col-span-5">
              <p class="text-text-secondary text-base md:text-lg leading-relaxed">
                Hier stopt het niet. We monitoren dagelijks, testen nieuwe varianten, sturen budgetten bij en rapporteren transparant. Zo halen we steeds meer uit elke euro die je investeert.
              </p>
            </div>
            <div class="md:col-span-1 hidden md:flex items-center justify-end">
              <div class="w-10 h-10 rounded-full border border-warm-grey/50 flex items-center justify-center group-hover:bg-emerald-500 group-hover:border-emerald-500 group-hover:text-white text-dark/30 transition-all">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </div>
            </div>
          </div>
        </a>
      </div>
    </section>

    <Cases />
    <CTA />
  </main>
  
  <Footer />
</Layout>

<script>
  const observeElements = () => {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
        }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', observeElements);
  } else {
    observeElements();
  }
</script>
