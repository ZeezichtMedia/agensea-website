<style>
  .ad-layout {
    position: absolute;
    inset: 0;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.5s ease;
  }
  .ad-layout.active {
    opacity: 1;
    pointer-events: auto;
  }
  .ad-layout .ad-el {
    opacity: 0;
    transform: translateY(8px);
  }
  .ad-layout.active .ad-el {
    animation: adBuild 0.5s ease-out forwards;
  }
  .ad-layout.active .space-y-3 > .ad-el:nth-child(1),
  .ad-layout.active .space-y-4 > .ad-el:nth-child(1) { animation-delay: 0.1s; }
  .ad-layout.active .space-y-3 > .ad-el:nth-child(2),
  .ad-layout.active .space-y-4 > .ad-el:nth-child(2) { animation-delay: 0.35s; }
  .ad-layout.active .space-y-3 > .ad-el:nth-child(3),
  .ad-layout.active .space-y-4 > .ad-el:nth-child(3) { animation-delay: 0.6s; }
  .ad-layout.active .space-y-3 > .ad-el:nth-child(4),
  .ad-layout.active .space-y-4 > .ad-el:nth-child(4) { animation-delay: 0.85s; }
  .ad-layout.active .space-y-3 > .ad-el:nth-child(5),
  .ad-layout.active .space-y-4 > .ad-el:nth-child(5) { animation-delay: 1.05s; }
  .ad-layout.fading .ad-el {
    animation: adFade 0.35s ease-in forwards !important;
  }
  @keyframes adBuild {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes adFade {
    from { opacity: 1; transform: translateY(0); }
    to { opacity: 0; transform: translateY(-4px); }
  }
</style>

<script>
  const observeElements = () => {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
        }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', observeElements);
  } else {
    observeElements();
  }

  // Ad platform cycler
  const adLayouts = document.querySelectorAll('.ad-layout');
  const adLabel = document.getElementById('adPlatformLabel');
  const adDots = document.querySelectorAll('.ad-dot');
  let adCurrent = 0;
  const AD_DISPLAY = 4000;
  const AD_FADE = 450;

  function updateDots(index) {
    adDots.forEach((dot, i) => {
      if (i === index) {
        dot.className = 'ad-dot w-1.5 h-1.5 rounded-full bg-dark/40 transition-all duration-300';
      } else {
        dot.className = 'ad-dot w-1.5 h-1.5 rounded-full bg-dark/15 transition-all duration-300';
      }
    });
  }

  function showAd(index) {
    const layout = adLayouts[index];
    if (adLabel && layout.dataset.platform) {
      adLabel.style.opacity = '0';
      setTimeout(() => {
        adLabel.textContent = layout.dataset.platform;
        adLabel.style.opacity = '1';
      }, 180);
    }
    updateDots(index);
    layout.querySelectorAll('.ad-el').forEach(el => {
      el.style.animation = 'none';
      el.offsetHeight;
      el.style.animation = '';
    });
    layout.classList.remove('fading');
    layout.classList.add('active');
  }

  function hideAd(index) {
    const layout = adLayouts[index];
    layout.classList.add('fading');
    setTimeout(() => {
      layout.classList.remove('active', 'fading');
    }, AD_FADE);
  }

  function cycleAd() {
    hideAd(adCurrent);
    setTimeout(() => {
      adCurrent = (adCurrent + 1) % adLayouts.length;
      showAd(adCurrent);
    }, AD_FADE);
  }

  showAd(0);
  setInterval(cycleAd, AD_DISPLAY + AD_FADE);
</script>

<script>
  // Goal Selector Logic
  const goalChips = document.querySelectorAll('.goal-chip');
  const goalPanels = document.querySelectorAll('.goal-panel');
  const goalWrapper = document.getElementById('goal-content-wrapper');
  const goalHeadingAccent = document.getElementById('goal-heading-accent');

  const goalLabels: Record<string, string> = {
    zichtbaarheid: 'meer zichtbaarheid.',
    leads: 'meer leads.',
    verkopen: 'producten verkopen.',
    imago: 'mijn imago verbeteren.',
    betrokkenheid: 'meer betrokkenheid.',
    aanvragen: 'meer aanvragen.'
  };

  let activeGoal: string | null = null;

  goalChips.forEach(chip => {
    chip.addEventListener('click', () => {
      const goalId = (chip as HTMLElement).dataset.goal;
      if (!goalId) return;

      // Toggle: clicking same chip again closes it
      if (activeGoal === goalId) {
        // Deactivate
        chip.classList.remove('bg-indigo', 'text-white', 'border-indigo', 'active');
        chip.classList.add('bg-white', 'text-dark', 'border-warm-grey/40');
        
        goalPanels.forEach(p => {
          p.classList.add('opacity-0', 'translate-y-6', 'pointer-events-none');
          p.classList.remove('opacity-100', 'translate-y-0', 'pointer-events-auto');
        });
        
        if (goalWrapper) goalWrapper.style.height = '0px';
        if (goalHeadingAccent) {
          goalHeadingAccent.style.opacity = '0';
          setTimeout(() => {
            goalHeadingAccent!.textContent = '...';
            goalHeadingAccent!.style.opacity = '1';
          }, 200);
        }
        activeGoal = null;
        return;
      }

      // Update chips
      goalChips.forEach(c => {
        c.classList.remove('bg-indigo', 'text-white', 'border-indigo', 'active');
        c.classList.add('bg-white', 'text-dark', 'border-warm-grey/40');
      });
      chip.classList.add('bg-indigo', 'text-white', 'border-indigo', 'active');
      chip.classList.remove('bg-white', 'text-dark', 'border-warm-grey/40');

      // Update heading
      if (goalHeadingAccent) {
        goalHeadingAccent.style.opacity = '0';
        setTimeout(() => {
          goalHeadingAccent!.textContent = goalLabels[goalId] || '...';
          goalHeadingAccent!.style.opacity = '1';
        }, 200);
      }

      // Show correct panel
      goalPanels.forEach(panel => {
        const panelId = (panel as HTMLElement).dataset.goalPanel;
        if (panelId === goalId) {
          panel.classList.remove('opacity-0', 'translate-y-6', 'pointer-events-none');
          panel.classList.add('opacity-100', 'translate-y-0', 'pointer-events-auto');
          
          // Animate height
          if (goalWrapper) {
            // Use requestAnimationFrame to ensure the panel is rendered before measuring
            requestAnimationFrame(() => {
              goalWrapper!.style.height = panel.scrollHeight + 'px';
            });
          }
        } else {
          panel.classList.add('opacity-0', 'translate-y-6', 'pointer-events-none');
          panel.classList.remove('opacity-100', 'translate-y-0', 'pointer-events-auto');
        }
      });

      activeGoal = goalId;
    });
  });

  // Smooth transition for heading accent
  if (goalHeadingAccent) {
    goalHeadingAccent.style.transition = 'opacity 0.2s ease-out';
  }
</script>
