  const modal = document.getElementById('case-modal');
  const closeTriggers = [
    document.getElementById('case-modal-close'),
    document.getElementById('case-modal-close-btn')
  ];

  function openCase(id) {
    const caseData = cases[id];
    if (!caseData) return;

    // Update content
    document.getElementById('case-title').textContent = caseData.title;
    document.getElementById('case-category').textContent = caseData.category;
    document.getElementById('case-description').innerHTML = caseData.description;
    document.getElementById('case-image').src = caseData.image;

    // Handle optional external link
    const linkContainer = document.getElementById('case-link-container');
    const linkBtn = document.getElementById('case-link');
    if (caseData.link) {
      linkContainer.classList.remove('hidden');
      linkBtn.setAttribute('href', caseData.link);
    } else {
      linkContainer.classList.add('hidden');
    }

    // Show modal
    modal.classList.remove('opacity-0', 'pointer-events-none');
    modal.querySelector('.relative').classList.remove('translate-y-8');
    document.body.style.overflow = 'hidden';
  }

  function closeCase() {
    modal.classList.add('opacity-0', 'pointer-events-none');
    modal.querySelector('.relative').classList.add('translate-y-8');
    document.body.style.overflow = '';
  }

  // Event Listeners
  window.addEventListener('open-case', (e: any) => openCase(e.detail.id));
  closeTriggers.forEach(t => t?.addEventListener('click', closeCase));
</script>
