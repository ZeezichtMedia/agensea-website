---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Cases from '../../components/Cases.astro';
import CTA from '../../components/CTA.astro';
---

<Layout title="Maatwerk Websites | Agensea">
  <Navbar />
  
  <main class="bg-cream min-h-screen pt-28 md:pt-36 pb-20 overflow-hidden relative">
    <!-- Background Decor -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
      <div class="mesh-blob w-[600px] h-[600px] bg-indigo/10 top-[-10%] right-[-10%] blur-[120px]"></div>
      <div class="mesh-blob w-[500px] h-[500px] bg-violet/10 bottom-[10%] left-[-10%] blur-[100px]"></div>
    </div>

    <!-- Hero Section -->
    <section class="max-w-7xl mx-auto px-6 lg:px-10 relative z-10 mb-16 md:mb-28">
      <div class="grid lg:grid-cols-12 gap-10 lg:gap-14 items-center">
        <!-- Content -->
        <div class="lg:col-span-7">
          <div class="reveal">
            <span class="inline-flex items-center gap-2 text-xs font-bold text-indigo uppercase tracking-[0.2em] mb-6">
              <span class="w-8 h-[2px] bg-indigo"></span>
              Onze diensten
            </span>
            <h1 class="font-display font-bold text-4xl md:text-5xl lg:text-6xl leading-[1.05] tracking-tight text-dark mb-5">
              Een professionele website <span class="text-indigo">die klanten oplevert.</span>
            </h1>
            <p class="text-base md:text-lg text-text-secondary leading-relaxed mb-8 max-w-xl">
              Je zoekt een website die er strak uitziet én doet wat hij moet doen: overtuigen. Wij bouwen razendsnelle, betrouwbare websites en webshops die perfect aansluiten bij jouw bedrijf.
            </p>
            <div class="flex flex-wrap gap-4">
              <a href="/contact" class="magnetic-btn px-8 mx-0 py-4 bg-dark text-white rounded-xl font-medium hover:bg-indigo transition-colors duration-300">
                Laten we sparren
              </a>
              <a href="#aanpak" class="px-8 py-4 border border-warm-grey/50 rounded-xl font-medium text-dark hover:border-indigo transition-all duration-300">
                Ontdek onze aanpak
              </a>
            </div>
          </div>
        </div>
        <!-- Right Image/Graphic area -->
        <div class="lg:col-span-5 reveal" style="transition-delay: 200ms;">
          <div class="w-full bg-white rounded-[2rem] shadow-2xl overflow-hidden border border-white relative">
            <!-- Browser Chrome -->
            <div class="h-9 bg-[#f5f3ef] flex items-center px-4 gap-1.5 border-b border-warm-grey/15">
              <div class="w-2.5 h-2.5 rounded-full bg-[#FF5F57]"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-[#FEBC2E]"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-[#28C840]"></div>
              <div class="ml-3 flex-1 h-5 bg-white/80 rounded-md border border-warm-grey/15 flex items-center px-2">
                <span class="text-[8px] text-text-secondary/40 font-mono">jouwbedrijf.nl</span>
              </div>
            </div>

            <!-- Animated Mini Website -->
            <div class="p-5 space-y-4 mini-site">
              <!-- Mini Nav -->
              <div class="mini-el el-1 flex items-center justify-between">
                <div class="w-14 h-4 bg-dark rounded-sm"></div>
                <div class="flex gap-3">
                  <div class="w-10 h-2.5 bg-warm-grey/30 rounded-sm"></div>
                  <div class="w-10 h-2.5 bg-warm-grey/30 rounded-sm"></div>
                  <div class="w-12 h-6 bg-indigo rounded-md"></div>
                </div>
              </div>

              <!-- Mini Hero -->
              <div class="pt-3 pb-2">
                <div class="mini-el el-2 w-3/4 h-4 bg-dark rounded-sm mb-2"></div>
                <div class="mini-el el-2 w-1/2 h-4 bg-indigo/60 rounded-sm mb-3"></div>
                <div class="mini-el el-3 w-full h-2 bg-warm-grey/20 rounded-sm mb-1"></div>
                <div class="mini-el el-3 w-4/5 h-2 bg-warm-grey/20 rounded-sm mb-4"></div>
                <div class="mini-el el-4 w-20 h-7 bg-indigo rounded-lg"></div>
              </div>

              <!-- Mini Feature Cards -->
              <div class="grid grid-cols-3 gap-2">
                <div class="mini-el el-5 bg-cream rounded-xl p-3 border border-warm-grey/15">
                  <div class="w-6 h-6 bg-indigo/10 rounded-lg mb-2 flex items-center justify-center">
                    <div class="w-3 h-3 rounded-full border-2 border-indigo/40"></div>
                  </div>
                  <div class="w-full h-1.5 bg-warm-grey/25 rounded-sm mb-1"></div>
                  <div class="w-2/3 h-1.5 bg-warm-grey/15 rounded-sm"></div>
                </div>
                <div class="mini-el el-6 bg-cream rounded-xl p-3 border border-warm-grey/15">
                  <div class="w-6 h-6 bg-violet/10 rounded-lg mb-2 flex items-center justify-center">
                    <div class="w-3 h-2 rounded-sm border-2 border-violet/40"></div>
                  </div>
                  <div class="w-full h-1.5 bg-warm-grey/25 rounded-sm mb-1"></div>
                  <div class="w-3/4 h-1.5 bg-warm-grey/15 rounded-sm"></div>
                </div>
                <div class="mini-el el-7 bg-cream rounded-xl p-3 border border-warm-grey/15">
                  <div class="w-6 h-6 bg-emerald-50 rounded-lg mb-2 flex items-center justify-center">
                    <div class="w-3 h-3 rounded-full border-2 border-emerald-300"></div>
                  </div>
                  <div class="w-full h-1.5 bg-warm-grey/25 rounded-sm mb-1"></div>
                  <div class="w-1/2 h-1.5 bg-warm-grey/15 rounded-sm"></div>
                </div>
              </div>

              <!-- Mini Chart -->
              <div class="mini-el el-8 bg-cream rounded-xl p-3 border border-warm-grey/15">
                <div class="flex items-center justify-between mb-2">
                  <div class="w-16 h-1.5 bg-warm-grey/25 rounded-sm"></div>
                  <div class="w-8 h-1.5 bg-emerald-300 rounded-sm"></div>
                </div>
                <div class="flex items-end gap-1.5 h-10">
                  <div class="chart-bar flex-1 bg-indigo/15 rounded-t-sm" style="height:40%"></div>
                  <div class="chart-bar flex-1 bg-indigo/15 rounded-t-sm" style="height:55%"></div>
                  <div class="chart-bar flex-1 bg-indigo/20 rounded-t-sm" style="height:35%"></div>
                  <div class="chart-bar flex-1 bg-indigo/20 rounded-t-sm" style="height:70%"></div>
                  <div class="chart-bar flex-1 bg-indigo/25 rounded-t-sm" style="height:50%"></div>
                  <div class="chart-bar flex-1 bg-indigo/30 rounded-t-sm" style="height:85%"></div>
                  <div class="chart-bar flex-1 bg-indigo rounded-t-sm" style="height:100%"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Details Section -->
    <section id="aanpak" class="py-24 bg-white relative z-10 w-full rounded-[3rem] shadow-sm mb-24 md:mb-40">
      <div class="max-w-7xl mx-auto px-6 lg:px-10">
        <h2 class="font-display text-4xl leading-tight font-bold mb-16 text-center max-w-2xl mx-auto">Niet zomaar een mooi plaatje, maar een <span class="text-indigo">strategisch fundament.</span></h2>
        
        <div class="grid md:grid-cols-3 gap-8 lg:gap-12">
          <!-- Feature 1 -->
          <div class="p-8 rounded-3xl bg-cream border border-warm-grey/30 hover:border-indigo/30 transition-colors">
            <h3 class="font-bold text-xl mb-4">Razendsnel</h3>
            <p class="text-text-secondary leading-relaxed">Niets is zo frustrerend als een trage website. Wij bouwen op de nieuwste technieken waardoor jouw pagina's direct laden. Goed voor je bezoeker én voor Google.</p>
          </div>
          <!-- Feature 2 -->
          <div class="p-8 rounded-3xl bg-cream border border-warm-grey/30 hover:border-indigo/30 transition-colors">
            <h3 class="font-bold text-xl mb-4">Conversie Gericht</h3>
            <p class="text-text-secondary leading-relaxed">Elk onderdeel is ontworpen om bezoekers te begeleiden naar de volgende stap. Of dat nu een offerte-aanvraag, een belletje of een aankoop is.</p>
          </div>
          <!-- Feature 3 -->
          <div class="p-8 rounded-3xl bg-cream border border-warm-grey/30 hover:border-indigo/30 transition-colors">
            <h3 class="font-bold text-xl mb-4">Meegroeien</h3>
            <p class="text-text-secondary leading-relaxed">Jouw bedrijf staat niet stil. Daarom bouwen we websites die je in de toekomst makkelijk uit kunt breiden met nieuwe pagina's of features.</p>
          </div>
        </div>
      </div>
    </section>

    <Cases />
    <CTA />
  </main>
  
  <Footer />
</Layout>

<style>
  /* Mini site build animation - 8s cycle, 2s pause */
  @keyframes buildIn {
    0%, 5% { opacity: 0; transform: translateY(8px); }
    10%, 80% { opacity: 1; transform: translateY(0); }
    90%, 100% { opacity: 0; transform: translateY(0); }
  }

  @keyframes barGrow {
    0%, 5% { transform: scaleY(0); }
    15%, 80% { transform: scaleY(1); }
    90%, 100% { transform: scaleY(0); }
  }

  .mini-el {
    opacity: 0;
    animation: buildIn 8s ease-out infinite;
  }

  .el-1 { animation-delay: 0s; }
  .el-2 { animation-delay: 0.4s; }
  .el-3 { animation-delay: 0.8s; }
  .el-4 { animation-delay: 1.2s; }
  .el-5 { animation-delay: 1.8s; }
  .el-6 { animation-delay: 2.1s; }
  .el-7 { animation-delay: 2.4s; }
  .el-8 { animation-delay: 3s; }

  .chart-bar {
    transform-origin: bottom;
    transform: scaleY(0);
    animation: barGrow 8s ease-out infinite;
    animation-delay: 3.2s;
  }

  .chart-bar:nth-child(2) { animation-delay: 3.35s; }
  .chart-bar:nth-child(3) { animation-delay: 3.5s; }
  .chart-bar:nth-child(4) { animation-delay: 3.65s; }
  .chart-bar:nth-child(5) { animation-delay: 3.8s; }
  .chart-bar:nth-child(6) { animation-delay: 3.95s; }
  .chart-bar:nth-child(7) { animation-delay: 4.1s; }
</style>

<script>
  const observeElements = () => {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  };
  
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', observeElements);
  } else {
    observeElements();
  }
</script>
