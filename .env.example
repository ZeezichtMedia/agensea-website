# ─────────────────────────────────────────────
# Agensea website — environment variables
# Kopieer dit bestand naar `.env` (niet committen) en vul de waardes in.
# Op Vercel: zet ze onder Project Settings → Environment Variables.
# ─────────────────────────────────────────────

# AI-zoekfunctie (Groq, OpenAI-compatible)
# Aanmaken: https://console.groq.com/keys
GROQ_API_KEY=

# Google PageSpeed Insights API (server-side, niet PUBLIC_)
# Aanmaken: https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_API_KEY=

# Webhook waar /api/scan-lead resultaten naartoe stuurt (optioneel)
SCAN_WEBHOOK_URL=

# ─────────────────────────────────────────────
# SMTP — voor toekomstige form endpoints (/api/contact, /api/offerte)
# Werkt met Gmail, Office365, of een eigen mailserver.
# ─────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Agensea Website <noreply@agensea.nl>"
SMTP_TO=info@agensea.nl
