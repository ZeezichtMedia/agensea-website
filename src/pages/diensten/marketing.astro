---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Cases from '../../components/Cases.astro';
import CTA from '../../components/CTA.astro';
---

<Layout title="Online Marketing & Groei | Agensea">
  <Navbar />
  
  <main class="bg-cream min-h-screen pt-28 md:pt-36 pb-20 overflow-hidden relative">
    <!-- Background Decor -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
      <div class="mesh-blob w-[600px] h-[600px] bg-indigo/10 top-[-10%] right-[-10%] blur-[120px]"></div>
      <div class="mesh-blob w-[500px] h-[500px] bg-violet/10 bottom-[10%] left-[-10%] blur-[100px]"></div>
    </div>

    <!-- Hero Section -->
    <section class="max-w-7xl mx-auto px-6 lg:px-10 relative z-10 mb-16 md:mb-28">
      <div class="grid lg:grid-cols-12 gap-10 lg:gap-14 items-center">
        <!-- Content -->
        <div class="lg:col-span-7">
          <div class="reveal">
            <span class="inline-flex items-center gap-2 text-xs font-bold text-indigo uppercase tracking-[0.2em] mb-6">
              <span class="w-8 h-[2px] bg-indigo"></span>
              Onze diensten
            </span>
            <h1 class="font-display font-bold text-4xl md:text-5xl lg:text-6xl leading-[1.05] tracking-tight text-dark mb-5">
              Meer klanten en <span class="text-indigo">online groei.</span>
            </h1>
            <p class="text-base md:text-lg text-text-secondary leading-relaxed mb-8 max-w-xl">
              Of je nu meer bereik, naamsbekendheid of concrete leads wilt: wij zetten de juiste campagnes op, op de juiste kanalen, voor de juiste doelgroep. Datagedreven en altijd transparant.
            </p>
            <div class="flex flex-wrap gap-4">
              <a href="/contact" class="magnetic-btn px-8 mx-0 py-4 bg-dark text-white rounded-xl font-medium hover:bg-indigo transition-colors duration-300">
                Laten we sparren
              </a>
              <a href="#werkwijze" class="px-8 py-4 border border-warm-grey/50 rounded-xl font-medium text-dark hover:border-indigo transition-all duration-300">
                Ontdek onze aanpak
              </a>
            </div>

          </div>
        </div>
        <!-- Right: Ad Platform Cycler -->
        <div class="lg:col-span-5 reveal" style="transition-delay: 200ms;">
          <div class="w-full bg-white rounded-[2rem] shadow-2xl overflow-hidden border border-white relative">
            <div class="h-9 bg-[#f5f3ef] flex items-center px-4 gap-3 border-b border-warm-grey/15">
              <div class="flex gap-1.5">
                <div class="w-2.5 h-2.5 rounded-full bg-[#FF5F57]"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-[#FEBC2E]"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-[#28C840]"></div>
              </div>
              <span id="adPlatformLabel" class="ml-2 text-[9px] font-bold uppercase tracking-wider text-text-secondary/50 transition-opacity duration-300">Google Search</span>
              <div class="ml-auto flex gap-1.5">
                <div class="ad-dot w-1.5 h-1.5 rounded-full bg-dark/40" data-index="0"></div>
                <div class="ad-dot w-1.5 h-1.5 rounded-full bg-dark/15" data-index="1"></div>
                <div class="ad-dot w-1.5 h-1.5 rounded-full bg-dark/15" data-index="2"></div>
                <div class="ad-dot w-1.5 h-1.5 rounded-full bg-dark/15" data-index="3"></div>
              </div>
            </div>

            <div id="adContainer" class="h-[290px] relative overflow-hidden">

              <!-- Google Search Ad -->
              <div class="ad-layout active" data-platform="Google Search" id="ad1">
                <div class="p-5 space-y-3">
                  <div class="ad-el">
                    <div class="flex items-center gap-2 mb-1.5">
                      <div class="w-6 h-6 rounded-full bg-[#f1f3f4] flex items-center justify-center">
                        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
                      </div>
                      <div class="flex-1 h-8 bg-[#f1f3f4] rounded-full flex items-center px-3">
                        <span class="text-[10px] text-dark/50">loodgieter rotterdam spoed</span>
                      </div>
                    </div>
                  </div>
                  <div class="ad-el">
                    <div class="flex items-center gap-1.5 mb-1">
                      <span class="text-[9px] font-bold text-dark/40 bg-dark/5 px-1.5 py-0.5 rounded">Gesponsord</span>
                      <span class="text-[9px] text-dark/30">·</span>
                      <span class="text-[9px] text-dark/40">www.debrouwerloodgieters.nl</span>
                    </div>
                    <p class="text-[12px] font-semibold text-[#1a0dab] leading-tight mb-1">Loodgieter Rotterdam - Binnen 30 Min Ter Plaatse</p>
                    <p class="text-[9px] text-dark/50 leading-relaxed mb-2">24/7 bereikbaar voor spoed. Geen voorrijkosten. Lekkage, verstopping of cv-storing? Bel direct en wij komen vandaag nog langs. ★★★★★ 4.8 (312 reviews)</p>
                    <div class="flex gap-4">
                      <span class="text-[9px] text-[#1a0dab]">Bel: 010-1234567</span>
                      <span class="text-[9px] text-[#1a0dab]">Tarieven</span>
                      <span class="text-[9px] text-[#1a0dab]">Reviews</span>
                    </div>
                  </div>
                  <div class="ad-el border-t border-warm-grey/10 pt-2 opacity-50">
                    <p class="text-[9px] text-dark/30 mb-0.5">www.loodgieter24.nl</p>
                    <p class="text-[11px] text-[#1a0dab]/60 leading-tight">Loodgieter Nodig? - Snel en Vakkundig</p>
                  </div>
                  <div class="ad-el border-t border-warm-grey/10 pt-2 opacity-30">
                    <p class="text-[9px] text-dark/25 mb-0.5">www.rioolservice-rdam.nl</p>
                    <p class="text-[11px] text-[#1a0dab]/40 leading-tight">Rioolproblemen? - Professionele Hulp</p>
                  </div>
                </div>
              </div>

              <!-- Instagram Feed Ad -->
              <div class="ad-layout" data-platform="Instagram" id="ad2">
                <div class="p-4 space-y-2.5">
                  <div class="ad-el flex items-center justify-between">
                    <div class="flex items-center gap-2.5">
                      <div class="w-9 h-9 rounded-full bg-gradient-to-tr from-amber-400 via-pink-500 to-violet-600 p-[2px]">
                        <div class="w-full h-full rounded-full bg-white flex items-center justify-center">
                          <span class="text-[8px] font-bold text-dark">NC</span>
                        </div>
                      </div>
                      <div>
                        <p class="text-[10px] font-bold text-dark leading-none">nordic_coffee_co</p>
                        <p class="text-[8px] text-dark/40 mt-0.5">Gesponsord</p>
                      </div>
                    </div>
                    <div class="flex gap-0.5"><div class="w-1 h-1 rounded-full bg-dark/40"></div><div class="w-1 h-1 rounded-full bg-dark/40"></div><div class="w-1 h-1 rounded-full bg-dark/40"></div></div>
                  </div>
                  <div class="ad-el w-full h-[120px] bg-gradient-to-br from-amber-50 via-orange-50 to-amber-100 rounded-lg flex items-center justify-center relative overflow-hidden">
                    <div class="absolute inset-0 bg-gradient-to-t from-dark/10 to-transparent"></div>
                    <span class="text-3xl select-none">☕</span>
                  </div>
                  <div class="ad-el flex items-center justify-between">
                    <div class="flex items-center gap-3.5">
                      <svg class="w-5 h-5 text-dark/70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                      <svg class="w-5 h-5 text-dark/70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                      <svg class="w-5 h-5 text-dark/70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/></svg>
                    </div>
                    <svg class="w-5 h-5 text-dark/70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
                  </div>
                  <div class="ad-el">
                    <p class="text-[10px] font-bold text-dark mb-0.5">1.247 vind-ik-leuks</p>
                    <p class="text-[9px] text-dark leading-snug"><span class="font-bold">nordic_coffee_co</span> Begin je ochtend goed. Onze nieuwe herfstblend is er. 🍂 Bestel nu met 15% korting. Link in bio.</p>
                    <p class="text-[8px] text-dark/30 mt-1">Bekijk alle 84 reacties</p>
                  </div>
                </div>
              </div>

              <!-- LinkedIn Sponsored Post -->
              <div class="ad-layout" data-platform="LinkedIn" id="ad3">
                <div class="p-5 space-y-2.5">
                  <div class="ad-el flex items-center gap-2.5">
                    <div class="w-10 h-10 rounded-md bg-[#0A66C2] flex items-center justify-center shrink-0">
                      <span class="text-[10px] font-bold text-white">TS</span>
                    </div>
                    <div class="flex-1">
                      <p class="text-[10px] font-bold text-dark leading-none">TechScale Solutions</p>
                      <p class="text-[8px] text-dark/40 mt-0.5">24.891 volgers</p>
                      <p class="text-[8px] text-dark/30">Gesponsord · <span class="text-dark/25">🌐</span></p>
                    </div>
                  </div>
                  <div class="ad-el">
                    <p class="text-[9px] text-dark/70 leading-relaxed">Waarom 200+ B2B-bedrijven overstapten naar ons CRM-platform. De resultaten spreken voor zich: 42% meer dealflow en 3x snellere opvolging. Ontdek hoe.</p>
                  </div>
                  <div class="ad-el bg-[#f3f6f8] rounded-lg border border-[#e0e0e0] overflow-hidden">
                    <div class="h-16 bg-gradient-to-r from-[#0A66C2]/15 to-[#0A66C2]/5 flex items-center justify-center">
                      <span class="text-[9px] font-bold text-[#0A66C2]/50 uppercase tracking-wider">Case Study</span>
                    </div>
                    <div class="p-3">
                      <p class="text-[9px] text-dark/70 leading-none mb-0.5">techscale.io</p>
                      <p class="text-[10px] font-bold text-dark leading-tight">Van 50 naar 200+ klanten in 12 maanden</p>
                      <p class="text-[8px] text-dark/40 mt-0.5">Gratis whitepaper downloaden</p>
                    </div>
                  </div>
                  <div class="ad-el flex items-center justify-between pt-1">
                    <div class="flex items-center gap-1">
                      <div class="flex -space-x-1">
                        <div class="w-3.5 h-3.5 rounded-full bg-[#0A66C2]"></div>
                        <div class="w-3.5 h-3.5 rounded-full bg-[#44b37f]"></div>
                        <div class="w-3.5 h-3.5 rounded-full bg-[#e77c7c]"></div>
                      </div>
                      <span class="text-[8px] text-dark/35 ml-1">128</span>
                    </div>
                    <span class="text-[8px] text-dark/35">43 reacties · 12 reposts</span>
                  </div>
                </div>
              </div>

              <!-- Google Display Banner -->
              <div class="ad-layout" data-platform="Display Banner" id="ad4">
                <div class="p-5 space-y-3">
                  <div class="ad-el text-center">
                    <span class="text-[7px] font-bold text-dark/20 uppercase tracking-widest">Advertentie · Google Display Network</span>
                  </div>
                  <div class="ad-el w-full h-44 bg-gradient-to-br from-dark via-[#1a1a2e] to-indigo/90 rounded-2xl p-5 flex flex-col justify-between relative overflow-hidden">
                    <div class="absolute top-0 right-0 w-32 h-32 bg-indigo/20 rounded-full blur-3xl"></div>
                    <div class="absolute bottom-0 left-0 w-20 h-20 bg-violet/20 rounded-full blur-2xl"></div>
                    <div class="relative z-10">
                      <p class="text-[8px] text-white/40 uppercase tracking-wider font-bold mb-1.5">FitMax Pro</p>
                      <p class="text-[14px] font-bold text-white leading-tight mb-1">Jouw persoonlijke <br/>trainingsplan in 5 min.</p>
                      <p class="text-[9px] text-white/50">AI-gestuurd. 100% op maat.</p>
                    </div>
                    <div class="relative z-10 flex items-center justify-between">
                      <p class="text-[8px] text-white/30">fitmaxpro.nl</p>
                      <div class="px-3.5 py-1.5 bg-white rounded-md">
                        <span class="text-[9px] font-bold text-dark">Start gratis</span>
                      </div>
                    </div>
                  </div>
                  <div class="ad-el flex items-center justify-between px-1">
                    <span class="text-[7px] text-dark/20">Waarom deze advertentie?</span>
                    <div class="flex items-center gap-1">
                      <svg class="w-3 h-3 text-dark/20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
                      <svg class="w-3 h-3 text-dark/20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
                    </div>
                  </div>
                </div>
              </div>

            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- Werkwijze: Clean Typographic Strips -->
    <section id="werkwijze" class="relative z-10 py-24 md:py-40">
      <div class="max-w-7xl mx-auto px-6 lg:px-10">
        <div class="reveal mb-16 md:mb-24">
          <span class="inline-flex items-center gap-2 text-xs font-bold text-indigo uppercase tracking-[0.2em] mb-6">
            <span class="w-8 h-[2px] bg-indigo"></span>
            Werkwijze
          </span>
          <h2 class="font-display text-4xl md:text-6xl font-bold leading-[1.05] text-dark max-w-3xl">
            Vier stappen naar <span class="text-indigo">meetbaar resultaat.</span>
          </h2>
        </div>
      </div>

      <div class="border-t border-warm-grey">
        
        <!-- Stap 1 -->
        <div class="reveal group block border-b border-warm-grey">
          <div class="max-w-7xl mx-auto px-6 lg:px-10 py-12 md:py-16 grid md:grid-cols-12 gap-6 md:gap-12 items-start">
            <div class="md:col-span-2">
              <span class="font-display text-7xl md:text-8xl font-bold bg-gradient-to-b from-indigo to-indigo/20 bg-clip-text text-transparent leading-none select-none">01</span>
            </div>
            <div class="md:col-span-4">
              <h3 class="font-display font-bold text-2xl md:text-3xl text-dark">Kennismaking</h3>
              <span class="inline-block mt-2 text-xs font-bold text-text-secondary uppercase tracking-widest">Vrijblijvend</span>
            </div>
            <div class="md:col-span-6">
              <p class="text-text-secondary text-base md:text-lg leading-relaxed">
                We duiken in je business, ontleden samen de doelgroep en leveren een transparant voorstel op maat. Inclusief platformkeuze, budgetindicatie en een helder kostenplaatje. Geen verrassingen.
              </p>
            </div>
          </div>
        </div>

        <!-- Stap 2 -->
        <div class="reveal group block border-b border-warm-grey">
          <div class="max-w-7xl mx-auto px-6 lg:px-10 py-12 md:py-16 grid md:grid-cols-12 gap-6 md:gap-12 items-start">
            <div class="md:col-span-2">
              <span class="font-display text-7xl md:text-8xl font-bold bg-gradient-to-b from-violet to-violet/20 bg-clip-text text-transparent leading-none select-none">02</span>
            </div>
            <div class="md:col-span-4">
              <h3 class="font-display font-bold text-2xl md:text-3xl text-dark">Strategie op maat</h3>
              <span class="inline-block mt-2 text-xs font-bold text-violet bg-violet/10 px-3 py-1 rounded-full uppercase tracking-widest">Na akkoord</span>
            </div>
            <div class="md:col-span-6">
              <p class="text-text-secondary text-base md:text-lg leading-relaxed">
                Van grove schets naar scherp plan. We verfijnen de doelgroep, verdelen het budget over de juiste kanalen en zetten KPI's en meetpunten klaar. Zodat elke euro die je investeert meetbaar is.
              </p>
            </div>
          </div>
        </div>

        <!-- Stap 3 -->
        <div class="reveal group block border-b border-warm-grey">
          <div class="max-w-7xl mx-auto px-6 lg:px-10 py-12 md:py-16 grid md:grid-cols-12 gap-6 md:gap-12 items-start">
            <div class="md:col-span-2">
              <span class="font-display text-7xl md:text-8xl font-bold bg-gradient-to-b from-indigo to-indigo/20 bg-clip-text text-transparent leading-none select-none">03</span>
            </div>
            <div class="md:col-span-4">
              <h3 class="font-display font-bold text-2xl md:text-3xl text-dark">Lancering</h3>
              <span class="inline-block mt-2 text-xs font-bold text-text-secondary uppercase tracking-widest">Go live</span>
            </div>
            <div class="md:col-span-6">
              <p class="text-text-secondary text-base md:text-lg leading-relaxed">
                Accounts gekoppeld, pixels geplaatst, advertenties vormgegeven, doelgroepen ingesteld. Alles staat klaar. Dan drukken we samen op de knop en gaan jouw campagnes live.
              </p>
            </div>
          </div>
        </div>

        <!-- Stap 4 -->
        <div class="reveal group block border-b border-warm-grey bg-gradient-to-r from-indigo/[0.04] to-transparent">
          <div class="max-w-7xl mx-auto px-6 lg:px-10 py-12 md:py-16 grid md:grid-cols-12 gap-6 md:gap-12 items-start">
            <div class="md:col-span-2">
              <span class="font-display text-7xl md:text-8xl font-bold bg-gradient-to-b from-emerald-500 to-emerald-500/20 bg-clip-text text-transparent leading-none select-none">04</span>
            </div>
            <div class="md:col-span-4">
              <h3 class="font-display font-bold text-2xl md:text-3xl text-dark">Optimalisatie</h3>
              <span class="inline-flex items-center gap-2 mt-2 text-xs font-bold text-emerald-600 bg-emerald-50 px-3 py-1 rounded-full uppercase tracking-widest">
                <span class="relative flex h-1.5 w-1.5">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-emerald-500"></span>
                </span>
                Doorlopend
              </span>
            </div>
            <div class="md:col-span-6">
              <p class="text-text-secondary text-base md:text-lg leading-relaxed">
                Hier stopt het niet. We monitoren dagelijks, testen nieuwe varianten, sturen budgetten bij en rapporteren transparant. Zo halen we steeds meer uit elke euro die je investeert.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <Cases />
    <CTA />
  </main>
  
  <Footer />
</Layout>

<style>
  .ad-layout {
    position: absolute;
    inset: 0;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.5s ease;
  }
  .ad-layout.active {
    opacity: 1;
    pointer-events: auto;
  }
  .ad-layout .ad-el {
    opacity: 0;
    transform: translateY(8px);
  }
  .ad-layout.active .ad-el {
    animation: adBuild 0.5s ease-out forwards;
  }
  .ad-layout.active .space-y-3 > .ad-el:nth-child(1),
  .ad-layout.active .space-y-4 > .ad-el:nth-child(1) { animation-delay: 0.1s; }
  .ad-layout.active .space-y-3 > .ad-el:nth-child(2),
  .ad-layout.active .space-y-4 > .ad-el:nth-child(2) { animation-delay: 0.35s; }
  .ad-layout.active .space-y-3 > .ad-el:nth-child(3),
  .ad-layout.active .space-y-4 > .ad-el:nth-child(3) { animation-delay: 0.6s; }
  .ad-layout.active .space-y-3 > .ad-el:nth-child(4),
  .ad-layout.active .space-y-4 > .ad-el:nth-child(4) { animation-delay: 0.85s; }
  .ad-layout.active .space-y-3 > .ad-el:nth-child(5),
  .ad-layout.active .space-y-4 > .ad-el:nth-child(5) { animation-delay: 1.05s; }
  .ad-layout.fading .ad-el {
    animation: adFade 0.35s ease-in forwards !important;
  }
  @keyframes adBuild {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes adFade {
    from { opacity: 1; transform: translateY(0); }
    to { opacity: 0; transform: translateY(-4px); }
  }
</style>

<script>
  const observeElements = () => {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
        }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', observeElements);
  } else {
    observeElements();
  }

  // Ad platform cycler
  const adLayouts = document.querySelectorAll('.ad-layout');
  const adLabel = document.getElementById('adPlatformLabel');
  const adDots = document.querySelectorAll('.ad-dot');
  let adCurrent = 0;
  const AD_DISPLAY = 4000;
  const AD_FADE = 450;

  function updateDots(index) {
    adDots.forEach((dot, i) => {
      if (i === index) {
        dot.className = 'ad-dot w-1.5 h-1.5 rounded-full bg-dark/40 transition-all duration-300';
      } else {
        dot.className = 'ad-dot w-1.5 h-1.5 rounded-full bg-dark/15 transition-all duration-300';
      }
    });
  }

  function showAd(index) {
    const layout = adLayouts[index];
    if (adLabel && layout.dataset.platform) {
      adLabel.style.opacity = '0';
      setTimeout(() => {
        adLabel.textContent = layout.dataset.platform;
        adLabel.style.opacity = '1';
      }, 180);
    }
    updateDots(index);
    layout.querySelectorAll('.ad-el').forEach(el => {
      el.style.animation = 'none';
      el.offsetHeight;
      el.style.animation = '';
    });
    layout.classList.remove('fading');
    layout.classList.add('active');
  }

  function hideAd(index) {
    const layout = adLayouts[index];
    layout.classList.add('fading');
    setTimeout(() => {
      layout.classList.remove('active', 'fading');
    }, AD_FADE);
  }

  function cycleAd() {
    hideAd(adCurrent);
    setTimeout(() => {
      adCurrent = (adCurrent + 1) % adLayouts.length;
      showAd(adCurrent);
    }, AD_FADE);
  }

  showAd(0);
  setInterval(cycleAd, AD_DISPLAY + AD_FADE);
</script>
