</footer>

<script>
  function formatTime(ms) {
    const totalSeconds = Math.floor(ms / 1000);
    const hours = Math.floor(totalSeconds / 3600);
    const minutes = Math.floor((totalSeconds % 3600) / 60);
    const seconds = totalSeconds % 60;
    
    return `${hours}u ${minutes.toString().padStart(2, '0')}m ${seconds.toString().padStart(2, '0')}s`;
  }

  function updateOnlineStatus() {
    const now = new Date();
    const hour = now.getHours();
    const day = now.getDay();
    
    // Werktijden: ma t/m vr, van 08:00 tot 19:00
    const isWorkday = day >= 1 && day <= 5;
    const isOnline = isWorkday && hour >= 8 && hour < 19;

    const dot = document.getElementById("status-dot");
    const text = document.getElementById("status-text");
    if (!dot || !text) return;

    if (isOnline) {
      dot.className = "w-1.5 h-1.5 rounded-full bg-green-500 animate-[pulse_2s_cubic-bezier(0.4,0,0.6,1)_infinite]";
      
      const close = new Date(now);
      close.setHours(19, 0, 0, 0);
      
      const diffMs = close.getTime() - now.getTime();
      text.textContent = `Nog ${formatTime(diffMs)} telefonisch bereikbaar`;
      
    } else {
      dot.className = "w-1.5 h-1.5 rounded-full bg-red-400";
      
      // Zoek het volgende geluksmomentje (08:00)
      let nextOpening = new Date(now);
      nextOpening.setHours(8, 0, 0, 0);
      
      // Als we al voorbij 8 uur 's ochtends zijn, dan is het op zijn vroegst morgen 08:00.
      if (hour >= 8) {
        nextOpening.setDate(nextOpening.getDate() + 1);
      }
      
      // Als het op zaterdag (6) of zondag (0) valt, verplaats
      if (nextOpening.getDay() === 6) {
        nextOpening.setDate(nextOpening.getDate() + 2);
      } else if (nextOpening.getDay() === 0) {
        nextOpening.setDate(nextOpening.getDate() + 1);
      }
      
      const diffMs = nextOpening.getTime() - now.getTime();
      // Laat de klok altijd onafgebroken live aftellen, ook doordeweeks en in het weekend.
      text.textContent = `Weer bereikbaar over ${formatTime(diffMs)}`;
    }
  }

  updateOnlineStatus();
  setInterval(updateOnlineStatus, 1000);
</script>
