---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Cases from '../../components/Cases.astro';
import CTA from '../../components/CTA.astro';
---

<Layout title="Online Marketing & Groei | Agensea">
  <Navbar />
  
  <main class="bg-cream min-h-screen pt-28 md:pt-36 pb-20 overflow-hidden relative">
    <!-- Background Decor -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
      <div class="mesh-blob w-[600px] h-[600px] bg-indigo/10 top-[-10%] right-[-10%] blur-[120px]"></div>
      <div class="mesh-blob w-[500px] h-[500px] bg-violet/10 bottom-[10%] left-[-10%] blur-[100px]"></div>
    </div>

    <!-- Hero Section -->
    <section class="max-w-7xl mx-auto px-6 lg:px-10 relative z-10 mb-16 md:mb-28">
      <div class="grid lg:grid-cols-12 gap-10 lg:gap-14 items-center">
        <!-- Content -->
        <div class="lg:col-span-7">
          <div class="reveal">
            <span class="inline-flex items-center gap-2 text-xs font-bold text-indigo uppercase tracking-[0.2em] mb-6">
              <span class="w-8 h-[2px] bg-indigo"></span>
              Onze diensten
            </span>
            <h1 class="font-display font-bold text-4xl md:text-5xl lg:text-6xl leading-[1.05] tracking-tight text-dark mb-5">
              Meer klanten en <span class="text-indigo">online groei.</span>
            </h1>
            <p class="text-base md:text-lg text-text-secondary leading-relaxed mb-8 max-w-xl">
              Of je nu meer bereik, naamsbekendheid of concrete leads wilt: wij zetten de juiste campagnes op, op de juiste kanalen, voor de juiste doelgroep. Datagedreven en altijd transparant.
            </p>
            <div class="flex flex-wrap gap-4">
              <a href="/contact" class="magnetic-btn px-8 mx-0 py-4 bg-dark text-white rounded-xl font-medium hover:bg-indigo transition-colors duration-300">
                Laten we sparren
              </a>
              <a href="#werkwijze" class="px-8 py-4 border border-warm-grey/50 rounded-xl font-medium text-dark hover:border-indigo transition-all duration-300">
                Ontdek onze aanpak
              </a>
            </div>

          </div>
        </div>
        <!-- Right: Ad Platform Mobile Cycler -->
        <div class="lg:col-span-5 reveal flex items-center justify-center lg:justify-end" style="transition-delay: 200ms;">
          <!-- Mobile Phone Frame -->
          <div class="w-[280px] h-[580px] bg-white rounded-[2.5rem] shadow-[0_20px_50px_-12px_rgba(0,0,0,0.15)] overflow-hidden border-[8px] border-dark relative flex flex-col ring-1 ring-black/5">
            <!-- Notch/Dynamic Island -->
            <div class="absolute top-0 inset-x-0 h-6 flex justify-center z-50">
              <div class="w-24 h-5 bg-dark rounded-b-xl relative">
                <div class="absolute right-4 top-1/2 -translate-y-1/2 w-1.5 h-1.5 rounded-full bg-white/10"></div>
              </div>
            </div>

            <!-- Mobile Status Bar -->
            <div class="h-[44px] w-full flex items-center px-[18px] justify-between text-[11px] font-semibold text-dark/80 z-40 relative bg-white/90 backdrop-blur-md">
              <span class="mt-0.5">09:41</span>
              <div class="flex items-center gap-1.5 mt-0.5">
                <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21L23.6 7.5C23.1 7.1 18.6 4 12 4C5.4 4 0.9 7.1 0.4 7.5L12 21Z"/></svg>
                <div class="w-[20px] h-[10px] rounded-[3px] border border-currentColor relative opacity-80"><div class="absolute inset-[1px] bg-currentColor w-[75%] rounded-[1.5px]"></div></div>
              </div>
            </div>

            <!-- App Header -->
            <div class="h-10 bg-white border-b border-warm-grey/15 flex items-center justify-between px-4 z-30 relative shrink-0">
               <span id="adPlatformLabel" class="text-[11px] font-bold tracking-wide text-dark transition-opacity duration-300">Google Search</span>
               <div class="flex gap-1.5">
                 <div class="ad-dot w-1.5 h-1.5 rounded-full bg-dark/40 transition-colors duration-300" data-index="0"></div>
                 <div class="ad-dot w-1.5 h-1.5 rounded-full bg-dark/15 transition-colors duration-300" data-index="1"></div>
                 <div class="ad-dot w-1.5 h-1.5 rounded-full bg-dark/15 transition-colors duration-300" data-index="2"></div>
                 <div class="ad-dot w-1.5 h-1.5 rounded-full bg-dark/15 transition-colors duration-300" data-index="3"></div>
               </div>
            </div>

            <!-- Ad Layout Container -->
            <div id="adContainer" class="flex-1 relative overflow-hidden bg-cream w-full">

              <!-- Google Search Ad -->
              <div class="ad-layout active" data-platform="Google Search" id="ad1">
                <div class="p-4 space-y-3">
                  <!-- Google Search Bar Mockup -->
                  <div class="ad-el relative">
                    <div class="w-full h-10 bg-white rounded-full shadow-sm border border-warm-grey/20 flex items-center px-4 gap-3">
                      <svg class="w-4 h-4 text-dark/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
                      <span class="text-[12px] text-dark/70">makelaar middelburg</span>
                    </div>
                  </div>
                  <div class="ad-el bg-white rounded-xl shadow-sm border border-warm-grey/10 p-4">
                    <div class="flex items-center gap-1.5 mb-1.5">
                      <span class="font-bold text-dark text-[11px]">Gesponsord</span>
                      <span class="text-[10px] text-dark/30">·</span>
                      <span class="text-[10px] text-dark/60">www.zeeuwsehuizen.nl</span>
                    </div>
                    <p class="text-[14px] font-medium text-[#1a0dab] leading-tight mb-2 hover:underline cursor-pointer">Makelaar Middelburg - Jouw Woning Snel Verkocht</p>
                    <p class="text-[11px] text-dark/70 leading-relaxed mb-3">Dé lokale NVM makelaar van Walcheren. Persoonlijke en deskundige aanpak. Vraag direct een gratis waardebepaling aan. ★★★★★ 4.9 (148 reviews)</p>
                    <div class="flex flex-wrap gap-2">
                      <span class="text-[11px] text-[#1a0dab] bg-[#1a0dab]/5 px-2 py-1 rounded-full">Gratis Waardebepaling</span>
                      <span class="text-[11px] text-[#1a0dab] bg-[#1a0dab]/5 px-2 py-1 rounded-full">Aanbod Bekijken</span>
                      <span class="text-[11px] text-[#1a0dab] bg-[#1a0dab]/5 px-2 py-1 rounded-full">Contactgegevens</span>
                    </div>
                  </div>
                  <div class="ad-el bg-white rounded-xl shadow-sm border border-warm-grey/10 p-4 opacity-70">
                    <p class="text-[10px] text-dark/60 mb-0.5">www.walcherenmakelaardij.nl</p>
                    <p class="text-[13px] font-medium text-[#1a0dab] leading-tight">Huis Verkopen in Middelburg - Lokale Expert</p>
                  </div>
                </div>
              </div>

              <!-- Instagram Feed Ad -->
              <div class="ad-layout bg-white" data-platform="Instagram" id="ad2">
                <div class="flex flex-col h-full">
                  <div class="ad-el px-3 py-2.5 flex items-center justify-between border-b border-warm-grey/10">
                    <div class="flex items-center gap-2.5">
                      <div class="w-8 h-8 rounded-full bg-gradient-to-tr from-amber-400 via-pink-500 to-violet-600 p-[2px]">
                        <div class="w-full h-full rounded-full bg-white flex items-center justify-center">
                          <span class="text-[10px] font-bold text-dark">NC</span>
                        </div>
                      </div>
                      <div>
                        <p class="text-[12px] font-bold text-dark leading-none">nordic_coffee_co</p>
                        <p class="text-[10px] text-dark/50 mt-0.5">Gesponsord</p>
                      </div>
                    </div>
                    <svg class="w-4 h-4 text-dark/60" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="5" r="2"/><circle cx="12" cy="12" r="2"/><circle cx="12" cy="19" r="2"/></svg>
                  </div>
                  <div class="ad-el w-full aspect-[4/5] bg-gradient-to-br from-[#f8ece5] to-[#f4dcd1] flex items-center justify-center relative shadow-inner">
                    <span class="text-6xl select-none drop-shadow-lg">☕</span>
                    <div class="absolute bottom-3 right-3 bg-dark/60 backdrop-blur-sm text-white text-[10px] px-2 py-1 rounded-full font-medium">1/1</div>
                  </div>
                  <div class="ad-el px-3 py-3">
                    <div class="flex items-center justify-between mb-2">
                      <div class="flex items-center gap-4">
                        <svg class="w-6 h-6 text-dark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                        <svg class="w-6 h-6 text-dark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                        <svg class="w-6 h-6 text-dark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/></svg>
                      </div>
                      <svg class="w-6 h-6 text-dark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
                    </div>
                    <p class="text-[12px] font-bold text-dark mb-1">1.247 vind-ik-leuks</p>
                    <p class="text-[11px] text-dark leading-snug"><span class="font-bold">nordic_coffee_co</span> Begin je ochtend goed. Onze nieuwe herfstblend is er. 🍂 Bestel nu met 15% korting. Link in bio.</p>
                  </div>
                </div>
              </div>

              <!-- LinkedIn Sponsored Post -->
              <div class="ad-layout bg-white" data-platform="LinkedIn" id="ad3">
                <div class="flex flex-col h-full pt-3">
                  <div class="ad-el px-4 flex items-start gap-3 mb-2">
                    <div class="w-10 h-10 rounded-md bg-[#0A66C2] flex items-center justify-center shrink-0">
                      <span class="text-[12px] font-bold text-white">TS</span>
                    </div>
                    <div class="flex-1 mt-0.5">
                      <p class="text-[12px] font-bold text-dark leading-none">TechScale Solutions</p>
                      <p class="text-[10px] text-dark/50 mt-1">24.891 volgers</p>
                      <p class="text-[9px] text-dark/40 flex items-center gap-1">Gesponsord · 🌐</p>
                    </div>
                    <svg class="w-4 h-4 text-dark/40" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="5" r="2"/><circle cx="12" cy="12" r="2"/><circle cx="12" cy="19" r="2"/></svg>
                  </div>
                  <div class="ad-el px-4 mb-2">
                    <p class="text-[11px] text-dark/80 leading-relaxed">Waarom 200+ B2B-bedrijven overstapten naar ons CRM-platform. 42% meer dealflow en 3x snellere opvolging. Ontdek hoe in onze nieuwe gids. 👇</p>
                  </div>
                  <div class="ad-el w-full aspect-[4/5] bg-gradient-to-br from-[#f3f6f8] to-[#e1e9f0] border-y border-warm-grey/20 flex flex-col items-center justify-center p-6 text-center relative cursor-pointer">
                    <div class="absolute inset-0 bg-gradient-to-b from-[#0A66C2]/5 to-[#0A66C2]/10 opacity-70 border-b-2 border-[#0A66C2]"></div>
                    <div class="relative z-10 w-12 h-12 rounded-lg bg-white shadow-md flex items-center justify-center mb-4">
                      <svg class="w-6 h-6 text-[#0A66C2]" viewBox="0 0 24 24" fill="currentColor"><path d="M19 3H5c-1.11 0-2 .89-2 2v14c0 1.11.89 2 2 2h14c1.11 0 2-.89 2-2V5c0-1.11-.89-2-2-2zm-2 10h-4v4h-2v-4H7v-2h4V7h2v4h4v2z"/></svg>
                    </div>
                    <p class="relative z-10 text-[18px] font-bold text-dark leading-tight mb-2 uppercase tracking-wide">2026 B2B CRM<br/>Trends</p>
                    <p class="relative z-10 text-[11px] text-dark/60 mb-6 font-medium">Gratis Whitepaper (PDF)</p>
                    <span class="relative z-10 text-[10px] font-bold tracking-widest text-white px-5 py-2.5 bg-[#0A66C2] rounded-full uppercase shadow-md flex items-center gap-2">Download <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg></span>
                  </div>
                  <div class="ad-el px-4 py-2 flex items-center justify-between border-b border-warm-grey/10">
                    <div class="flex items-center gap-1.5">
                      <div class="flex -space-x-1">
                        <div class="w-4 h-4 rounded-full bg-[#0A66C2] border border-white flex items-center justify-center"><svg class="w-2.5 h-2.5 text-white" viewBox="0 0 24 24" fill="currentColor"><path d="M1 21h4V9H1v12zm22-11c0-1.1-.9-2-2-2h-6.31l.95-4.57.03-.32a1.505 1.505 0 0 0-.44-1.06L14.17 1 7.59 7.59C7.22 7.95 7 8.45 7 9v10c0 1.1.9 2 2 2h9c.83 0 1.54-.5 1.84-1.22l3.02-7.05c.09-.23.14-.47.14-.73v-2z"/></svg></div>
                        <div class="w-4 h-4 rounded-full bg-[#df704d] border border-white flex items-center justify-center"><svg class="w-2.5 h-2.5 text-white" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg></div>
                      </div>
                      <span class="text-[10px] text-dark/50">128</span>
                    </div>
                    <span class="text-[10px] text-dark/50">43 reacties</span>
                  </div>
                </div>
              </div>

              <!-- Display Banner Ad -->
              <div class="ad-layout bg-white flex flex-col justify-center h-full p-4" data-platform="Display Banner" id="ad4">
                <div class="ad-el text-center mb-3">
                  <span class="text-[8px] font-bold text-dark/30 uppercase tracking-widest bg-dark/5 px-2 py-1 rounded">Advertentie · Display Netwerk</span>
                </div>
                <!-- Banner itself (portrait format for mobile) -->
                <div class="ad-el w-full aspect-[4/5] bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-indigo-900 via-dark to-black rounded-2xl p-6 flex flex-col relative overflow-hidden shadow-2xl border border-white/5 mx-auto">
                  <div class="absolute -top-10 -right-10 w-40 h-40 bg-indigo/30 rounded-full blur-[40px] pointer-events-none"></div>
                  <div class="absolute bottom-10 -left-10 w-32 h-32 bg-violet-600/20 rounded-full blur-[30px] pointer-events-none"></div>
                  
                  <div class="relative z-10 flex-1 flex flex-col">
                    <p class="text-[10px] text-indigo-300 uppercase tracking-[0.2em] font-bold mb-3 flex items-center gap-1.5"><svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg> FitMax Pro</p>
                    <h3 class="text-[24px] font-bold text-white leading-[1.15] mb-2 tracking-tight">Jouw <br/><span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 to-violet-400">persoonlijke</span> <br/>trainingsplan <br/>in 5 min.</h3>
                    <p class="text-[12px] text-white/70 leading-relaxed max-w-[90%] mt-2">Volledig op maat, AI-gestuurd en altijd op zak. Resultaat gegarandeerd.</p>
                  </div>
                  
                  <div class="relative z-10 mt-auto pt-6 flex flex-col gap-3">
                    <button class="w-full py-3.5 bg-gradient-to-r from-indigo-500 to-violet-600 text-white rounded-xl font-bold text-[13px] shadow-[0_4px_14px_0_rgba(99,102,241,0.39)] flex items-center justify-center gap-2 hover:scale-[1.02] transition-transform">
                      Start 7 Dagen Gratis <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                    </button>
                    <p class="text-[9px] text-center text-white/40">Geen creditcard nodig.</p>
                  </div>
                </div>
                <div class="ad-el text-right mt-2">
                  <a href="#" class="text-[9px] text-dark/30 hover:underline inline-flex items-center gap-1">Waarom deze advertentie? <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg></a>
                </div>
              </div>

            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- Werkwijze: Clean Typographic Strips -->
    <section id="werkwijze" class="relative z-10 py-24 md:py-40">
      <div class="max-w-7xl mx-auto px-6 lg:px-10">
        <div class="reveal mb-16 md:mb-24">
          <span class="inline-flex items-center gap-2 text-xs font-bold text-indigo uppercase tracking-[0.2em] mb-6">
            <span class="w-8 h-[2px] bg-indigo"></span>
            Werkwijze
          </span>
          <h2 class="font-display text-4xl md:text-6xl font-bold leading-[1.05] text-dark max-w-3xl">
            Vier stappen naar <span class="text-indigo">meetbaar resultaat.</span>
          </h2>
        </div>
      </div>

      <div class="border-t border-warm-grey">
        
        <!-- Stap 1 -->
        <div class="reveal group block border-b border-warm-grey">
          <div class="max-w-7xl mx-auto px-6 lg:px-10 py-12 md:py-16 grid md:grid-cols-12 gap-6 md:gap-12 items-start">
            <div class="md:col-span-2">
              <span class="font-display text-7xl md:text-8xl font-bold bg-gradient-to-b from-indigo to-indigo/20 bg-clip-text text-transparent leading-none select-none">01</span>
            </div>
            <div class="md:col-span-4">
              <h3 class="font-display font-bold text-2xl md:text-3xl text-dark">Kennismaking</h3>
              <span class="inline-block mt-2 text-xs font-bold text-text-secondary uppercase tracking-widest">Vrijblijvend</span>
            </div>
            <div class="md:col-span-6">
              <p class="text-text-secondary text-base md:text-lg leading-relaxed">
                We duiken in je business, ontleden samen de doelgroep en leveren een transparant voorstel op maat. Inclusief platformkeuze, budgetindicatie en een helder kostenplaatje. Geen verrassingen.
              </p>
            </div>
          </div>
        </div>

        <!-- Stap 2 -->
        <div class="reveal group block border-b border-warm-grey">
          <div class="max-w-7xl mx-auto px-6 lg:px-10 py-12 md:py-16 grid md:grid-cols-12 gap-6 md:gap-12 items-start">
            <div class="md:col-span-2">
              <span class="font-display text-7xl md:text-8xl font-bold bg-gradient-to-b from-violet to-violet/20 bg-clip-text text-transparent leading-none select-none">02</span>
            </div>
            <div class="md:col-span-4">
              <h3 class="font-display font-bold text-2xl md:text-3xl text-dark">Strategie op maat</h3>
              <span class="inline-block mt-2 text-xs font-bold text-violet bg-violet/10 px-3 py-1 rounded-full uppercase tracking-widest">Na akkoord</span>
            </div>
            <div class="md:col-span-6">
              <p class="text-text-secondary text-base md:text-lg leading-relaxed">
                Van grove schets naar scherp plan. We verfijnen de doelgroep, verdelen het budget over de juiste kanalen en zetten KPI's en meetpunten klaar. Zodat elke euro die je investeert meetbaar is.
              </p>
            </div>
          </div>
        </div>

        <!-- Stap 3 -->
        <div class="reveal group block border-b border-warm-grey">
          <div class="max-w-7xl mx-auto px-6 lg:px-10 py-12 md:py-16 grid md:grid-cols-12 gap-6 md:gap-12 items-start">
            <div class="md:col-span-2">
              <span class="font-display text-7xl md:text-8xl font-bold bg-gradient-to-b from-indigo to-indigo/20 bg-clip-text text-transparent leading-none select-none">03</span>
            </div>
            <div class="md:col-span-4">
              <h3 class="font-display font-bold text-2xl md:text-3xl text-dark">Lancering</h3>
              <span class="inline-block mt-2 text-xs font-bold text-text-secondary uppercase tracking-widest">Go live</span>
            </div>
            <div class="md:col-span-6">
              <p class="text-text-secondary text-base md:text-lg leading-relaxed">
                Accounts gekoppeld, pixels geplaatst, advertenties vormgegeven, doelgroepen ingesteld. Alles staat klaar. Dan drukken we samen op de knop en gaan jouw campagnes live.
              </p>
            </div>
          </div>
        </div>

        <!-- Stap 4 -->
        <div class="reveal group block border-b border-warm-grey bg-gradient-to-r from-indigo/[0.04] to-transparent">
          <div class="max-w-7xl mx-auto px-6 lg:px-10 py-12 md:py-16 grid md:grid-cols-12 gap-6 md:gap-12 items-start">
            <div class="md:col-span-2">
              <span class="font-display text-7xl md:text-8xl font-bold bg-gradient-to-b from-emerald-500 to-emerald-500/20 bg-clip-text text-transparent leading-none select-none">04</span>
            </div>
            <div class="md:col-span-4">
              <h3 class="font-display font-bold text-2xl md:text-3xl text-dark">Optimalisatie</h3>
              <span class="inline-flex items-center gap-2 mt-2 text-xs font-bold text-emerald-600 bg-emerald-50 px-3 py-1 rounded-full uppercase tracking-widest">
                <span class="relative flex h-1.5 w-1.5">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-emerald-500"></span>
                </span>
                Doorlopend
              </span>
            </div>
            <div class="md:col-span-6">
              <p class="text-text-secondary text-base md:text-lg leading-relaxed">
                Hier stopt het niet. We monitoren dagelijks, testen nieuwe varianten, sturen budgetten bij en rapporteren transparant. Zo halen we steeds meer uit elke euro die je investeert.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <Cases />
    <CTA />
  </main>
  
  <Footer />
</Layout>

<style>
  .ad-layout {
    position: absolute;
    inset: 0;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.5s ease;
  }
  .ad-layout.active {
    opacity: 1;
    pointer-events: auto;
  }
  .ad-layout .ad-el {
    opacity: 0;
    transform: translateY(8px);
  }
  .ad-layout.active .ad-el {
    animation: adBuild 0.5s ease-out forwards;
  }
  .ad-layout.active .space-y-3 > .ad-el:nth-child(1),
  .ad-layout.active .space-y-4 > .ad-el:nth-child(1) { animation-delay: 0.1s; }
  .ad-layout.active .space-y-3 > .ad-el:nth-child(2),
  .ad-layout.active .space-y-4 > .ad-el:nth-child(2) { animation-delay: 0.35s; }
  .ad-layout.active .space-y-3 > .ad-el:nth-child(3),
  .ad-layout.active .space-y-4 > .ad-el:nth-child(3) { animation-delay: 0.6s; }
  .ad-layout.active .space-y-3 > .ad-el:nth-child(4),
  .ad-layout.active .space-y-4 > .ad-el:nth-child(4) { animation-delay: 0.85s; }
  .ad-layout.active .space-y-3 > .ad-el:nth-child(5),
  .ad-layout.active .space-y-4 > .ad-el:nth-child(5) { animation-delay: 1.05s; }
  .ad-layout.fading .ad-el {
    animation: adFade 0.35s ease-in forwards !important;
  }
  @keyframes adBuild {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes adFade {
    from { opacity: 1; transform: translateY(0); }
    to { opacity: 0; transform: translateY(-4px); }
  }
</style>

<script>
  const observeElements = () => {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
        }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', observeElements);
  } else {
    observeElements();
  }

  // Ad platform cycler
  const adLayouts = document.querySelectorAll('.ad-layout');
  const adLabel = document.getElementById('adPlatformLabel');
  const adDots = document.querySelectorAll('.ad-dot');
  let adCurrent = 0;
  const AD_DISPLAY = 4000;
  const AD_FADE = 450;

  function updateDots(index) {
    adDots.forEach((dot, i) => {
      if (i === index) {
        dot.className = 'ad-dot w-1.5 h-1.5 rounded-full bg-dark/40 transition-all duration-300';
      } else {
        dot.className = 'ad-dot w-1.5 h-1.5 rounded-full bg-dark/15 transition-all duration-300';
      }
    });
  }

  function showAd(index) {
    const layout = adLayouts[index];
    if (adLabel && layout.dataset.platform) {
      adLabel.style.opacity = '0';
      setTimeout(() => {
        adLabel.textContent = layout.dataset.platform;
        adLabel.style.opacity = '1';
      }, 180);
    }
    updateDots(index);
    layout.querySelectorAll('.ad-el').forEach(el => {
      el.style.animation = 'none';
      el.offsetHeight;
      el.style.animation = '';
    });
    layout.classList.remove('fading');
    layout.classList.add('active');
  }

  function hideAd(index) {
    const layout = adLayouts[index];
    layout.classList.add('fading');
    setTimeout(() => {
      layout.classList.remove('active', 'fading');
    }, AD_FADE);
  }

  function cycleAd() {
    hideAd(adCurrent);
    setTimeout(() => {
      adCurrent = (adCurrent + 1) % adLayouts.length;
      showAd(adCurrent);
    }, AD_FADE);
  }

  showAd(0);
  setInterval(cycleAd, AD_DISPLAY + AD_FADE);
</script>
