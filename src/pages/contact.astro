---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Contact"
  description="Neem contact op met Agensea. Bel, mail of vul het formulier in voor een vrijblijvend gesprek over je website, marketing of software project."
>
  <Navbar />
  
  <main id="main-content" class="bg-cream min-h-screen pt-32 md:pt-48 pb-20 overflow-hidden relative">
    <!-- Background Decor -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
      <div class="mesh-blob w-[600px] h-[600px] bg-indigo/10 top-[-10%] right-[-10%] blur-[120px]"></div>
      <div class="mesh-blob w-[500px] h-[500px] bg-violet/10 bottom-[10%] left-[-10%] blur-[100px]"></div>
    </div>

    <div class="max-w-7xl mx-auto px-6 lg:px-10 relative z-10">
      <div class="grid lg:grid-cols-12 gap-16 lg:gap-24">
        
        <!-- Left: Text & Info -->
        <div class="lg:col-span-5 relative">
          <div class="reveal">
            <span class="inline-flex items-center gap-2 text-xs font-bold text-indigo uppercase tracking-[0.2em] mb-6">
              <span class="w-8 h-[2px] bg-indigo"></span>
              Kennismaken
            </span>
            <h1 class="font-display font-bold text-5xl md:text-6xl lg:text-7xl leading-[1.05] tracking-tight text-dark mb-8">
              Laten we jouw ambities bespreken.
            </h1>
            <p class="text-lg text-text-secondary leading-relaxed mb-12">
              Klaar voor de volgende stap in je digitale landschap? Plan direct een moment in of stuur ons een bericht. We reageren (meestal) razendsnel.
            </p>
          </div>

          <div class="grid gap-8 reveal" style="transition-delay: 200ms;">
            <!-- Direct Contact -->
            <div class="p-8 bg-white rounded-3xl shadow-sm border border-warm-grey/50 hover:border-indigo/30 transition-colors group">
              <div class="w-12 h-12 bg-indigo/5 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                <svg class="w-5 h-5 text-indigo" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
              </div>
              <p class="text-[10px] font-bold text-text-secondary uppercase tracking-[0.2em] mb-2">Telefoon</p>
              <a href="tel:+31681383601" class="font-display font-bold text-2xl text-dark hover:text-indigo transition-colors">+31 6 81 38 36 01</a>
            </div>

            <!-- Direct Mail -->
            <div class="p-8 bg-white rounded-3xl shadow-sm border border-warm-grey/50 hover:border-indigo/30 transition-colors group">
              <div class="w-12 h-12 bg-indigo/5 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                <svg class="w-5 h-5 text-indigo" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              </div>
              <p class="text-[10px] font-bold text-text-secondary uppercase tracking-[0.2em] mb-2">E-mail</p>
              <a href="mailto:info@agensea.nl" class="font-display font-bold text-2xl text-dark hover:text-indigo transition-colors hover:tracking-tight">info@agensea.nl</a>
            </div>
          </div>
        </div>

        <!-- Right: Form -->
        <div class="lg:col-span-7 reveal" style="transition-delay: 300ms;">
          <div class="bg-white p-6 md:p-8 lg:p-12 rounded-[2.5rem] shadow-[0_8px_30px_rgb(0,0,0,0.04)] border border-warm-grey/20 relative">
            <div class="absolute top-0 right-0 p-8 opacity-5 pointer-events-none select-none">
              <svg class="w-32 h-32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
            </div>
            
            <h3 class="font-display font-bold text-3xl mb-8">Stuur een kort bericht</h3>
            
            <form method="POST" class="space-y-6 relative z-10" id="contact-form">
              <div class="grid md:grid-cols-2 gap-6">
                <div>
                  <label for="name" class="block text-xs font-bold text-dark uppercase tracking-wider mb-2">Naam <span class="text-indigo">*</span></label>
                  <input type="text" id="name" name="name" required class="w-full bg-cream border border-warm-grey/50 rounded-xl px-5 py-4 focus:outline-none focus:border-indigo focus:ring-1 focus:ring-indigo transition-all font-medium text-dark placeholder:text-text-secondary/50" placeholder="Voor- en achternaam">
                </div>
                <div>
                  <label for="bedrijf" class="block text-xs font-bold text-dark uppercase tracking-wider mb-2">Organisatie</label>
                  <input type="text" id="bedrijf" name="bedrijf" class="w-full bg-cream border border-warm-grey/50 rounded-xl px-5 py-4 focus:outline-none focus:border-indigo focus:ring-1 focus:ring-indigo transition-all font-medium text-dark placeholder:text-text-secondary/50" placeholder="Bedrijfsnaam">
                </div>
              </div>

              <div class="grid md:grid-cols-2 gap-6">
                <div>
                  <label for="email" class="block text-xs font-bold text-dark uppercase tracking-wider mb-2">E-mail <span class="text-indigo">*</span></label>
                  <input type="email" id="email" name="email" required class="w-full bg-cream border border-warm-grey/50 rounded-xl px-5 py-4 focus:outline-none focus:border-indigo focus:ring-1 focus:ring-indigo transition-all font-medium text-dark placeholder:text-text-secondary/50" placeholder="Jouw e-mailadres">
                </div>
                <div>
                  <label for="tel" class="block text-xs font-bold text-dark uppercase tracking-wider mb-2">Telefoonnummer</label>
                  <input type="tel" id="tel" name="tel" class="w-full bg-cream border border-warm-grey/50 rounded-xl px-5 py-4 focus:outline-none focus:border-indigo focus:ring-1 focus:ring-indigo transition-all font-medium text-dark placeholder:text-text-secondary/50" placeholder="Optioneel">
                </div>
              </div>

              <div>
                <label for="message" class="block text-xs font-bold text-dark uppercase tracking-wider mb-2">Je bericht <span class="text-indigo">*</span></label>
                <textarea id="message" name="message" required rows="5" class="w-full bg-cream border border-warm-grey/50 rounded-xl px-5 py-4 focus:outline-none focus:border-indigo focus:ring-1 focus:ring-indigo transition-all font-medium text-dark placeholder:text-text-secondary/50 resize-y" placeholder="Waar ben je naar op zoek?"></textarea>
              </div>

              <input type="text" name="hp_url" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0;" />

              <p id="contact-error" class="hidden text-sm text-red-600 font-medium"></p>

              <button type="submit" id="contact-submit" class="w-full bg-indigo text-white font-medium text-lg rounded-xl py-5 hover:bg-dark transition-colors duration-300 group flex items-center justify-center gap-3 disabled:opacity-60 disabled:cursor-not-allowed">
                <span id="contact-submit-label">Verstuur bericht</span>
                <svg id="contact-submit-arrow" class="w-5 h-5 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </button>
            </form>

            <div id="contact-success" class="hidden text-center py-8">
              <div class="w-16 h-16 rounded-full bg-green-100 flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-green-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
              </div>
              <h3 class="font-display text-2xl font-bold text-dark mb-2">Bedankt voor je bericht!</h3>
              <p class="text-text-secondary">We reageren zo snel mogelijk, meestal binnen een werkdag.</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  // Add base reveal animation logic specific for this page if needed
  const observeElements = () => {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', observeElements);
  } else {
    observeElements();
  }

  // Contact form submit
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement | null;
  const submitLabel = document.getElementById('contact-submit-label');
  const errorEl = document.getElementById('contact-error');
  const successEl = document.getElementById('contact-success');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form || !submitBtn) return;
    errorEl?.classList.add('hidden');

    const data = new FormData(form);
    const payload = {
      formType: 'contact',
      hp_url: String(data.get('hp_url') ?? ''),
      fields: {
        name: String(data.get('name') ?? ''),
        bedrijf: String(data.get('bedrijf') ?? ''),
        email: String(data.get('email') ?? ''),
        tel: String(data.get('tel') ?? ''),
        message: String(data.get('message') ?? ''),
      },
    };

    submitBtn.disabled = true;
    if (submitLabel) submitLabel.textContent = 'Versturen...';

    try {
      const res = await fetch('/api/send-mail', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      if (!res.ok) throw new Error('send failed');
      form.classList.add('hidden');
      successEl?.classList.remove('hidden');
    } catch (err) {
      submitBtn.disabled = false;
      if (submitLabel) submitLabel.textContent = 'Verstuur bericht';
      if (errorEl) {
        errorEl.textContent = 'Er ging iets mis bij het versturen. Probeer opnieuw of mail direct naar info@agensea.nl.';
        errorEl.classList.remove('hidden');
      }
    }
  });
</script>
