---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Cases from '../../components/Cases.astro';
import CasePopup from '../../components/CasePopup.astro';
import CTA from '../../components/CTA.astro';
---

<Layout title="Maatwerk Websites | Agensea">
  <Navbar />
  <CasePopup />
  
  <main class="bg-cream min-h-screen pt-28 md:pt-36 pb-20 overflow-hidden relative">
    <!-- Background Decor -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
      <div class="mesh-blob w-[600px] h-[600px] bg-indigo/10 top-[-10%] right-[-10%] blur-[120px]"></div>
      <div class="mesh-blob w-[500px] h-[500px] bg-violet/10 bottom-[10%] left-[-10%] blur-[100px]"></div>
    </div>

    <!-- Hero Section -->
    <section class="max-w-7xl mx-auto px-6 lg:px-10 relative z-10 mb-16 md:mb-28">
      <div class="grid lg:grid-cols-12 gap-10 lg:gap-14 items-center">
        <!-- Content -->
        <div class="lg:col-span-7">
          <div class="reveal">
            <span class="inline-flex items-center gap-2 text-xs font-bold text-indigo uppercase tracking-[0.2em] mb-6">
              <span class="w-8 h-[2px] bg-indigo"></span>
              Onze diensten
            </span>
            <h1 class="font-display font-bold text-4xl md:text-5xl lg:text-6xl leading-[1.05] tracking-tight text-dark mb-5">
              Een professionele website <span class="text-indigo">die klanten oplevert.</span>
            </h1>
            <p class="text-base md:text-lg text-text-secondary leading-relaxed mb-8 max-w-xl">
              Je zoekt een website die er strak uitziet én doet wat hij moet doen: overtuigen. Wij bouwen razendsnelle, betrouwbare websites en webshops die perfect aansluiten bij jouw bedrijf.
            </p>
            <div class="flex flex-wrap gap-4">
              <a href="/contact" class="magnetic-btn px-8 mx-0 py-4 bg-dark text-white rounded-xl font-medium hover:bg-indigo transition-colors duration-300">
                Laten we sparren
              </a>
              <a href="#aanpak" class="px-8 py-4 border border-warm-grey/50 rounded-xl font-medium text-dark hover:border-indigo transition-all duration-300">
                Ontdek onze aanpak
              </a>
            </div>
          </div>
        </div>
        <!-- Right Image/Graphic area -->        <div class="lg:col-span-5 reveal" style="transition-delay: 200ms;">
          <div class="w-full bg-white rounded-[2rem] shadow-2xl overflow-hidden border border-white relative">
            <!-- Browser Chrome -->
            <div class="h-9 bg-[#f5f3ef] flex items-center px-4 gap-1.5 border-b border-warm-grey/15">
              <div class="w-2.5 h-2.5 rounded-full bg-[#FF5F57]"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-[#FEBC2E]"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-[#28C840]"></div>
              <div class="ml-3 flex-1 h-5 bg-white/80 rounded-md border border-warm-grey/15 flex items-center px-2">
                <span id="urlText" class="text-[8px] text-text-secondary/40 font-mono transition-opacity duration-300">jouwbedrijf.nl</span>
              </div>
            </div>

            <!-- Layout Container -->
            <div id="layoutContainer" class="p-5 h-[300px] relative overflow-hidden">
              
              <!-- Layout 1: Corporate -->
              <div class="site-layout active" data-url="jouwbedrijf.nl" id="layout1">
                <div class="space-y-4">
                  <div class="mini-el flex items-center justify-between">
                    <div class="w-14 h-4 bg-dark rounded-sm"></div>
                    <div class="flex gap-3">
                      <div class="w-10 h-2.5 bg-warm-grey/30 rounded-sm"></div>
                      <div class="w-10 h-2.5 bg-warm-grey/30 rounded-sm"></div>
                      <div class="w-12 h-6 bg-indigo rounded-md"></div>
                    </div>
                  </div>
                  <div class="pt-2 pb-1">
                    <div class="mini-el w-3/4 h-4 bg-dark rounded-sm mb-2"></div>
                    <div class="mini-el w-1/2 h-4 bg-indigo/60 rounded-sm mb-3"></div>
                    <div class="mini-el w-full h-2 bg-warm-grey/20 rounded-sm mb-1"></div>
                    <div class="mini-el w-4/5 h-2 bg-warm-grey/20 rounded-sm mb-3"></div>
                    <div class="mini-el w-20 h-7 bg-indigo rounded-lg"></div>
                  </div>
                  <div class="grid grid-cols-3 gap-2">
                    <div class="mini-el bg-cream rounded-xl p-3 border border-warm-grey/15">
                      <div class="w-6 h-6 bg-indigo/10 rounded-lg mb-2"></div>
                      <div class="w-full h-1.5 bg-warm-grey/25 rounded-sm mb-1"></div>
                      <div class="w-2/3 h-1.5 bg-warm-grey/15 rounded-sm"></div>
                    </div>
                    <div class="mini-el bg-cream rounded-xl p-3 border border-warm-grey/15">
                      <div class="w-6 h-6 bg-violet/10 rounded-lg mb-2"></div>
                      <div class="w-full h-1.5 bg-warm-grey/25 rounded-sm mb-1"></div>
                      <div class="w-3/4 h-1.5 bg-warm-grey/15 rounded-sm"></div>
                    </div>
                    <div class="mini-el bg-cream rounded-xl p-3 border border-warm-grey/15">
                      <div class="w-6 h-6 bg-emerald-50 rounded-lg mb-2"></div>
                      <div class="w-full h-1.5 bg-warm-grey/25 rounded-sm mb-1"></div>
                      <div class="w-1/2 h-1.5 bg-warm-grey/15 rounded-sm"></div>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Layout 2: Webshop -->
              <div class="site-layout" data-url="jouwwebshop.nl/producten" id="layout2">
                <div class="space-y-4">
                  <div class="mini-el flex items-center justify-between">
                    <div class="w-14 h-4 bg-dark rounded-sm"></div>
                    <div class="flex gap-2 items-center">
                      <div class="w-8 h-2.5 bg-warm-grey/30 rounded-sm"></div>
                      <div class="w-8 h-2.5 bg-warm-grey/30 rounded-sm"></div>
                      <div class="w-7 h-7 bg-indigo/10 rounded-lg flex items-center justify-center">
                        <div class="w-3.5 h-3 border-2 border-indigo/50 rounded-sm"></div>
                      </div>
                    </div>
                  </div>
                  <div class="mini-el flex gap-2 items-center">
                    <div class="flex-1 h-7 bg-cream border border-warm-grey/20 rounded-lg"></div>
                    <div class="w-16 h-7 bg-indigo/10 rounded-lg"></div>
                  </div>
                  <div class="grid grid-cols-2 gap-3">
                    <div class="mini-el bg-cream rounded-xl border border-warm-grey/15 overflow-hidden">
                      <div class="w-full h-16 bg-indigo/5"></div>
                      <div class="p-2.5">
                        <div class="w-3/4 h-2 bg-warm-grey/25 rounded-sm mb-1.5"></div>
                        <div class="w-1/2 h-2 bg-indigo/40 rounded-sm font-bold"></div>
                      </div>
                    </div>
                    <div class="mini-el bg-cream rounded-xl border border-warm-grey/15 overflow-hidden">
                      <div class="w-full h-16 bg-violet/5"></div>
                      <div class="p-2.5">
                        <div class="w-2/3 h-2 bg-warm-grey/25 rounded-sm mb-1.5"></div>
                        <div class="w-1/3 h-2 bg-indigo/40 rounded-sm"></div>
                      </div>
                    </div>
                    <div class="mini-el bg-cream rounded-xl border border-warm-grey/15 overflow-hidden">
                      <div class="w-full h-16 bg-emerald-50/50"></div>
                      <div class="p-2.5">
                        <div class="w-full h-2 bg-warm-grey/25 rounded-sm mb-1.5"></div>
                        <div class="w-2/5 h-2 bg-indigo/40 rounded-sm"></div>
                      </div>
                    </div>
                    <div class="mini-el bg-cream rounded-xl border border-warm-grey/15 overflow-hidden">
                      <div class="w-full h-16 bg-amber-50/50"></div>
                      <div class="p-2.5">
                        <div class="w-1/2 h-2 bg-warm-grey/25 rounded-sm mb-1.5"></div>
                        <div class="w-1/3 h-2 bg-indigo/40 rounded-sm"></div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Layout 3: Portfolio -->
              <div class="site-layout" data-url="creatief-bureau.nl" id="layout3">
                <div class="space-y-4">
                  <div class="mini-el flex items-center justify-between">
                    <div class="w-10 h-4 bg-dark rounded-sm"></div>
                    <div class="flex gap-4">
                      <div class="w-8 h-2.5 bg-warm-grey/30 rounded-sm"></div>
                      <div class="w-8 h-2.5 bg-warm-grey/30 rounded-sm"></div>
                      <div class="w-8 h-2.5 bg-warm-grey/30 rounded-sm"></div>
                    </div>
                  </div>
                  <div class="mini-el w-full h-28 bg-gradient-to-br from-indigo/10 via-violet/10 to-indigo/5 rounded-xl relative overflow-hidden">
                    <div class="absolute bottom-3 left-3">
                      <div class="w-24 h-3 bg-white/80 rounded-sm mb-1"></div>
                      <div class="w-16 h-2 bg-white/50 rounded-sm"></div>
                    </div>
                  </div>
                  <div class="grid grid-cols-3 gap-2">
                    <div class="mini-el h-14 bg-violet/10 rounded-lg"></div>
                    <div class="mini-el h-14 bg-indigo/10 rounded-lg"></div>
                    <div class="mini-el h-14 bg-emerald-50 rounded-lg"></div>
                  </div>
                  <div class="grid grid-cols-2 gap-2">
                    <div class="mini-el h-10 bg-amber-50 rounded-lg"></div>
                    <div class="mini-el h-10 bg-violet/5 rounded-lg"></div>
                  </div>
                </div>
              </div>

              <!-- Layout 4: Dashboard / SaaS -->
              <div class="site-layout" data-url="app.jouwplatform.nl/dashboard" id="layout4">
                <div class="flex gap-3">
                  <div class="w-10 shrink-0 space-y-3 pt-1">
                    <div class="mini-el w-8 h-8 bg-dark rounded-lg"></div>
                    <div class="mini-el w-6 h-1.5 bg-warm-grey/30 rounded-sm mx-auto"></div>
                    <div class="mini-el w-6 h-1.5 bg-indigo/40 rounded-sm mx-auto"></div>
                    <div class="mini-el w-6 h-1.5 bg-warm-grey/30 rounded-sm mx-auto"></div>
                    <div class="mini-el w-6 h-1.5 bg-warm-grey/30 rounded-sm mx-auto"></div>
                  </div>
                  <div class="flex-1 space-y-3">
                    <div class="mini-el flex gap-2">
                      <div class="flex-1 bg-cream rounded-xl p-3 border border-warm-grey/15">
                        <div class="w-10 h-1.5 bg-warm-grey/20 rounded-sm mb-1.5"></div>
                        <div class="w-12 h-3 bg-indigo/50 rounded-sm"></div>
                      </div>
                      <div class="flex-1 bg-cream rounded-xl p-3 border border-warm-grey/15">
                        <div class="w-10 h-1.5 bg-warm-grey/20 rounded-sm mb-1.5"></div>
                        <div class="w-12 h-3 bg-emerald-400/50 rounded-sm"></div>
                      </div>
                      <div class="flex-1 bg-cream rounded-xl p-3 border border-warm-grey/15">
                        <div class="w-10 h-1.5 bg-warm-grey/20 rounded-sm mb-1.5"></div>
                        <div class="w-12 h-3 bg-violet/50 rounded-sm"></div>
                      </div>
                    </div>
                    <div class="mini-el bg-cream rounded-xl p-3 border border-warm-grey/15">
                      <div class="flex items-end gap-1 h-12">
                        <div class="flex-1 bg-indigo/15 rounded-t-sm" style="height:30%"></div>
                        <div class="flex-1 bg-indigo/20 rounded-t-sm" style="height:50%"></div>
                        <div class="flex-1 bg-indigo/20 rounded-t-sm" style="height:40%"></div>
                        <div class="flex-1 bg-indigo/25 rounded-t-sm" style="height:65%"></div>
                        <div class="flex-1 bg-indigo/30 rounded-t-sm" style="height:55%"></div>
                        <div class="flex-1 bg-indigo/40 rounded-t-sm" style="height:80%"></div>
                        <div class="flex-1 bg-indigo rounded-t-sm" style="height:95%"></div>
                      </div>
                    </div>
                    <div class="mini-el bg-cream rounded-xl p-2.5 border border-warm-grey/15 space-y-2">
                      <div class="flex gap-2">
                        <div class="w-1/4 h-1.5 bg-warm-grey/20 rounded-sm"></div>
                        <div class="w-1/4 h-1.5 bg-warm-grey/20 rounded-sm"></div>
                        <div class="w-1/4 h-1.5 bg-warm-grey/20 rounded-sm"></div>
                        <div class="w-1/4 h-1.5 bg-warm-grey/20 rounded-sm"></div>
                      </div>
                      <div class="flex gap-2">
                        <div class="w-1/4 h-1.5 bg-warm-grey/10 rounded-sm"></div>
                        <div class="w-1/4 h-1.5 bg-warm-grey/10 rounded-sm"></div>
                        <div class="w-1/4 h-1.5 bg-emerald-200 rounded-sm"></div>
                        <div class="w-1/4 h-1.5 bg-warm-grey/10 rounded-sm"></div>
                      </div>
                      <div class="flex gap-2">
                        <div class="w-1/4 h-1.5 bg-warm-grey/10 rounded-sm"></div>
                        <div class="w-1/4 h-1.5 bg-warm-grey/10 rounded-sm"></div>
                        <div class="w-1/4 h-1.5 bg-amber-200 rounded-sm"></div>
                        <div class="w-1/4 h-1.5 bg-warm-grey/10 rounded-sm"></div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Ads Goal Selector: "Ik wil..." -->
    <section id="doelstellingen" class="relative z-10 py-20 md:py-32">
      <div class="max-w-7xl mx-auto px-6 lg:px-10">
        
        <!-- Section Header -->
        <div class="reveal mb-12 md:mb-16">
          <span class="inline-flex items-center gap-2 text-xs font-bold text-indigo uppercase tracking-[0.2em] mb-6">
            <span class="w-8 h-[2px] bg-indigo"></span>
            Jouw behoefte
          </span>
          <h2 class="font-display text-3xl md:text-5xl lg:text-6xl font-bold leading-[1.05] text-dark max-w-3xl">
            Ik wil <span class="text-indigo" id="goal-heading-accent">...</span>
          </h2>
          <p class="mt-4 text-base md:text-lg text-text-secondary max-w-2xl leading-relaxed">
            Selecteer je behoefte en ontdek hoe we jouw digitale aanwezigheid versterken.
          </p>
        </div>

        <!-- Goal Chips -->
        <div class="reveal flex flex-wrap gap-3 mb-10 md:mb-14" id="goal-chips">
          <button class="goal-chip flex items-center gap-2 px-5 py-3 rounded-full text-sm md:text-base font-medium border border-warm-grey/40 bg-white text-dark hover:border-indigo hover:text-indigo transition-all duration-300 cursor-pointer group" data-goal="nieuwe-website">
            <svg class="w-4 h-4 text-indigo/70 group-hover:text-indigo group-[.active]:text-white transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
            Nieuwe website
          </button>
          <button class="goal-chip flex items-center gap-2 px-5 py-3 rounded-full text-sm md:text-base font-medium border border-warm-grey/40 bg-white text-dark hover:border-indigo hover:text-indigo transition-all duration-300 cursor-pointer group" data-goal="webshop">
            <svg class="w-4 h-4 text-indigo/70 group-hover:text-indigo group-[.active]:text-white transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="21" r="1"></circle><circle cx="19" cy="21" r="1"></circle><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"></path></svg>
            Een webshop
          </button>
          <button class="goal-chip flex items-center gap-2 px-5 py-3 rounded-full text-sm md:text-base font-medium border border-warm-grey/40 bg-white text-dark hover:border-indigo hover:text-indigo transition-all duration-300 cursor-pointer group" data-goal="rebranding">
            <svg class="w-4 h-4 text-indigo/70 group-hover:text-indigo group-[.active]:text-white transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12A10 10 0 0 0 15 21.54A10 10 0 0 1 15 2.46A10 10 0 0 0 2 12Z"/></svg>
            Website vernieuwen
          </button>
          <button class="goal-chip flex items-center gap-2 px-5 py-3 rounded-full text-sm md:text-base font-medium border border-warm-grey/40 bg-white text-dark hover:border-indigo hover:text-indigo transition-all duration-300 cursor-pointer group" data-goal="snelheid">
            <svg class="w-4 h-4 text-indigo/70 group-hover:text-indigo group-[.active]:text-white transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
            Snellere website
          </button>
          <button class="goal-chip flex items-center gap-2 px-5 py-3 rounded-full text-sm md:text-base font-medium border border-warm-grey/40 bg-white text-dark hover:border-indigo hover:text-indigo transition-all duration-300 cursor-pointer group" data-goal="maatwerk">
            <svg class="w-4 h-4 text-indigo/70 group-hover:text-indigo group-[.active]:text-white transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
            Maatwerk platform
          </button>
        </div>

        <!-- Content Panels -->
        <div class="relative transition-[height] duration-500 ease-out" id="goal-content-wrapper" style="height: 0px; overflow: hidden;">
          
          <!-- Nieuwe Website -->
          <div class="goal-panel absolute inset-x-0 top-0 opacity-0 translate-y-6 pointer-events-none transition-all duration-500" data-goal-panel="nieuwe-website">
            <div class="bg-white/60 backdrop-blur-2xl border border-white/80 rounded-3xl p-6 md:p-10 shadow-xl">
              <div class="grid md:grid-cols-12 gap-6 md:gap-10">
                <div class="md:col-span-7">
                  <span class="inline-block text-xs font-bold text-indigo uppercase tracking-widest mb-3">Zakelijke Website</span>
                  <h3 class="font-display text-2xl md:text-3xl font-bold text-dark mb-4">Een ijzersterke digitale eerste indruk</h3>
                  <p class="text-text-secondary text-base leading-relaxed mb-6">
                    De fundering van jouw online succes. We bouwen krachtige, razendsnelle websites die jouw merkverhaal overbrengen en bezoekers omzetten in klanten. Van corporate bedrijfsites tot overtuigende landingspagina's.
                  </p>
                  <a href="/contact" class="inline-flex items-center gap-2 px-6 py-3 bg-dark text-white rounded-xl font-medium hover:bg-indigo transition-colors duration-300 text-sm">
                    Bekijk de mogelijkheden
                    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                  </a>
                </div>
                <!-- ... -->
              </div>
            </div>
          </div>

          <!-- Webshop -->
          <div class="goal-panel absolute inset-x-0 top-0 opacity-0 translate-y-6 pointer-events-none transition-all duration-500" data-goal-panel="webshop">
            <div class="bg-white/60 backdrop-blur-2xl border border-white/80 rounded-3xl p-6 md:p-10 shadow-xl">
              <div class="grid md:grid-cols-12 gap-6 md:gap-10">
                <div class="md:col-span-7">
                  <span class="inline-block text-xs font-bold text-indigo uppercase tracking-widest mb-3">E-Commerce App</span>
                  <h3 class="font-display text-2xl md:text-3xl font-bold text-dark mb-4">Meer verkopen uit een geoptimaliseerde shop</h3>
                  <p class="text-text-secondary text-base leading-relaxed mb-6">
                    We ontwerpen webshops met focus op conversie. Minimale afleiding, een logisch bestelproces en razendsnelle laadtijden. Volledig op maat of gekoppeld aan de bekende back-end systemen. Laat je omzet exponentieel groeien.
                  </p>
                  <a href="/contact" class="inline-flex items-center gap-2 px-6 py-3 bg-dark text-white rounded-xl font-medium hover:bg-indigo transition-colors duration-300 text-sm">
                    Start jouw webshop
                    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                  </a>
                </div>
              </div>
            </div>
          </div>

          <!-- Rebranding -->
          <div class="goal-panel absolute inset-x-0 top-0 opacity-0 translate-y-6 pointer-events-none transition-all duration-500" data-goal-panel="rebranding">
            <div class="bg-white/60 backdrop-blur-2xl border border-white/80 rounded-3xl p-6 md:p-10 shadow-xl">
              <div class="grid md:grid-cols-12 gap-6 md:gap-10">
                <div class="md:col-span-7">
                  <span class="inline-block text-xs font-bold text-indigo uppercase tracking-widest mb-3">Redesign Strategie</span>
                  <h3 class="font-display text-2xl md:text-3xl font-bold text-dark mb-4">Blaas nieuw leven in jouw online huis</h3>
                  <p class="text-text-secondary text-base leading-relaxed mb-6">
                    Laat je website niet achterlopen. Een doordachte redesign zorgt voor een modern design, betere techniek en gebruiksvriendelijke structuur. We brengen de look-en-feel weer helemaal in lijn met jullie visie.
                  </p>
                  <a href="/contact" class="inline-flex items-center gap-2 px-6 py-3 bg-dark text-white rounded-xl font-medium hover:bg-indigo transition-colors duration-300 text-sm">
                    Plan een redesign sprint
                    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                  </a>
                </div>
              </div>
            </div>
          </div>

          <!-- Snelheid -->
          <div class="goal-panel absolute inset-x-0 top-0 opacity-0 translate-y-6 pointer-events-none transition-all duration-500" data-goal-panel="snelheid">
            <div class="bg-white/60 backdrop-blur-2xl border border-white/80 rounded-3xl p-6 md:p-10 shadow-xl">
              <div class="grid md:grid-cols-12 gap-6 md:gap-10">
                <div class="md:col-span-7">
                  <span class="inline-block text-xs font-bold text-indigo uppercase tracking-widest mb-3">Performance & SEO</span>
                  <h3 class="font-display text-2xl md:text-3xl font-bold text-dark mb-4">Snelle laadtijden, hogere Google posities</h3>
                  <p class="text-text-secondary text-base leading-relaxed mb-6">
                     Bezoekers haken af als je site langzaam laadt, en ook Google straft trage pagina's genadeloos af. We bouwen een moderne, lichtgewicht architectuur waarmee je website pijlsnel aanvoelt op alle apparaten. 
                  </p>
                  <a href="/contact" class="inline-flex items-center gap-2 px-6 py-3 bg-dark text-white rounded-xl font-medium hover:bg-indigo transition-colors duration-300 text-sm">
                    Optimaliseer jouw techniek
                    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                  </a>
