<section id="contact" class="pt-12 pb-24 md:pt-24 md:pb-40 px-6 lg:px-10">
  <div class="max-w-7xl mx-auto">
    <div class="reveal max-w-3xl mx-auto text-center">
      <span class="inline-flex items-center gap-2 text-xs font-medium text-text-secondary uppercase tracking-[0.2em] mb-6">
