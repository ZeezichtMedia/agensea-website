---

<!-- Top Bar: Logo & Navigation Container -->
<div
  class="fixed top-10 left-0 right-0 z-[900] pointer-events-none"
  id="nav-header"
>
  <div class="max-w-7xl mx-auto px-6 flex justify-between items-center">
    <!-- Logo -->
    <a
      href="/"
      class="font-display text-2xl font-bold tracking-tight interactive pointer-events-auto"
      id="logo-main"
    ><span class="logo-char text-dark transition-colors duration-300">a</span><span class="logo-char text-dark transition-colors duration-300">g</span><span class="logo-char text-dark transition-colors duration-300">e</span><span class="logo-char text-dark transition-colors duration-300">n</span><span class="logo-char text-dark transition-colors duration-300">s</span><span class="logo-char text-dark transition-colors duration-300">e</span><span class="logo-char text-dark transition-colors duration-300">a</span><span class="logo-char text-indigo transition-colors duration-300">.</span></a>

    <!-- Navigation Pill (v9.1: Right Aligned & Scaled Up) -->
    <div class="pointer-events-none" id="nav-wrapper">
      <nav
        class="px-4 md:px-8 py-2.5 md:py-3 bg-white/60 backdrop-blur-3xl border border-white/20 rounded-full shadow-[0_8px_32px_rgba(0,0,0,0.08)] transition-all duration-500 pointer-events-auto flex items-center gap-4 md:gap-8"
        id="main-nav"
      >
        <!-- Primary Core Links -->
        <div class="flex items-center gap-4 md:gap-10">
          <a
            href="/#diensten"
            class="hidden md:block text-xs font-bold uppercase tracking-widest text-dark/60 hover:text-indigo transition-colors interactive"
            >Diensten</a
          >
          <a
            href="/#cases"
            class="hidden md:block text-xs font-bold uppercase tracking-widest text-dark/60 hover:text-indigo transition-colors interactive"
            >Cases</a
          >

          <button
            id="nav-search-btn"
            class="flex items-center gap-2 md:gap-3 text-xs font-bold uppercase tracking-widest text-dark/60 hover:text-indigo transition-colors interactive"
          >
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="3"
            >
              <circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"
              ></path>
            </svg>
            <span class="hidden lg:inline">AI Zoeken</span>
          </button>
        </div>

        <!-- Divider -->
        <div class="w-[1px] h-5 bg-dark/10"></div>

        <!-- Menu Toggle Button -->
        <button
          id="menu-toggle"
          class="relative group flex items-center gap-3 interactive hover:text-indigo transition-colors"
        >
          <div
            class="relative w-5 h-4 flex flex-col justify-between items-center py-0.5"
          >
            <span
              class="block w-5 h-[2px] bg-current transition-all duration-300 origin-center"
              id="menu-line-1"></span>
            <span
              class="block w-5 h-[2px] bg-current transition-all duration-300 origin-center"
              id="menu-line-2"></span>
          </div>
          <span
            id="menu-text"
            class="text-xs font-bold uppercase tracking-[0.2em] text-inherit transition-colors"
            >Menu</span
          >
        </button>
      </nav>
    </div>
  </div>
</div>

<!-- Mega Menu Overlay -->
<div
  id="mega-menu"
  class="fixed inset-0 z-[899] bg-cream/95 backdrop-blur-3xl pt-24 pb-20 md:flex md:flex-col md:justify-center overflow-y-auto overflow-x-hidden opacity-0 pointer-events-none transition-all duration-700 ease-out-expo scale-110"
>
  <!-- Decorative Background Blobs -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div
      class="mesh-blob w-[800px] h-[800px] bg-indigo/10 top-[-20%] right-[-10%] blur-[120px]"
    >
    </div>
    <div
      class="mesh-blob w-[600px] h-[600px] bg-violet/10 bottom-[-20%] left-[-10%] blur-[120px]"
    >
    </div>
  </div>

  <div
    class="relative z-10 w-full max-w-7xl mx-auto px-6 lg:px-10 mt-8 md:mt-0"
  >
    <div class="grid md:grid-cols-2 gap-16 lg:gap-32 items-center">
      <!-- Diensten (Key Activities) -->
      <div>
        <span
          class="inline-flex items-center gap-2 text-xs font-bold text-indigo uppercase tracking-[0.3em] mb-6 md:mb-12"
        >
          <span class="w-10 h-[2px] bg-indigo"></span>
          Wat we doen
        </span>
        <ul class="space-y-2 md:space-y-8">
          <li>
            <a
              href="/diensten/websites"
              class="mega-link group flex items-center text-5xl md:text-7xl font-display font-bold text-dark/20 hover:text-dark transition-all duration-500 hover:tracking-tight interactive"
            >
              Websites
              <span
                class="text-indigo opacity-0 -translate-x-8 group-hover:opacity-100 group-hover:translate-x-4 transition-all duration-500 hidden md:inline-block"
                >.</span
              >
            </a>
          </li>
          <li>
            <a
              href="/diensten/marketing"
              class="mega-link group flex items-center text-5xl md:text-7xl font-display font-bold text-dark/20 hover:text-dark transition-all duration-500 hover:tracking-tight interactive"
            >
              Marketing
              <span
                class="text-indigo opacity-0 -translate-x-8 group-hover:opacity-100 group-hover:translate-x-4 transition-all duration-500 hidden md:inline-block"
                >.</span
              >
            </a>
          </li>
          <li>
            <a
              href="/diensten/software"
              class="mega-link group flex items-center text-5xl md:text-7xl font-display font-bold text-dark/20 hover:text-dark transition-all duration-500 hover:tracking-tight interactive"
            >
              Software
              <span
                class="text-indigo opacity-0 -translate-x-8 group-hover:opacity-100 group-hover:translate-x-4 transition-all duration-500 hidden md:inline-block"
                >.</span
              >
            </a>
          </li>
        </ul>
      </div>

      <!-- Bureau Info -->
      <div class="py-4 mt-8 md:mt-0">
        <div class="space-y-8 md:space-y-12">
          <div>
            <span
              class="block text-[10px] font-bold text-text-secondary uppercase tracking-[0.3em] mb-4 md:mb-6"
              >Navigatie</span
            >
            <ul class="flex flex-col sm:grid sm:grid-cols-2 gap-3 md:gap-6">
              <li>
                <a
                  href="/over-ons"
                  class="mega-link text-xl font-bold text-dark hover:text-indigo transition-colors flex items-center gap-2"
                  ><div class="w-1.5 h-1.5 rounded-full bg-indigo/30 sm:hidden">
                  </div> Over ons</a
                >
              </li>
              <li>
                <a
                  href="/#cases"
                  class="mega-link text-xl font-bold text-dark hover:text-indigo transition-colors flex items-center gap-2"
                  ><div class="w-1.5 h-1.5 rounded-full bg-indigo/30 sm:hidden">
                  </div> Portfolio</a
                >
              </li>
              <li>
                <a
                  href="/contact"
                  class="mega-link text-xl font-bold text-dark hover:text-indigo transition-colors flex items-center gap-2"
                  ><div class="w-1.5 h-1.5 rounded-full bg-indigo/30 sm:hidden">
                  </div> Contact</a
                >
              </li>
              <li>
                <a
                  href="/kennisbank"
                  class="mega-link text-xl font-bold text-dark hover:text-indigo transition-colors flex items-center gap-2"
                  ><div class="w-1.5 h-1.5 rounded-full bg-indigo/30 sm:hidden">
                  </div> Kennisbank</a
                >
              </li>
            </ul>
          </div>

          <div
            class="p-6 md:p-8 bg-white/50 rounded-2xl md:rounded-3xl border border-white inline-block w-full"
          >
            <p
              class="text-[10px] font-bold text-text-secondary uppercase tracking-[0.3em] mb-2 md:mb-4"
            >
              Direct contact
            </p>
            <a
              href="tel:+31681383601"
              class="text-xl md:text-2xl font-display font-bold text-dark hover:text-indigo transition-colors"
              >+31 6 81 38 36 01</a
            >
            <p class="mt-1 md:mt-2 text-xs md:text-sm text-text-secondary">
              Vragen? We helpen je graag verder.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  const toggleBtn = document.getElementById("menu-toggle");
  const megaMenu = document.getElementById("mega-menu");
  const menuText = document.getElementById("menu-text");
  const line1 = document.getElementById("menu-line-1");
  const line2 = document.getElementById("menu-line-2");
  const mainNav = document.getElementById("main-nav");
  const navWrapper = document.getElementById("nav-wrapper");
  const links = document.querySelectorAll(".mega-link");
  let isOpen = false;
  let lastScroll = 0;

  // ── Menu Toggle Logic ────────────────────
  function toggleMenu() {
    isOpen = !isOpen;

    if (isOpen) {
      megaMenu?.classList.remove(
        "opacity-0",
        "pointer-events-none",
        "scale-110",
      );
      megaMenu?.classList.add(
        "opacity-100",
        "pointer-events-auto",
        "scale-100",
      );

      line1?.classList.add("translate-y-[6px]", "rotate-45");
      line2?.classList.add("-translate-y-[6px]", "-rotate-45");

      if (menuText) menuText.textContent = "Dicht";
      document.body.style.overflow = "hidden";
      if (window.lenis) window.lenis.stop();
    } else {
      megaMenu?.classList.add("opacity-0", "pointer-events-none", "scale-110");
      megaMenu?.classList.remove(
        "opacity-100",
        "pointer-events-auto",
        "scale-100",
      );

      line1?.classList.remove("translate-y-[6px]", "rotate-45");
      line2?.classList.remove("-translate-y-[6px]", "-rotate-45");

      if (menuText) menuText.textContent = "Menu";
      document.body.style.overflow = "";
      if (window.lenis) window.lenis.start();
    }
  }

  toggleBtn?.addEventListener("click", toggleMenu);
  links.forEach((link) =>
    link.addEventListener("click", () => isOpen && toggleMenu()),
  );

  // AI Search Trigger
  document.getElementById("nav-search-btn")?.addEventListener("click", () => {
    window.dispatchEvent(new CustomEvent("open-ai-search"));
  });

  // ── Smart Scroll & Color Logic ────────────────────
  window.addEventListener("scroll", () => {
    const currentScroll = window.pageYOffset;
    const navHeader = document.getElementById("nav-header");
    const logo = document.getElementById("logo-main");
    const darkSections = document.querySelectorAll(".bg-dark, .bg-indigo");

    // 1. Dynamic Logo Color — per-character sampling
    if (logo) {
      const chars = logo.querySelectorAll('.logo-char');

      // Hide logo to sample what's behind each character
      logo.style.visibility = 'hidden';

      const results: { char: Element; isDark: boolean }[] = [];

      chars.forEach((char) => {
        const rect = char.getBoundingClientRect();
        const cx = Math.round(rect.left + rect.width / 2);
        const cy = Math.round(rect.top + rect.height / 2);
        const el = document.elementFromPoint(cx, cy);

        let isDark = false;
        if (el) {
          // Walk up to find the nearest element with a non-transparent bg
          let target: Element | null = el;
          while (target && target !== document.documentElement) {
            const bg = getComputedStyle(target).backgroundColor;
            const match = bg.match(/rgba?\((\d+),\s*(\d+),\s*(\d+)/);
            if (match) {
              const [, r, g, b] = match.map(Number);
              const alphaMatch = bg.match(/rgba\(\d+,\s*\d+,\s*\d+,\s*([\d.]+)/);
              const alpha = alphaMatch ? parseFloat(alphaMatch[1]) : 1;
              if (alpha > 0.1) {
                const lum = 0.299 * r + 0.587 * g + 0.114 * b;
                isDark = lum < 128;
                break;
              }
            }
            target = target.parentElement;
          }
        }
        results.push({ char, isDark });
      });

      logo.style.visibility = '';

      results.forEach(({ char, isDark }) => {
        const isDot = char.textContent === '.';
        if (isDark) {
          char.classList.remove('text-dark', 'text-indigo');
          char.classList.add('text-white');
        } else {
          char.classList.remove('text-white');
          if (isDot) {
            char.classList.add('text-indigo');
            char.classList.remove('text-dark');
          } else {
            char.classList.add('text-dark');
            char.classList.remove('text-indigo');
          }
        }
      });
    }

    // 2. Shrink/Aesthetic Change on Scroll
    if (currentScroll > 50) {
      mainNav?.classList.add("bg-white/80", "py-2", "px-5");
      mainNav?.classList.remove("bg-white/60", "py-3", "px-6");
    } else {
      mainNav?.classList.remove("bg-white/80", "py-2", "px-5");
      mainNav?.classList.add("bg-white/60", "py-3", "px-6");
    }

    lastScroll = currentScroll;
  });
</script>

<style>
  .ease-out-expo {
    transition-timing-function: cubic-bezier(0.16, 1, 0.3, 1);
  }

</style>
