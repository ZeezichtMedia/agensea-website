<style>
  .site-layout {
    position: absolute;
    inset: 0;
    padding: 20px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.6s ease;
  }
  
  .site-layout.active {
    opacity: 1;
    pointer-events: auto;
  }

  .site-layout .mini-el {
    opacity: 0;
    transform: translateY(8px);
  }

  .site-layout.active .mini-el {
    animation: buildEl 0.5s ease-out forwards;
  }

  .site-layout.active .mini-el:nth-child(1) { animation-delay: 0.1s; }
  .site-layout.active .mini-el:nth-child(2) { animation-delay: 0.3s; }
  .site-layout.active .mini-el:nth-child(3) { animation-delay: 0.5s; }
  .site-layout.active .mini-el:nth-child(4) { animation-delay: 0.7s; }
  .site-layout.active .mini-el:nth-child(5) { animation-delay: 0.9s; }

  /* Deep nested mini-els in sub-containers */
  .site-layout.active .space-y-4 > :nth-child(1) .mini-el,
  .site-layout.active .space-y-4 > .mini-el:nth-child(1),
  .site-layout.active .space-y-3 > .mini-el:nth-child(1) { animation-delay: 0.1s; }

  .site-layout.active .space-y-4 > :nth-child(2) .mini-el,
  .site-layout.active .space-y-4 > .mini-el:nth-child(2),
  .site-layout.active .space-y-3 > .mini-el:nth-child(2) { animation-delay: 0.35s; }

  .site-layout.active .space-y-4 > :nth-child(3) .mini-el,
  .site-layout.active .space-y-4 > .mini-el:nth-child(3),
  .site-layout.active .space-y-3 > .mini-el:nth-child(3) { animation-delay: 0.6s; }

  .site-layout.active .space-y-4 > :nth-child(4) .mini-el,
  .site-layout.active .space-y-4 > .mini-el:nth-child(4),
  .site-layout.active .space-y-3 > .mini-el:nth-child(4) { animation-delay: 0.85s; }

  .site-layout.active .space-y-4 > :nth-child(5) .mini-el,
  .site-layout.active .space-y-4 > .mini-el:nth-child(5),
  .site-layout.active .space-y-3 > .mini-el:nth-child(5) { animation-delay: 1.1s; }

  /* Grid children stagger */
  .site-layout.active .grid > .mini-el:nth-child(1) { animation-delay: 0.6s; }
  .site-layout.active .grid > .mini-el:nth-child(2) { animation-delay: 0.75s; }
  .site-layout.active .grid > .mini-el:nth-child(3) { animation-delay: 0.9s; }
  .site-layout.active .grid > .mini-el:nth-child(4) { animation-delay: 1.05s; }

  .site-layout.fading .mini-el {
    animation: fadeEl 0.4s ease-in forwards !important;
  }

  @keyframes buildEl {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeEl {
    from { opacity: 1; transform: translateY(0); }
    to { opacity: 0; transform: translateY(-4px); }
  }
</style>

<script>
  // ── Website Scan Tool ─────────────────────────────
  const scanBtn = document.getElementById('scan-btn') as HTMLButtonElement;
  const scanInput = document.getElementById('scan-input') as HTMLInputElement;
  const scanLoading = document.getElementById('scan-loading')!;
  const scanResults = document.getElementById('scan-results')!;
  const scanError = document.getElementById('scan-error')!;

  function setScore(id: string, ringId: string, score: number) {
    const el = document.getElementById(id)!;
    const ring = document.getElementById(ringId)!;
    el.textContent = String(score);
    // Color by score
    const color = score >= 90 ? '#22c55e' : score >= 50 ? '#f59e0b' : '#ef4444';
    el.style.color = color;
    ring.style.stroke = color;
    // Animate ring: circumference = 2π×26 ≈ 163
    const offset = 163 - (163 * score) / 100;
    ring.style.transition = 'stroke-dashoffset 1s cubic-bezier(0.22,1,0.36,1)';
    requestAnimationFrame(() => {
      ring.style.strokeDashoffset = String(offset);
    });
  }

  async function runScan() {
    let url = scanInput.value.trim();
    if (!url) return;
    if (!url.startsWith('http')) url = 'https://' + url;

    scanError.classList.add('hidden');
    scanResults.classList.add('hidden');
    scanLoading.classList.remove('hidden');
    scanBtn.disabled = true;

    // Simulated progress steps
    const steps = [
      { label: 'Verbinding maken...', progress: 10 },
      { label: 'Pagina laden...', progress: 25 },
      { label: 'Snelheid meten...', progress: 40 },
      { label: 'SEO analyseren...', progress: 55 },
      { label: 'Toegankelijkheid checken...', progress: 70 },
      { label: 'Best practices controleren...', progress: 82 },
      { label: 'Resultaten verwerken...', progress: 90 },
    ];
    const progressBar = document.getElementById('scan-progress')!;
    const stepLabel = document.getElementById('scan-step')!;
    let stepIndex = 0;
    stepLabel.textContent = steps[0].label;
    progressBar.style.width = steps[0].progress + '%';

    const stepInterval = setInterval(() => {
      stepIndex++;
      if (stepIndex < steps.length) {
        stepLabel.textContent = steps[stepIndex].label;
        progressBar.style.width = steps[stepIndex].progress + '%';
      }
    }, 3500);

    try {
      const key = import.meta.env.PUBLIC_PAGESPEED_KEY;
      const api = `https://www.googleapis.com/pagespeedonline/v5/runPagespeed?url=${encodeURIComponent(url)}&strategy=mobile&category=performance&category=seo&category=accessibility&category=best-practices&key=${key}`;
      const res = await fetch(api);
      if (!res.ok) {
        const body = await res.text();
        console.error('PageSpeed API status:', res.status, body);
        throw new Error(`API fout (${res.status})`);
      }
      const data = await res.json();

      const cats = data.lighthouseResult?.categories;
      const perf = Math.round((cats?.performance?.score ?? 0) * 100);
      const seo  = Math.round((cats?.seo?.score ?? 0) * 100);
      const acc  = Math.round((cats?.accessibility?.score ?? 0) * 100);
      const bp   = Math.round((cats?.['best-practices']?.score ?? 0) * 100);
      const avg  = Math.round((perf + seo + acc + bp) / 4);

      clearInterval(stepInterval);
      progressBar.style.width = '100%';
      stepLabel.textContent = 'Klaar!';
      await new Promise(r => setTimeout(r, 400));

      scanLoading.classList.add('hidden');
      scanResults.classList.remove('hidden');

      const label = document.getElementById('scan-url-label')!;
      label.textContent = url;

      // Reset rings first
      ['score-perf-ring','score-seo-ring','score-acc-ring','score-bp-ring'].forEach(id => {
        const r = document.getElementById(id)!;
        r.style.transition = 'none';
        r.style.strokeDashoffset = '163';
      });

      setTimeout(() => {
        setScore('score-perf', 'score-perf-ring', perf);
        setScore('score-seo',  'score-seo-ring',  seo);
        setScore('score-acc',  'score-acc-ring',  acc);
        setScore('score-bp',   'score-bp-ring',   bp);
      }, 50);

      const verdict = document.getElementById('scan-verdict')!;
      if (avg >= 90) verdict.textContent = 'Sterke website! Er is altijd ruimte voor verbetering.';
      else if (avg >= 70) verdict.textContent = 'Redelijke score, maar je laat klanten liggen.';
      else if (avg >= 50) verdict.textContent = 'Hier valt flink winst te behalen.';
      else verdict.textContent = 'Je website heeft serieuze aandacht nodig.';

      // ── AI Roast: parse failed audits ──
      const auditMap: Record<string, string> = {
        'render-blocking-resources': 'Je website wordt geblokkeerd door bestanden die eerst volledig moeten laden. Daardoor zien bezoekers even een wit scherm.',
        'uses-responsive-images': 'Je foto\'s worden op een telefoon even groot geladen als op een groot scherm. Dat maakt je site onnodig traag op mobiel.',
        'offscreen-images': 'Foto\'s die je pas ziet als je naar beneden scrollt, worden nu al meteen geladen. Dat vertraagt het eerste wat bezoekers zien.',
        'unused-css-rules': 'Er zit opmaakcode op je site die nergens voor wordt gebruikt. Dat is alsof je bagage meesleept die je nooit openmaakt.',
        'unused-javascript': 'Er wordt code geladen die niks doet op deze pagina. Dat maakt je site trager zonder reden.',
        'uses-optimized-images': 'Je foto\'s zijn groter dan nodig. Kleiner maken zonder zichtbaar kwaliteitsverlies kan je site flink versnellen.',
        'uses-text-compression': 'Je website stuurt bestanden ongecomprimeerd naar de browser. Met compressie laadt je site tot 3x sneller.',
        'uses-long-cache-ttl': 'Als iemand je site opnieuw bezoekt, moet alles opnieuw worden geladen. Met caching onthouden browsers wat ze al hebben.',
        'dom-size': 'Je pagina bevat heel veel elementen. Op een telefoon voelt dat alsof je door stroop scrollt.',
        'total-blocking-time': 'Je site reageert traag als je ergens op klikt of tikt. Bezoekers merken dat direct.',
        'largest-contentful-paint': 'Het belangrijkste onderdeel van je pagina (vaak een grote afbeelding of kop) laadt te langzaam. Bezoekers haken dan af.',
        'cumulative-layout-shift': 'Elementen op je pagina verspringen terwijl hij laadt. Bezoekers klikken daardoor soms op het verkeerde.',
        'meta-description': 'Je pagina mist een omschrijving voor Google. Daardoor bepaalt Google zelf wat er onder je link staat in de zoekresultaten.',
        'document-title': 'Je pagina heeft geen duidelijke titel. Dat is het eerste wat mensen zien in Google en in hun browsertabblad.',
        'image-alt': 'Je foto\'s hebben geen beschrijving. Daardoor kan Google ze niet vinden, en kunnen slechtzienden niet horen wat erop staat.',
        'link-text': 'Links met teksten als "klik hier" zeggen niets over waar ze naartoe gaan. Dat is verwarrend voor bezoekers en slecht voor Google.',
        'color-contrast': 'Sommige tekst is moeilijk leesbaar omdat de kleur te weinig verschilt van de achtergrond.',
        'heading-order': 'De koppen op je pagina staan niet in een logische volgorde. Dat maakt het voor Google lastiger om je pagina te begrijpen.',
        'viewport': 'Je website is niet goed ingesteld voor mobiel. Op een telefoon moet je waarschijnlijk inzoomen om tekst te lezen.',
        'is-crawlable': 'Google mag je site niet bezoeken. Dat betekent dat je onzichtbaar bent in de zoekresultaten.',
        'robots-txt': 'Een technisch bestand blokkeert Google om bepaalde pagina\'s te bekijken. Mogelijk missen er pagina\'s in de zoekresultaten.',
        'font-display': 'Je lettertypen blokkeren het laden van tekst. Bezoekers zien even helemaal geen tekst totdat het lettertype geladen is.',
        'modern-image-formats': 'Je foto\'s staan in een oud formaat. Modernere formaten zijn tot 50% kleiner bij dezelfde kwaliteit.',
        'redirects': 'Bezoekers worden doorgestuurd via omwegen voordat ze op de juiste pagina komen. Elke omweg kost extra laadtijd.',
        'server-response-time': 'Je server doet er te lang over om te reageren. Dat is vaak op te lossen met betere hosting.',
      };

      const audits = data.lighthouseResult?.audits || {};
      const failedIssues: string[] = [];
      for (const [key, desc] of Object.entries(auditMap)) {
        const audit = audits[key];
        if (audit && typeof audit.score === 'number' && audit.score < 0.5 && failedIssues.length < 4) {
          failedIssues.push(desc);
        }
      }

      const roastEl = document.getElementById('scan-roast')!;
      const issuesList = document.getElementById('scan-issues')!;
      if (failedIssues.length > 0) {
        roastEl.classList.remove('hidden');
        issuesList.innerHTML = failedIssues.map(issue =>
          `<li class="flex gap-3 items-start text-sm">
            <svg class="w-4 h-4 text-amber-500 shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 9v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span class="text-text-secondary">${issue}</span>
          </li>`
        ).join('');
      }

      // Store data for lead capture
      const scanPayload = { url, scores: { performance: perf, seo, accessibility: acc, bestPractices: bp }, issues: failedIssues };
      (window as any).__scanData = scanPayload;

      // Log elke scan (ook zonder e-mail)
      fetch('/api/scan-lead', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ ...scanPayload, email: null }),
      }).catch(() => {});

    } catch (e) {
      clearInterval(stepInterval);
      console.error('Scan error:', e);
      scanLoading.classList.add('hidden');
      scanError.textContent = e instanceof Error ? e.message : 'Scan mislukt. Controleer de URL en probeer opnieuw.';
      scanError.classList.remove('hidden');
    } finally {
      scanBtn.disabled = false;
    }
  }

  scanBtn?.addEventListener('click', runScan);
  scanInput?.addEventListener('keydown', (e) => { if (e.key === 'Enter') runScan(); });

  // ── Lead Capture ─────────────────────────────
  const sendBtn = document.getElementById('scan-send-btn');
  const emailInput = document.getElementById('scan-email') as HTMLInputElement;

  sendBtn?.addEventListener('click', async () => {
    const email = emailInput?.value.trim();
    if (!email || !email.includes('@')) {
      emailInput?.focus();
      return;
    }

    const scanData = (window as any).__scanData;
    if (!scanData) return;

    sendBtn.textContent = 'Versturen...';
    (sendBtn as HTMLButtonElement).disabled = true;

    try {
      await fetch('/api/scan-lead', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          url: scanData.url,
          email,
          scores: scanData.scores,
          issues: scanData.issues,
        }),
      });

      document.getElementById('scan-lead-form')!.classList.add('hidden');
      document.getElementById('scan-lead-success')!.classList.remove('hidden');
    } catch {
      sendBtn.textContent = 'Ontvang rapport';
      (sendBtn as HTMLButtonElement).disabled = false;
    }
  });

  const observeElements = () => {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
        }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', observeElements);
  } else {
    observeElements();
  }

  // Layout cycler
  const layouts = document.querySelectorAll('.site-layout');
  const urlInput = document.getElementById('urlInput') as HTMLInputElement | null;
  const mockLogos = document.querySelectorAll('.mock-logo');
  let current = 0;
  let userHasTyped = false;
  const DISPLAY_TIME = 4000;
  const FADE_TIME = 500;

  // When user types in the URL bar, update all mock logos
  if (urlInput) {
    const hint = document.getElementById('mockup-hint');
    const urlBar = urlInput.closest('.url-bar-hint');

    urlInput.addEventListener('input', () => {
      userHasTyped = true;
      const val = urlInput.value.replace(/^https?:\/\//, '').replace(/\.nl.*|\.com.*|\.be.*/, '').replace(/^www\./, '');
      const displayName = val || 'jouwbedrijf';
      mockLogos.forEach(logo => {
        logo.textContent = displayName;
      });
      // Hide hint after typing
      if (hint) hint.style.display = 'none';
      if (urlBar) {
        urlBar.classList.remove('border-indigo/30');
        urlBar.classList.add('border-warm-grey/15');
      }
    });

    urlInput.addEventListener('focus', () => {
      urlInput.select();
      if (hint) hint.style.display = 'none';
    });
  }

  function showLayout(index: number) {
    const layout = layouts[index];
    // Update URL bar only if user hasn't typed
    if (urlInput && layout.dataset.url && !userHasTyped) {
      urlInput.style.opacity = '0';
      setTimeout(() => {
        urlInput.value = layout.dataset.url!;
        urlInput.style.opacity = '1';
      }, 200);
    }
    // Reset animations
    layout.querySelectorAll('.mini-el').forEach(el => {
      el.style.animation = 'none';
      el.offsetHeight; // trigger reflow
      el.style.animation = '';
    });
    layout.classList.remove('fading');
    layout.classList.add('active');
  }

  function hideLayout(index) {
    const layout = layouts[index];
    layout.classList.add('fading');
    setTimeout(() => {
      layout.classList.remove('active', 'fading');
    }, FADE_TIME);
  }

  function cycle() {
    hideLayout(current);
    setTimeout(() => {
      current = (current + 1) % layouts.length;
      showLayout(current);
    }, FADE_TIME);
  }

  // Start cycling
  showLayout(0);
  setInterval(cycle, DISPLAY_TIME + FADE_TIME);

  // H1 slot machine
  const slot = document.getElementById('h1-slot');
  if (slot) {
    const items = slot.children;
    const count = items.length;
    let idx = 0;
    setInterval(() => {
      idx = (idx + 1) % count;
      slot.style.transform = `translateY(-${idx * (100 / count)}%)`;
    }, 2500);
  }
</script>

<script>
  // Goal Selector Logic for Websites
  const goalChips = document.querySelectorAll('.goal-chip');
  const goalPanels = document.querySelectorAll('.goal-panel');
  const goalWrapper = document.getElementById('goal-content-wrapper');
  const goalHeadingAccent = document.getElementById('goal-heading-accent');

  const goalLabels: Record<string, string> = {
    'nieuwe-website': 'een nieuwe website.',
    'webshop': 'een webshop starten.',
    'rebranding': 'mijn website vernieuwen.',
    'snelheid': 'een snellere website.',
  };

  let activeGoal: string | null = null;

  goalChips.forEach(chip => {
    chip.addEventListener('click', () => {
      const goalId = (chip as HTMLElement).dataset.goal;
      if (!goalId) return;

      // Toggle: clicking same chip again closes it
      if (activeGoal === goalId) {
        // Deactivate
        chip.classList.remove('bg-indigo', 'text-white', 'border-indigo', 'active');
        chip.classList.add('bg-white', 'text-dark', 'border-warm-grey/40');
        
        goalPanels.forEach(p => {
          p.classList.add('opacity-0', 'translate-y-6', 'pointer-events-none');
          p.classList.remove('opacity-100', 'translate-y-0', 'pointer-events-auto');
        });
        
        if (goalWrapper) goalWrapper.style.height = '0px';
        if (goalHeadingAccent) {
          goalHeadingAccent.style.opacity = '0';
          setTimeout(() => {
            goalHeadingAccent!.textContent = '...';
            goalHeadingAccent!.style.opacity = '1';
          }, 200);
        }
        activeGoal = null;
        return;
      }

      // Update chips
      goalChips.forEach(c => {
        c.classList.remove('bg-indigo', 'text-white', 'border-indigo', 'active');
        c.classList.add('bg-white', 'text-dark', 'border-warm-grey/40');
      });
      chip.classList.add('bg-indigo', 'text-white', 'border-indigo', 'active');
      chip.classList.remove('bg-white', 'text-dark', 'border-warm-grey/40');

      // Update heading
      if (goalHeadingAccent) {
        goalHeadingAccent.style.opacity = '0';
        setTimeout(() => {
          goalHeadingAccent!.textContent = goalLabels[goalId] || '...';
          goalHeadingAccent!.style.opacity = '1';
        }, 200);
      }

      // Show correct panel
      goalPanels.forEach(panel => {
        const panelId = (panel as HTMLElement).dataset.goalPanel;
        if (panelId === goalId) {
          panel.classList.remove('opacity-0', 'translate-y-6', 'pointer-events-none');
          panel.classList.add('opacity-100', 'translate-y-0', 'pointer-events-auto');
          
          // Animate height
          if (goalWrapper) {
            requestAnimationFrame(() => {
              goalWrapper!.style.height = panel.scrollHeight + 'px';
            });
          }

          // Scroll cards into view
          setTimeout(() => {
            const chipsEl = document.getElementById('goal-chips');
            if (chipsEl) {
              const top = chipsEl.getBoundingClientRect().top + window.scrollY - (window.innerHeight * 0.3);
              window.scrollTo({ top, behavior: 'smooth' });
            }
          }, 50);
        } else {
          panel.classList.add('opacity-0', 'translate-y-6', 'pointer-events-none');
          panel.classList.remove('opacity-100', 'translate-y-0', 'pointer-events-auto');
        }
      });

      activeGoal = goalId;
    });
  });

  // Smooth transition for heading accent
  if (goalHeadingAccent) {
    goalHeadingAccent.style.transition = 'opacity 0.2s ease-out';
  }
</script>
