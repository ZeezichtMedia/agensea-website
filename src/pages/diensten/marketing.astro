---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Cases from '../../components/Cases.astro';
import CTA from '../../components/CTA.astro';
---

<Layout title="Online Marketing & Groei | Agensea">
  <Navbar />
  
  <main class="bg-cream min-h-screen pt-32 md:pt-48 pb-20 overflow-hidden relative">
    <!-- Background Decor -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
      <div class="mesh-blob w-[600px] h-[600px] bg-indigo/10 top-[-10%] right-[-10%] blur-[120px]"></div>
      <div class="mesh-blob w-[500px] h-[500px] bg-violet/10 bottom-[10%] left-[-10%] blur-[100px]"></div>
    </div>

    <!-- Hero Section -->
    <section class="max-w-7xl mx-auto px-6 lg:px-10 relative z-10 mb-24 md:mb-40">
      <div class="grid lg:grid-cols-12 gap-12 lg:gap-20 items-center">
        <!-- Content -->
        <div class="lg:col-span-7">
          <div class="reveal">
            <span class="inline-flex items-center gap-2 text-xs font-bold text-indigo uppercase tracking-[0.2em] mb-6">
              <span class="w-8 h-[2px] bg-indigo"></span>
              Onze diensten
            </span>
            <h1 class="font-display font-bold text-5xl md:text-6xl lg:text-7xl leading-[1.05] tracking-tight text-dark mb-8">
              Meer klanten en <span class="text-indigo">online groei.</span>
            </h1>
            <p class="text-lg md:text-xl text-text-secondary leading-relaxed mb-10 max-w-xl">
              Je wilt beter gevonden worden en structureel meer aanvragen of verkopen realiseren. Met datagedreven campagnes en slimme SEO zorgen we dat jouw ideale klant je direct weet te vinden.
            </p>
            <div class="flex flex-wrap gap-4">
              <a href="/contact" class="magnetic-btn px-8 mx-0 py-4 bg-dark text-white rounded-xl font-medium hover:bg-indigo transition-colors duration-300">
                Laten we sparren
              </a>
              <a href="#werkwijze" class="px-8 py-4 border border-warm-grey/50 rounded-xl font-medium text-dark hover:border-indigo transition-all duration-300">
                Ontdek onze aanpak
              </a>
            </div>
          </div>
        </div>
        <!-- Right Graphic area: Bar Chart -->
        <div class="lg:col-span-5 reveal" style="transition-delay: 200ms;">
          <div class="w-full aspect-[4/5] bg-white rounded-[2.5rem] shadow-2xl overflow-hidden border border-white relative flex flex-col p-8">
             <span class="text-xs font-bold uppercase tracking-widest text-text-secondary/50">Jouw kanalen, onze expertise</span>
             
             <div class="mt-6 space-y-4 flex-1">
               <div class="flex items-center gap-4 p-4 rounded-2xl bg-cream border border-warm-grey/20">
                 <div class="w-10 h-10 rounded-xl bg-indigo/10 flex items-center justify-center shrink-0">
                   <svg class="w-5 h-5 text-indigo" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                 </div>
                 <div class="flex-1">
                   <p class="text-sm font-bold text-dark">Google Ads & SEO</p>
                   <p class="text-xs text-text-secondary">Vindbaar zijn als het ertoe doet</p>
                 </div>
               </div>
               <div class="flex items-center gap-4 p-4 rounded-2xl bg-cream border border-warm-grey/20">
                 <div class="w-10 h-10 rounded-xl bg-violet/10 flex items-center justify-center shrink-0">
                   <svg class="w-5 h-5 text-violet" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                 </div>
                 <div class="flex-1">
                   <p class="text-sm font-bold text-dark">Meta & Social Ads</p>
                   <p class="text-xs text-text-secondary">De juiste mensen op het juiste moment</p>
                 </div>
               </div>
               <div class="flex items-center gap-4 p-4 rounded-2xl bg-cream border border-warm-grey/20">
                 <div class="w-10 h-10 rounded-xl bg-indigo/10 flex items-center justify-center shrink-0">
                   <svg class="w-5 h-5 text-indigo" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
                 </div>
                 <div class="flex-1">
                   <p class="text-sm font-bold text-dark">LinkedIn Ads</p>
                   <p class="text-xs text-text-secondary">B2B leads die er echt toe doen</p>
                 </div>
               </div>
               <div class="flex items-center gap-4 p-4 rounded-2xl bg-cream border border-warm-grey/20">
                 <div class="w-10 h-10 rounded-xl bg-emerald-50 flex items-center justify-center shrink-0">
                   <svg class="w-5 h-5 text-emerald-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
                 </div>
                 <div class="flex-1">
                   <p class="text-sm font-bold text-dark">Conversie tracking</p>
                   <p class="text-xs text-text-secondary">Elke klik en lead inzichtelijk</p>
                 </div>
               </div>
             </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Platforms -->
    <section class="relative z-10 mb-24 md:mb-40">
      <div class="max-w-7xl mx-auto px-6 lg:px-10">
        <p class="text-center text-xs font-bold text-text-secondary/50 uppercase tracking-[0.2em] mb-8">We draaien campagnes op</p>
        <div class="flex flex-wrap justify-center items-center gap-6 md:gap-12">
          <div class="flex items-center gap-3 px-6 py-4 rounded-2xl bg-white border border-warm-grey/20">
            <svg class="w-6 h-6 text-indigo" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            <span class="font-bold text-dark text-sm">Google Ads</span>
          </div>
          <div class="flex items-center gap-3 px-6 py-4 rounded-2xl bg-white border border-warm-grey/20">
            <svg class="w-6 h-6 text-violet" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            <span class="font-bold text-dark text-sm">Meta Ads</span>
          </div>
          <div class="flex items-center gap-3 px-6 py-4 rounded-2xl bg-white border border-warm-grey/20">
            <svg class="w-6 h-6 text-indigo" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
            <span class="font-bold text-dark text-sm">LinkedIn Ads</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Werkwijze: Clean Typographic Strips -->
    <section id="werkwijze" class="relative z-10 py-24 md:py-40">
      <div class="max-w-7xl mx-auto px-6 lg:px-10">
        <div class="reveal mb-16 md:mb-24">
          <span class="inline-flex items-center gap-2 text-xs font-bold text-indigo uppercase tracking-[0.2em] mb-6">
            <span class="w-8 h-[2px] bg-indigo"></span>
            Werkwijze
          </span>
          <h2 class="font-display text-4xl md:text-6xl font-bold leading-[1.05] text-dark max-w-3xl">
            Vier stappen naar <span class="text-indigo">meetbaar resultaat.</span>
          </h2>
        </div>
      </div>

      <div class="border-t border-warm-grey">
        
        <!-- Stap 1 -->
        <div class="reveal group block border-b border-warm-grey">
          <div class="max-w-7xl mx-auto px-6 lg:px-10 py-12 md:py-16 grid md:grid-cols-12 gap-6 md:gap-12 items-start">
            <div class="md:col-span-2">
              <span class="font-display text-7xl md:text-8xl font-bold bg-gradient-to-b from-indigo to-indigo/20 bg-clip-text text-transparent leading-none select-none">01</span>
            </div>
            <div class="md:col-span-4">
              <h3 class="font-display font-bold text-2xl md:text-3xl text-dark">Kennismaking</h3>
              <span class="inline-block mt-2 text-xs font-bold text-text-secondary uppercase tracking-widest">Vrijblijvend</span>
            </div>
            <div class="md:col-span-6">
              <p class="text-text-secondary text-base md:text-lg leading-relaxed">
                We duiken in je business, ontleden samen de doelgroep en leveren een transparant voorstel op maat. Inclusief platformkeuze, budgetindicatie en een helder kostenplaatje. Geen verrassingen.
              </p>
            </div>
          </div>
        </div>

        <!-- Stap 2 -->
        <div class="reveal group block border-b border-warm-grey">
          <div class="max-w-7xl mx-auto px-6 lg:px-10 py-12 md:py-16 grid md:grid-cols-12 gap-6 md:gap-12 items-start">
            <div class="md:col-span-2">
              <span class="font-display text-7xl md:text-8xl font-bold bg-gradient-to-b from-violet to-violet/20 bg-clip-text text-transparent leading-none select-none">02</span>
            </div>
            <div class="md:col-span-4">
              <h3 class="font-display font-bold text-2xl md:text-3xl text-dark">Strategie op maat</h3>
              <span class="inline-block mt-2 text-xs font-bold text-violet bg-violet/10 px-3 py-1 rounded-full uppercase tracking-widest">Na akkoord</span>
            </div>
            <div class="md:col-span-6">
              <p class="text-text-secondary text-base md:text-lg leading-relaxed">
                Van grove schets naar scherp plan. We verfijnen de doelgroep, verdelen het budget over de juiste kanalen en zetten KPI's en meetpunten klaar. Zodat elke euro die je investeert meetbaar is.
              </p>
            </div>
          </div>
        </div>

        <!-- Stap 3 -->
        <div class="reveal group block border-b border-warm-grey">
          <div class="max-w-7xl mx-auto px-6 lg:px-10 py-12 md:py-16 grid md:grid-cols-12 gap-6 md:gap-12 items-start">
            <div class="md:col-span-2">
              <span class="font-display text-7xl md:text-8xl font-bold bg-gradient-to-b from-indigo to-indigo/20 bg-clip-text text-transparent leading-none select-none">03</span>
            </div>
            <div class="md:col-span-4">
              <h3 class="font-display font-bold text-2xl md:text-3xl text-dark">Lancering</h3>
              <span class="inline-block mt-2 text-xs font-bold text-text-secondary uppercase tracking-widest">Go live</span>
            </div>
            <div class="md:col-span-6">
              <p class="text-text-secondary text-base md:text-lg leading-relaxed">
                Accounts gekoppeld, pixels geplaatst, advertenties vormgegeven, doelgroepen ingesteld. Alles staat klaar. Dan drukken we samen op de knop en gaan jouw campagnes live.
              </p>
            </div>
          </div>
        </div>

        <!-- Stap 4 -->
        <div class="reveal group block border-b border-warm-grey bg-gradient-to-r from-indigo/[0.04] to-transparent">
          <div class="max-w-7xl mx-auto px-6 lg:px-10 py-12 md:py-16 grid md:grid-cols-12 gap-6 md:gap-12 items-start">
            <div class="md:col-span-2">
              <span class="font-display text-7xl md:text-8xl font-bold bg-gradient-to-b from-emerald-500 to-emerald-500/20 bg-clip-text text-transparent leading-none select-none">04</span>
            </div>
            <div class="md:col-span-4">
              <h3 class="font-display font-bold text-2xl md:text-3xl text-dark">Optimalisatie</h3>
              <span class="inline-flex items-center gap-2 mt-2 text-xs font-bold text-emerald-600 bg-emerald-50 px-3 py-1 rounded-full uppercase tracking-widest">
                <span class="relative flex h-1.5 w-1.5">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-emerald-500"></span>
                </span>
                Doorlopend
              </span>
            </div>
            <div class="md:col-span-6">
              <p class="text-text-secondary text-base md:text-lg leading-relaxed">
                Hier stopt het niet. We monitoren dagelijks, testen nieuwe varianten, sturen budgetten bij en rapporteren transparant. Zo halen we steeds meer uit elke euro die je investeert.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <Cases />
    <CTA />
  </main>
  
  <Footer />
</Layout>

<script>
  const observeElements = () => {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
        }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', observeElements);
  } else {
    observeElements();
  }
</script>
