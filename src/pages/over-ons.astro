---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
import TeamPopup from '../components/TeamPopup.astro';
---

<Layout title="Over Ons">
  <Navbar />
  
  <main class="pt-32 pb-16 md:pt-48 md:pb-24 overflow-hidden">
    
    <!-- Hero Section -->
    <section class="px-6 lg:px-10 max-w-7xl mx-auto mb-20 md:mb-32">
      <div class="max-w-4xl">
        <span class="reveal inline-flex items-center gap-2 text-xs font-bold text-indigo uppercase tracking-[0.2em] mb-6">
          <span class="w-8 h-[2px] bg-indigo"></span>
          Het bureau
        </span>
        <h1 class="reveal font-display text-5xl md:text-7xl lg:text-8xl font-bold leading-[1.05] text-dark mb-8 tracking-tight">
          Lokaal <span class="text-indigo">geworteld.</span> <br />
          Groots in resultaat.
        </h1>
        <p class="reveal text-lg md:text-xl text-text-secondary leading-relaxed max-w-2xl font-light delay-200">
          Agensea is ontstaan vanuit een passie voor de digitale wereld. We zijn een no-nonsense team uit Zeeland dat houdt van korte lijntjes, heldere communicatie en ijzersterk werk. Geen overbodige complexiteit, maar digitale producten die werken en er waanzinnig uitzien.
        </p>
      </div>
    </section>

    <!-- The Team Section -->
    <section class="px-6 lg:px-10 max-w-7xl mx-auto mb-20 md:mb-32">
      <div class="reveal mb-12 flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div>
          <h2 class="font-display text-4xl md:text-5xl font-bold text-dark mb-4 group cursor-pointer">
            Ontmoet de <span class="text-indigo transition-colors duration-300">gezichten.</span>
          </h2>
          <p class="text-text-secondary text-base md:text-lg max-w-xl leading-relaxed">
            Wij zijn de drijvende krachten achter Agensea. Klik op een profiel om ons beter te leren kennen.
          </p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
        
        <!-- Jorik -->
        <button 
          class="reveal flex flex-col interactive text-left group"
          onclick="window.dispatchEvent(new CustomEvent('open-team-member', { detail: { id: 'jorik' } }))"
        >
          <div class="w-full aspect-[4/5] bg-warm-grey rounded-2xl mb-6 overflow-hidden relative border border-warm-grey/50">
            <div class="w-full h-full bg-cover bg-center transition-transform duration-700 group-hover:scale-105" style="background-image: url('/team/jorik.webp');"></div>
            <!-- Overlay hover effect -->
            <div class="absolute inset-x-0 bottom-0 top-1/2 bg-gradient-to-t from-dark/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <div class="absolute bottom-6 right-6 w-12 h-12 bg-white text-dark rounded-full flex items-center justify-center opacity-0 translate-y-4 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-500 shadow-xl">
              <svg class="w-5 h-5 -rotate-45" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
          </div>
          <h3 class="font-display text-2xl font-bold text-dark group-hover:text-indigo transition-colors">Jorik Schut</h3>
          <span class="text-sm font-medium text-text-secondary mt-1">Online Marketing Specialist</span>
        </button>

        <!-- Jorian -->
        <button 
          class="reveal flex flex-col interactive text-left group delay-100"
          onclick="window.dispatchEvent(new CustomEvent('open-team-member', { detail: { id: 'jorian' } }))"
        >
          <div class="w-full aspect-[4/5] bg-warm-grey rounded-2xl mb-6 overflow-hidden relative border border-warm-grey/50">
            <div class="w-full h-full bg-cover bg-center transition-transform duration-700 group-hover:scale-105" style="background-image: url('/team/jorian.webp');"></div>
            <div class="absolute inset-x-0 bottom-0 top-1/2 bg-gradient-to-t from-dark/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <div class="absolute bottom-6 right-6 w-12 h-12 bg-white text-dark rounded-full flex items-center justify-center opacity-0 translate-y-4 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-500 shadow-xl">
              <svg class="w-5 h-5 -rotate-45" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
          </div>
          <h3 class="font-display text-2xl font-bold text-dark group-hover:text-indigo transition-colors">Jorian</h3>
          <span class="text-sm font-medium text-text-secondary mt-1">SEO & IT Specialist</span>
        </button>

        <!-- Ruben -->
        <button 
          class="reveal flex flex-col interactive text-left group delay-200"
          onclick="window.dispatchEvent(new CustomEvent('open-team-member', { detail: { id: 'ruben' } }))"
        >
          <div class="w-full aspect-[4/5] bg-warm-grey rounded-2xl mb-6 overflow-hidden relative border border-warm-grey/50">
            <div class="w-full h-full bg-cover bg-center transition-transform duration-700 group-hover:scale-105" style="background-image: url('/team/ruben.webp');"></div>
            <div class="absolute inset-x-0 bottom-0 top-1/2 bg-gradient-to-t from-dark/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <div class="absolute bottom-6 right-6 w-12 h-12 bg-white text-dark rounded-full flex items-center justify-center opacity-0 translate-y-4 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-500 shadow-xl">
              <svg class="w-5 h-5 -rotate-45" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
          </div>
          <h3 class="font-display text-2xl font-bold text-dark group-hover:text-indigo transition-colors">Ruben</h3>
          <span class="text-sm font-medium text-text-secondary mt-1">Account Manager & Verbinder</span>
        </button>

      </div>
    </section>

    <!-- Freelancers / Flex-schil -->
    <section class="px-6 lg:px-10 max-w-7xl mx-auto mb-10">
      <div class="bg-indigo text-white rounded-[3rem] p-10 md:p-16 lg:p-20 relative overflow-hidden">
        
        <!-- Abstract background elements -->
        <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-white/5 rounded-full blur-[100px] translate-x-1/3 -translate-y-1/3"></div>
        <div class="absolute -bottom-20 -left-20 w-[400px] h-[400px] bg-[#4353FF]/50 rounded-full blur-[80px]"></div>

        <div class="relative z-10 grid md:grid-cols-2 gap-12 items-center">
          <div class="reveal">
            <span class="inline-flex items-center gap-2 text-xs font-bold text-white/70 uppercase tracking-[0.2em] mb-4">
              <span class="w-6 h-[2px] bg-white/50"></span>
              De flexibele schil
            </span>
            <h2 class="font-display text-4xl md:text-5xl lg:text-5xl font-bold leading-[1.1] mb-6">
              Vaste <span class="text-white/60">freelancers.</span>
            </h2>
            <p class="text-white/80 text-lg leading-relaxed mb-8 max-w-md">
              Afhankelijk van de grootte en complexiteit van jouw project werken we samen met onze vertrouwde flex-schil. Van copywriters tot 3D-animators en gespecialiseerde ontwikkelaars. Zo blijft Agensea wendbaar, betaalbaar én leveren we altijd de hoogste kwaliteit door precies de juiste experts in te schakelen.
            </p>
            <div class="flex items-center gap-4">
              <div class="flex -space-x-3">
                <div class="w-10 h-10 rounded-full border-2 border-indigo bg-white/20 backdrop-blur flex items-center justify-center">
                   <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                </div>
                <div class="w-10 h-10 rounded-full border-2 border-indigo bg-white/20 backdrop-blur flex items-center justify-center">
                   <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15.05 5A5 5 0 0 1 19 8.95M15.05 1A9 9 0 0 1 23 8.94m-1 7.98v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                </div>
                <div class="w-10 h-10 rounded-full border-2 border-indigo bg-white/20 backdrop-blur flex items-center justify-center">
                   <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="M2 2l7.586 7.586"/><circle cx="11" cy="11" r="2"/></svg>
                </div>
              </div>
              <span class="text-sm font-medium text-white/90">+ Netwerk van specialisten</span>
            </div>
          </div>
          
          <div class="reveal delay-200 hidden md:flex justify-end relative">
            <!-- Decorative Badge or Shape -->
            <div class="w-64 h-64 border border-white/20 rounded-[2rem] flex flex-col items-center justify-center p-8 text-center backdrop-blur-sm bg-white/5 rotate-3 hover:rotate-0 transition-transform duration-500">
              <svg class="w-12 h-12 text-white/50 mb-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
              </svg>
              <h3 class="font-display text-xl font-bold mb-2">Schaalbare Expertise</h3>
              <p class="text-xs text-white/70">Wij groeien dynamisch mee met de behoeftes van jouw onderneming.</p>
            </div>
          </div>
        </div>

      </div>
    </section>

    <CTA />
  </main>

  <Footer />
  <TeamPopup />
</Layout>
