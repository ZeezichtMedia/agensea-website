---
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import CTA from "../../components/CTA.astro";
import AuthorBox from "../../components/blog/AuthorBox.astro";
import ReaderSidebar from "../../components/ReaderSidebar.astro";
import { authorsById } from "../../data/authors";

export async function getStaticPaths() {
    const blogEntries = await getCollection("blog");
    return blogEntries.map((entry: CollectionEntry<"blog">) => ({
        params: { slug: entry.id },
        props: { entry },
    }));
}

interface Props {
    entry: CollectionEntry<"blog">;
}

const { entry } = Astro.props as Props;
const { Content, headings } = await render(entry);

// Resolve author-ID naar volledig Author object via centrale data file.
// Frontmatter bevat alleen `author: jorian` (id), niet een inline object.
const author = entry.data.author ? authorsById[entry.data.author] : undefined;

// Reading time
const wordCount = entry.body ? entry.body.split(/\s+/).length : 0;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));

// TOC items for ReaderSidebar (h1-h3 only)
const tocItems = headings
    .filter((h: { depth: number }) => h.depth <= 3)
    .map((h: { slug: string; text: string; depth: number }) => ({
        slug: h.slug,
        label: h.text,
        depth: h.depth as 1 | 2 | 3,
    }));

// Schema.org BlogPosting JSON-LD — bevat author + image als beschikbaar.
const schema = {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: entry.data.title,
    description: entry.data.description,
    inLanguage: "nl-NL",
    datePublished: entry.data.pubDate.toISOString(),
    ...(entry.data.updatedDate && {
        dateModified: entry.data.updatedDate.toISOString(),
    }),
    ...(entry.data.image && { image: entry.data.image.src }),
    url: `https://agensea.nl/kennisbank/${entry.id}/`,
    isPartOf: { "@id": "https://agensea.nl/#website" },
    publisher: {
        "@type": "Organization",
        name: "Agensea",
        url: "https://agensea.nl",
        logo: {
            "@type": "ImageObject",
            url: "https://agensea.nl/brand/agensea-logo-512.png",
        },
    },
    ...(author && {
        author: {
            "@type": "Person",
            name: author.name,
            description: author.bio,
            image: `https://agensea.nl${author.avatar}`,
            ...(author.linkedin && { sameAs: [author.linkedin] }),
        },
    }),
};

// BreadcrumbList voor deze blogpost.
const breadcrumbSchema = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
        { "@type": "ListItem", position: 1, name: "Home", item: "https://agensea.nl/" },
        { "@type": "ListItem", position: 2, name: "Kennisbank", item: "https://agensea.nl/kennisbank/" },
        { "@type": "ListItem", position: 3, name: entry.data.title, item: `https://agensea.nl/kennisbank/${entry.id}/` },
    ],
};
---

<Layout
    title={entry.data.title}
    description={entry.data.description}
    seoTitle={entry.data.seo?.metaTitle}
    seoDescription={entry.data.seo?.metaDescription}
    ogImage={entry.data.image?.src}
>
    <!-- JSON-LD Structured Data -->
    <script
        slot="head"
        type="application/ld+json"
        set:html={JSON.stringify(schema)}
    />
    <script
        slot="head"
        type="application/ld+json"
        set:html={JSON.stringify(breadcrumbSchema)}
    />

    <Navbar />

    <main id="main-content" class="min-h-screen pt-36 md:pt-44 pb-20">
        <!-- Hero Header -->
        <header class="max-w-4xl mx-auto px-6 mb-16 md:mb-24">
            <div class="mb-8">
                <a
                    href="/kennisbank"
                    class="group inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-dark/40 hover:text-indigo transition-colors"
                >
                    <svg
                        width="16"
                        height="16"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        class="group-hover:-translate-x-1 transition-transform"
                    >
                        <path d="m15 18-6-6 6-6"></path>
                    </svg>
                    Alle inzichten
                </a>
            </div>

            <div class="flex flex-wrap items-center gap-4 mb-8">
                <time
                    datetime={entry.data.pubDate.toISOString()}
                    class="text-xs font-bold text-indigo uppercase tracking-[0.2em]"
                >
                    {
                        entry.data.pubDate.toLocaleDateString("nl-NL", {
                            year: "numeric",
                            month: "long",
                            day: "numeric",
                        })
                    }
                </time>
                <span class="w-1 h-1 rounded-full bg-dark/20"></span>
                <span
                    class="text-xs font-bold text-dark/40 uppercase tracking-[0.2em]"
                    >{readingTime} min leestijd</span
                >
                {
                    entry.data.updatedDate &&
                        entry.data.updatedDate > entry.data.pubDate && (
                            <>
                                <span class="w-1 h-1 rounded-full bg-dark/20" />
                                <span class="text-xs font-bold text-dark/40 uppercase tracking-[0.2em]">
                                    Bijgewerkt{" "}
                                    {entry.data.updatedDate.toLocaleDateString(
                                        "nl-NL",
                                        {
                                            year: "numeric",
                                            month: "long",
                                            day: "numeric",
                                        },
                                    )}
                                </span>
                            </>
                        )
                }
            </div>

            {
                entry.data.category && (
                    <span class="inline-block text-[10px] font-bold text-indigo uppercase tracking-[0.3em] bg-indigo/5 px-3 py-1 rounded-full mb-6">
                        {entry.data.category}
                    </span>
                )
            }

            <h1
                class="text-4xl md:text-6xl lg:text-7xl font-display font-bold text-dark tracking-tight leading-[1.08] mb-6"
            >
                {entry.data.title}
            </h1>

            <p
                class="text-xl md:text-2xl text-dark/60 font-sans leading-relaxed max-w-3xl"
            >
                {entry.data.excerpt || entry.data.description}
            </p>

            <div
                class="mt-10 h-px bg-gradient-to-r from-indigo/30 via-warm-grey to-transparent"
            >
            </div>
        </header>

        <!-- Content Grid: Article + Sidebar TOC -->
        <div class="max-w-7xl mx-auto px-6">
            <div class="grid lg:grid-cols-[1fr_260px] gap-16 xl:gap-24">
                <!-- Article Content -->
                <article id="article-body" class="min-w-0">
                    <div class="markdown-body max-w-3xl">
                        <Content />
                    </div>

                    <!-- Tags -->
                    {
                        entry.data.tags && entry.data.tags.length > 0 && (
                            <div class="max-w-3xl mt-16 pt-8 border-t border-warm-grey">
                                <p class="text-[10px] font-bold text-dark/40 uppercase tracking-[0.3em] mb-4">
                                    Tags
                                </p>
                                <div class="flex flex-wrap gap-2">
                                    {entry.data.tags.map((tag) => (
                                        <span class="px-3 py-1.5 bg-dark/[0.03] text-dark/60 text-xs font-medium rounded-full border border-dark/5 hover:border-indigo/30 hover:text-indigo transition-colors">
                                            {tag}
                                        </span>
                                    ))}
                                </div>
                            </div>
                        )
                    }

                    <!-- Author Box (EEAT) -->
                    {
                        author && (
                            <AuthorBox
                                name={author.name}
                                bio={author.bio}
                                avatar={author.avatar}
                                credentials={author.credentials}
                            />
                        )
                    }
                </article>

                <!-- Sticky Sidebar (shared component) -->
                <aside class="hidden lg:block">
                    <ReaderSidebar items={tocItems} />
                </aside>
            </div>
        </div>
    </main>

    <div class="mt-20">
        <CTA />
    </div>
    <Footer />
</Layout>

<script>
    // Wrap alle markdown-tables in een horizontaal scrollbare container,
    // zodat ze op smalle viewports niet uit de layout drukken.
    function wrapTables() {
        const tables = document.querySelectorAll(".markdown-body table");
        tables.forEach((table) => {
            const parent = table.parentElement;
            if (!parent || parent.classList.contains("table-scroll-wrapper")) return;
            const wrapper = document.createElement("div");
            wrapper.className = "table-scroll-wrapper";
            parent.insertBefore(wrapper, table);
            wrapper.appendChild(table);
        });
    }
    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", wrapTables);
    } else {
        wrapTables();
    }
</script>

<style is:global>
    @reference "../../styles/global.css";

    .markdown-body h1 {
        @apply text-3xl md:text-4xl font-display font-bold text-dark tracking-tight mb-6 mt-20 relative;
    }
    .markdown-body h1::before {
        content: "";
        @apply block w-10 h-[3px] bg-indigo mb-4 rounded-full;
    }
    .markdown-body h2 {
        @apply text-2xl md:text-3xl font-display font-bold text-dark tracking-tight mb-5 mt-16;
    }
    .markdown-body h3 {
        @apply text-xl md:text-2xl font-display font-bold text-dark tracking-tight mb-4 mt-12;
    }
    .markdown-body p {
        @apply text-lg text-dark/75 font-sans leading-[1.85] mb-7;
    }
    .markdown-body > p:first-of-type {
        @apply text-xl text-dark/85 leading-[1.75];
    }
    .markdown-body ul {
        @apply mb-8 text-lg text-dark/75 space-y-3 pl-0 list-none;
    }
    .markdown-body ul li {
        @apply relative pl-6;
    }
    .markdown-body ul li::before {
        content: "";
        @apply absolute left-0 top-[0.65em] w-2 h-2 rounded-full bg-indigo/40;
    }
    .markdown-body ol {
        @apply list-decimal list-outside ml-6 mb-8 text-lg text-dark/75 space-y-3;
    }
    .markdown-body strong {
        @apply font-bold text-dark;
    }
    .markdown-body em {
        @apply italic text-dark/65;
    }
    .markdown-body a {
        @apply text-indigo font-medium underline underline-offset-4 decoration-indigo/30 decoration-2 hover:decoration-indigo transition-all;
    }
    .markdown-body blockquote {
        @apply relative border-l-[3px] border-indigo pl-6 py-2 my-10 bg-indigo/[0.03] rounded-r-xl;
    }
    .markdown-body blockquote p {
        @apply text-dark/70 italic text-lg;
    }
    .markdown-body code {
        @apply bg-dark/5 text-dark px-1.5 py-0.5 rounded-md text-[0.9em] font-mono;
    }
    .markdown-body pre {
        @apply bg-dark rounded-2xl p-6 overflow-x-auto mb-8 mt-6;
    }
    .markdown-body pre code {
        @apply bg-transparent text-cream p-0;
    }
    .markdown-body hr {
        @apply border-none h-px bg-gradient-to-r from-transparent via-warm-grey to-transparent my-16;
    }
    .markdown-body img {
        @apply rounded-2xl my-8 shadow-lg;
    }
    /* Tables — responsive: wrap in overflow container via JS, smaller type on mobile */
    .markdown-body .table-scroll-wrapper {
        @apply w-full mb-8 overflow-x-auto rounded-xl border border-warm-grey;
        -webkit-overflow-scrolling: touch;
    }
    .markdown-body .table-scroll-wrapper::-webkit-scrollbar {
        height: 6px;
    }
    .markdown-body .table-scroll-wrapper::-webkit-scrollbar-thumb {
        @apply bg-warm-grey rounded-full;
    }
    .markdown-body table {
        @apply w-full text-sm md:text-base mb-0;
        min-width: 100%;
    }
    .markdown-body .table-scroll-wrapper table {
        @apply mb-0;
    }
    /* Fallback voor tables die (nog) niet gewrapt zijn */
    .markdown-body > table {
        @apply mb-8;
        display: block;
        overflow-x: auto;
    }
    .markdown-body th {
        @apply text-left font-bold text-dark py-3 px-4 border-b-2 border-indigo/20 whitespace-nowrap;
    }
    .markdown-body td {
        @apply py-3 px-4 border-b border-warm-grey text-dark/75 align-top;
    }
    .markdown-body th:first-child,
    .markdown-body td:first-child {
        @apply pl-4;
    }
</style>
