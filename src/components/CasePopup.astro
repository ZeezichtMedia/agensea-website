---
---

<div 
  id="case-modal" 
  class="fixed inset-0 z-[1000] flex items-center justify-center p-6 md:p-12 opacity-0 pointer-events-none transition-all duration-500"
>
  <!-- Backdrop -->
  <div class="absolute inset-0 bg-dark/20 backdrop-blur-md" id="case-modal-close"></div>
  
  <!-- Modal Container -->
  <div class="relative bg-white rounded-3xl w-full max-w-5xl max-h-[85vh] overflow-hidden shadow-2xl translate-y-8 transition-all duration-500 flex flex-col md:flex-row">
    
    <!-- Left: Image/Visual -->
    <div class="w-full md:w-1/2 h-64 md:h-auto bg-warm-grey relative overflow-hidden">
      <img id="case-image" src="" alt="" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-t from-dark/40 to-transparent md:bg-gradient-to-r"></div>
    </div>
    
    <!-- Right: Content -->
    <div class="w-full md:w-1/2 p-8 md:p-12 overflow-y-auto">
      <button 
        id="case-modal-close-btn"
        class="absolute top-6 right-6 w-10 h-10 rounded-full bg-cream hover:bg-warm-grey flex items-center justify-center transition-colors interactive"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M18 6L6 18M6 6l12 12" />
        </svg>
      </button>

      <div class="mt-4">
        <span id="case-category" class="text-xs font-bold uppercase tracking-widest text-indigo mb-4 block"></span>
        <h2 id="case-title" class="font-display text-3xl md:text-5xl font-bold leading-tight mb-6"></h2>
        <div id="case-description" class="text-text-secondary text-lg leading-relaxed space-y-4"></div>
        
      </div>
    </div>
  </div>
</div>

<script>
  const cases = {
    arieke: {
      category: "LinkedIn Campagne",
      title: "Arieke van Liere",
      description: `
        <h4 class="font-bold text-dark mb-2">Vraagstuk</h4>
        <p class="mb-6">Arieke wilde haar nieuwe showreel krachtig onder de aandacht brengen bij een specifieke, zakelijke doelgroep via LinkedIn, met als hoofddoel het genereren van maximale engagement en concrete aanvragen voor haar rol als dagvoorzitter.</p>
        
        <h4 class="font-bold text-dark mb-2">Wat Agensea heeft gedaan</h4>
        <p class="mb-6">We ontwikkelden een gerichte, data-gedreven LinkedIn-strategie. Van het scherpstellen van de doelgroep tot de daadwerkelijke uitrol, planning en optimalisatie van de campagne we begeleidden het volledige traject van A tot Z.</p>
        
        <h4 class="font-bold text-dark mb-6">Resultaat</h4>
        
        <div class="p-4 rounded-xl border bg-warm-grey/30 border-warm-grey/50">
          <div class="flex items-start gap-3">
            <svg class="w-4 h-4 mt-0.5 shrink-0 text-indigo/40" viewBox="0 0 24 24" fill="currentColor"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983z"/></svg>
            <div>
              <p class="text-sm leading-relaxed text-text-secondary/50 italic">Review binnenkort beschikbaar.</p>
              <span class="block mt-2 text-[10px] font-bold uppercase tracking-widest text-text-secondary/60">Arieke van Liere</span>
            </div>
          </div>
        </div>
      `,
      image: "/portfolio/arieke-van-liere.png",
    },
    adrz: {
      category: "Imago Campagne",
      title: "Adrz",
      description: `
        <h4 class="font-bold text-dark mb-2">Vraagstuk</h4>
        <p class="mb-6">Adrz had sterke nieuwe imagocontent gecreëerd en zocht een strategische partner om deze visuele verhalen lokaal (binnen heel Zeeland) zo krachtig en efficiënt mogelijk digitaal te verspreiden.</p>
        
        <h4 class="font-bold text-dark mb-2">Wat Agensea heeft gedaan</h4>
        <p class="mb-6">We ontwierpen een cross-mediale imagocampagne, slim en doelgroepgericht over YouTube en Meta (Facebook/Instagram). Door data-gedreven targeting zorgden we dat de content precies landde bij de juiste Zeeuwen.</p>
        
        <h4 class="font-bold text-dark mb-6">Resultaat</h4>

        <div class="p-4 rounded-xl border bg-warm-grey/30 border-warm-grey/50">
          <div class="flex items-start gap-3">
            <svg class="w-4 h-4 mt-0.5 shrink-0 text-indigo/40" viewBox="0 0 24 24" fill="currentColor"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983z"/></svg>
            <div>
              <p class="text-sm leading-relaxed text-text-secondary/50 italic">Review binnenkort beschikbaar.</p>
              <span class="block mt-2 text-[10px] font-bold uppercase tracking-widest text-text-secondary/60">Adrz</span>
            </div>
          </div>
        </div>
      `,
      image: "/portfolio/adrz.png",
    },
    rd: {
      category: "Website",
      title: "Bouwgroep R&D",
      description: `
        <h4 class="font-bold text-dark mb-2">Vraagstuk</h4>
        <p class="mb-6">De toenmalige website van Bouwgroep R&D sloot qua uitstraling niet meer aan bij hun professionaliteit en actuele aanbod. Ze zochten een online visueel visitekaartje dat makkelijk navigeert en commercieel klopt.</p>
        
        <h4 class="font-bold text-dark mb-2">Wat Agensea heeft gedaan</h4>
        <p class="mb-6">We ontwierpen en bouwden een compleet nieuwe, strategisch doordachte website. De nadruk lag op logische UX (User Experience) en een fris, modern design dat hun unieke kwaliteiten direct vertaalt naar de bezoeker.</p>
        
        <h4 class="font-bold text-dark mb-6">Resultaat</h4>

        <div class="p-4 rounded-xl border bg-indigo/5 border-indigo/10">
          <div class="flex items-start gap-3">
            <svg class="w-4 h-4 mt-0.5 shrink-0 text-indigo/40" viewBox="0 0 24 24" fill="currentColor"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983z"/></svg>
            <div>
              <p class="text-sm leading-relaxed text-dark">Ik ben heel erg blij met het eindresultaat. Het hele traject verliep soepel en professioneel, van het eerste gesprek tot de oplevering. De website sluit nu perfect aan bij wie we zijn als bedrijf.</p>
              <span class="block mt-2 text-[10px] font-bold uppercase tracking-widest text-text-secondary/60">Mischa, Bouwgroep R&D</span>
            </div>
          </div>
        </div>
      `,
      image: "/portfolio/bouwgroep-rd.png",
    },
    bb: {
      category: "Website",
      title: "B&B Voorste Eng",
      description: `
        <h4 class="font-bold text-dark mb-2">Vraagstuk</h4>
        <p class="mb-6">B&B Voorste Eng was voor hun reserveringen volledig afhankelijk van dure, externe boekingsplatforms en miste nog de regie en uitstraling van een volwaardige eigen website.</p>
        
        <h4 class="font-bold text-dark mb-2">Wat Agensea heeft gedaan</h4>
        <p class="mb-6">We hebben de fundamenten gelegd voor hun online eigenwaarde: een heldere en sfeervolle maatwerk website. Hierdoor verlaagden we direct de drempel voor potentiële gasten om informatie te vinden en zonder tussenpartij actie te ondernemen.</p>
        
        <h4 class="font-bold text-dark mb-6">Resultaat</h4>

        <div class="p-4 rounded-xl border bg-warm-grey/30 border-warm-grey/50">
          <div class="flex items-start gap-3">
            <svg class="w-4 h-4 mt-0.5 shrink-0 text-indigo/40" viewBox="0 0 24 24" fill="currentColor"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983z"/></svg>
            <div>
              <p class="text-sm leading-relaxed text-text-secondary/50 italic">Review binnenkort beschikbaar.</p>
              <span class="block mt-2 text-[10px] font-bold uppercase tracking-widest text-text-secondary/60">B&B Voorste Eng</span>
            </div>
          </div>
        </div>
      `,
      image: "/portfolio/bb-voorste-eng.png",
    }
  };

  const modal = document.getElementById('case-modal');
  const closeTriggers = [
    document.getElementById('case-modal-close'),
    document.getElementById('case-modal-close-btn')
  ];

  function openCase(id) {
    const caseData = cases[id];
    if (!caseData) return;

    // Update content
    document.getElementById('case-title').textContent = caseData.title;
    document.getElementById('case-category').textContent = caseData.category;
    document.getElementById('case-description').innerHTML = caseData.description;
    document.getElementById('case-image').src = caseData.image;

    // Show modal
    modal.classList.remove('opacity-0', 'pointer-events-none');
    modal.querySelector('.relative').classList.remove('translate-y-8');
    document.body.style.overflow = 'hidden';
  }

  function closeCase() {
    modal.classList.add('opacity-0', 'pointer-events-none');
    modal.querySelector('.relative').classList.add('translate-y-8');
    document.body.style.overflow = '';
  }

  // Event Listeners
  window.addEventListener('open-case', (e: any) => openCase(e.detail.id));
  closeTriggers.forEach(t => t?.addEventListener('click', closeCase));
</script>
