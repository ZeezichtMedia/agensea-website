---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Gratis Website Demo Aanvragen" description="Vraag nu een gratis, werkende interface demo aan voor je nieuwe website of applicatie. Zonder verplichtingen, maar mét resultaat.">
  
  <!-- Minimal Header (No Navigation for conversion maximation) -->
  <header class="absolute top-0 left-0 right-0 z-50 p-6 md:p-10">
    <div class="max-w-7xl mx-auto flex justify-between items-center">
      <a href="/" class="font-display text-2xl font-bold tracking-tight text-dark transition-colors interactive">
        agensea<span class="text-indigo">.</span>
      </a>
      <a href="/" class="text-xs font-bold uppercase tracking-widest text-dark/40 hover:text-indigo transition-colors flex items-center gap-2">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Terug naar site
      </a>
    </div>
  </header>

  <main id="main-content" class="relative min-h-screen flex items-center pt-32 pb-20 overflow-hidden bg-cream">
    <!-- Abstract Background -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
      <div class="absolute w-[800px] h-[800px] bg-indigo/10 blur-[120px] rounded-full top-[-10%] right-[-10%] animate-pulse" style="animation-duration: 10s;"></div>
      <div class="absolute w-[600px] h-[600px] bg-violet/10 blur-[100px] rounded-full bottom-[-10%] left-[-10%] animate-pulse" style="animation-duration: 15s; animation-delay: -5s;"></div>
    </div>

    <div class="relative z-10 w-full max-w-7xl mx-auto px-6 lg:px-10">
      <div class="grid lg:grid-cols-12 gap-16 lg:gap-24 items-center">
        
        <!-- Left: Value Proposition -->
        <div class="lg:col-span-6 reveal">
          <span class="inline-flex items-center gap-3 text-xs font-bold uppercase tracking-[0.2em] text-indigo mb-6">
            <span class="w-8 h-[2px] bg-indigo"></span>
            No strings attached
          </span>
          <h1 class="font-display font-bold text-5xl md:text-[4rem] lg:text-[4.5rem] leading-[1.05] tracking-tight text-dark mb-8">
            Laat ons bewijzen<br />wat we <span class="text-indigo">kunnen.</span>
          </h1>
          <p class="text-lg md:text-xl text-text-secondary leading-relaxed mb-12">
            Geen eindeloze verkooppraatjes of vage beloftes. Vul hieronder in wat je doelen zijn, en wij bouwen een gratis, interactief concept voor je nieuwe website of applicatie. Jij oordeelt pas achteraf.
          </p>

          <!-- 3 Steps -->
          <ul class="space-y-8 mb-16 relative before:absolute before:inset-y-0 before:left-6 before:w-[2px] before:bg-indigo/10">
            <li class="relative flex gap-6 items-start">
              <div class="w-12 h-12 rounded-full bg-white border-2 border-indigo flex items-center justify-center shrink-0 shadow-lg relative z-10 text-indigo font-bold font-display text-lg">1</div>
              <div class="pt-2">
                <h3 class="font-bold text-lg text-dark mb-1">Jij deelt je doelen</h3>
                <p class="text-text-secondary/80 leading-relaxed text-sm">Vul simpelweg het intakeformulier naast deze tekst in met een korte briefing rond je uitdaging.</p>
              </div>
            </li>
            <li class="relative flex gap-6 items-start">
              <div class="w-12 h-12 rounded-full bg-white border-2 border-indigo/30 flex items-center justify-center shrink-0 shadow-lg relative z-10 text-indigo/60 font-bold font-display text-lg">2</div>
              <div class="pt-2">
                <h3 class="font-bold text-lg text-dark mb-1">Wij ontwerpen een demo</h3>
                <p class="text-text-secondary/80 leading-relaxed text-sm">We bouwen op eigen kosten een kraakhelder, visueel klikbaar concept gericht op pure conversie.</p>
              </div>
            </li>
            <li class="relative flex gap-6 items-start">
              <div class="w-12 h-12 rounded-full bg-white border-2 border-indigo/30 flex items-center justify-center shrink-0 shadow-lg relative z-10 text-indigo/60 font-bold font-display text-lg">3</div>
              <div class="pt-2">
                <h3 class="font-bold text-lg text-dark mb-1">Eerlijk advies & Overdracht</h3>
                <p class="text-text-secondary/80 leading-relaxed text-sm">We lopen in 30 minuten digitaal samen door het prototype. Helemaal gratis, geen enkele verplichting.</p>
              </div>
            </li>
          </ul>

          <!-- Trust Logos (Portfolio focus) -->
          <div>
            <p class="text-[10px] font-bold uppercase tracking-widest text-text-secondary/50 mb-4">Bekijk onze eerdere website projecten</p>
            <div class="flex items-center gap-4">
              <a href="/#cases" class="w-16 h-10 bg-cover bg-center rounded-md shadow-sm border border-dark/10 hover:scale-105 transition-transform cursor-pointer" style="background-image: url('/portfolio/minicamping-boogaard.webp');" title="Minicamping Boogaard"></a>
              <a href="/#cases" class="w-16 h-10 bg-cover bg-[center_top] rounded-md shadow-sm border border-dark/10 hover:scale-105 transition-transform cursor-pointer" style="background-image: url('/portfolio/assieraden-specialist.webp');" title="Assieraden Specialist"></a>
              <a href="/#cases" class="w-16 h-10 bg-cover bg-[center_top] rounded-md shadow-sm border border-dark/10 hover:scale-105 transition-transform cursor-pointer" style="background-image: url('/portfolio/bb-voorste-eng.png');" title="B&B Voorste Eng"></a>
            </div>
          </div>
        </div>

        <!-- Right: The Form Card -->
        <div class="lg:col-span-6 relative reveal" style="transition-delay: 200ms;">
          <div class="w-full bg-white/60 backdrop-blur-2xl rounded-[2.5rem] p-8 md:p-12 border border-white shadow-[0_20px_60px_-15px_rgba(0,0,0,0.05)] relative overflow-hidden">
            
            <!-- Internal Glow -->
            <div class="absolute -top-32 -right-32 w-64 h-64 bg-indigo/10 rounded-full blur-[60px]"></div>

            <div class="relative z-10">
              <h2 class="font-display text-3xl font-bold text-dark mb-2">Claim je gratis demo</h2>
              <p class="text-text-secondary text-sm mb-8">Laat je gegevens achter en we plannen direct een moment in.</p>

              <form id="demo-form" method="POST" class="space-y-5">
                
                <div class="grid md:grid-cols-2 gap-5">
                  <div class="space-y-2">
                    <label for="firstName" class="block text-xs font-bold uppercase tracking-widest text-dark/60">Voornaam</label>
                    <input type="text" id="firstName" name="firstName" required class="w-full bg-white/80 border border-dark/10 rounded-xl px-4 py-3 text-dark focus:border-indigo focus:ring-1 focus:ring-indigo outline-none transition-all placeholder:text-dark/20 text-sm font-medium" placeholder="Jouw roepnaam">
                  </div>
                  <div class="space-y-2">
                    <label for="company" class="block text-xs font-bold uppercase tracking-widest text-dark/60">Bedrijf / Organisatie</label>
                    <input type="text" id="company" name="company" required class="w-full bg-white/80 border border-dark/10 rounded-xl px-4 py-3 text-dark focus:border-indigo focus:ring-1 focus:ring-indigo outline-none transition-all placeholder:text-dark/20 text-sm font-medium" placeholder="Bedrijfsnaam">
                  </div>
                </div>

                <div class="space-y-2">
                  <label for="email" class="block text-xs font-bold uppercase tracking-widest text-dark/60">E-mailadres</label>
                  <input type="email" id="email" name="email" required class="w-full bg-white/80 border border-dark/10 rounded-xl px-4 py-3 text-dark focus:border-indigo focus:ring-1 focus:ring-indigo outline-none transition-all placeholder:text-dark/20 text-sm font-medium" placeholder="hallo@bedrijf.nl">
                </div>

                <div class="space-y-2">
                  <label for="website" class="block text-xs font-bold uppercase tracking-widest text-dark/60">Huidige Website (optioneel)</label>
                  <input type="url" id="website" name="website" class="w-full bg-white/80 border border-dark/10 rounded-xl px-4 py-3 text-dark focus:border-indigo focus:ring-1 focus:ring-indigo outline-none transition-all placeholder:text-dark/20 text-sm font-medium" placeholder="https://www.jouwwebsite.nl">
                </div>

                <div class="space-y-2">
                  <label for="goal" class="block text-xs font-bold uppercase tracking-widest text-dark/60">Je grootste frustratie/doel nu</label>
                  <select id="goal" name="goal" required class="w-full bg-white/80 border border-dark/10 rounded-xl px-4 py-3 text-dark focus:border-indigo focus:ring-1 focus:ring-indigo outline-none transition-all appearance-none cursor-pointer text-sm font-medium">
                    <option value="" disabled selected>Kies wat het beste past...</option>
                    <option value="leads">Te weinig concrete aanvragen/leads via de site.</option>
                    <option value="imago">De site straalt niet de kwaliteit uit die we leveren.</option>
                    <option value="software">We doen teveel dubbel en handmatig werk (SaaS nodig).</option>
                    <option value="anders">Anders (licht toe in het bericht)</option>
                  </select>
                </div>

                <div class="space-y-2">
                  <label for="message" class="block text-xs font-bold uppercase tracking-widest text-dark/60">Korte wens/omschrijving</label>
                  <textarea id="message" name="message" rows="3" required class="w-full bg-white/80 border border-dark/10 rounded-xl px-4 py-3 text-dark focus:border-indigo focus:ring-1 focus:ring-indigo outline-none transition-all placeholder:text-dark/20 resize-none text-sm font-medium" placeholder="Vertel in 2 zinnen wat je zoekt. Bijv. 'We starten in Q3 een nieuwe marketingcampagne en hebben een strakke LP nodig.'"></textarea>
                </div>

                <input type="text" name="hp_url" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0;" />

                <p id="demo-error" class="hidden text-sm text-red-600 font-medium"></p>

                <button type="submit" id="demo-submit" class="w-full group relative inline-flex items-center justify-center gap-3 bg-indigo text-white px-8 py-4 rounded-xl font-bold uppercase tracking-widest text-sm overflow-hidden transition-all hover:scale-[1.02] shadow-[0_10px_30px_-10px_rgba(67,83,255,0.5)] mt-4 disabled:opacity-60 disabled:cursor-not-allowed disabled:hover:scale-100">
                  <div class="absolute inset-0 bg-white/20 translate-y-full group-hover:translate-y-0 transition-transform duration-300"></div>
                  <span class="relative z-10 flex items-center gap-2">
                    <span id="demo-submit-label">Vraag gratis demo aan</span>
                    <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                  </span>
                </button>
                <p class="text-center text-[10px] text-text-secondary/50 font-bold uppercase tracking-widest mt-4">Wij beschermen je privacy strikt en spammen niet.</p>
              </form>

              <div id="demo-success" class="hidden text-center py-8">
                <div class="w-16 h-16 rounded-full bg-green-100 flex items-center justify-center mx-auto mb-4">
                  <svg class="w-8 h-8 text-green-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                </div>
                <h3 class="font-display text-2xl font-bold text-dark mb-2">Aanvraag ontvangen!</h3>
                <p class="text-text-secondary">We nemen binnen twee werkdagen contact op om een moment in te plannen.</p>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </main>
</Layout>

<script>
  const demoForm = document.getElementById('demo-form') as HTMLFormElement | null;
  const demoSubmit = document.getElementById('demo-submit') as HTMLButtonElement | null;
  const demoSubmitLabel = document.getElementById('demo-submit-label');
  const demoError = document.getElementById('demo-error');
  const demoSuccess = document.getElementById('demo-success');

  demoForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!demoForm || !demoSubmit) return;
    demoError?.classList.add('hidden');

    const data = new FormData(demoForm);
    const payload = {
      formType: 'demo',
      hp_url: String(data.get('hp_url') ?? ''),
      fields: {
        firstName: String(data.get('firstName') ?? ''),
        company: String(data.get('company') ?? ''),
        email: String(data.get('email') ?? ''),
        website: String(data.get('website') ?? ''),
        goal: String(data.get('goal') ?? ''),
        message: String(data.get('message') ?? ''),
      },
    };

    demoSubmit.disabled = true;
    if (demoSubmitLabel) demoSubmitLabel.textContent = 'Versturen...';

    try {
      const res = await fetch('/api/send-mail', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      if (!res.ok) throw new Error('send failed');
      demoForm.classList.add('hidden');
      demoSuccess?.classList.remove('hidden');
    } catch (err) {
      demoSubmit.disabled = false;
      if (demoSubmitLabel) demoSubmitLabel.textContent = 'Vraag gratis demo aan';
      if (demoError) {
        demoError.textContent = 'Er ging iets mis. Probeer opnieuw of mail direct naar info@agensea.nl.';
        demoError.classList.remove('hidden');
      }
    }
  });
</script>
