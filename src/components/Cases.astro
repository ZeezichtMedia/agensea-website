---
import { cases, caseCategories } from "../data/cases";

interface Props {
  categoryFilter?: string;
}

const { categoryFilter } = Astro.props;

const displayCases = categoryFilter
  ? cases.filter((c) => c.category === categoryFilter)
  : cases;
---

<section id="cases" class="pt-12 pb-16 md:pt-24 md:pb-24 px-6 lg:px-10 overflow-hidden">
  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="reveal flex flex-col lg:flex-row lg:items-end lg:justify-between gap-8 mb-16">
      <div class="max-w-xl">
        <span class="inline-flex items-center gap-2 text-xs font-medium text-text-secondary uppercase tracking-[0.2em] mb-4">
          <span class="w-8 h-[1px] bg-indigo"></span>
          Portfolio
        </span>
        <h2 class="font-display text-3xl md:text-5xl font-bold leading-tight">
          Recent werk
        </h2>
      </div>

      <!-- Filters (Only show if no strict categoryFilter is applied) -->
      {!categoryFilter && (
        <div class="flex flex-wrap gap-2 md:gap-4 p-1 bg-dark-lighter/30 rounded-full border border-white/5 w-fit">
          {caseCategories.map((cat) => (
            <button
              class={`filter-btn px-5 py-2 rounded-full text-xs font-bold uppercase tracking-widest transition-all duration-300 interactive ${cat.id === 'all' ? 'active bg-white text-dark shadow-lg' : 'text-text-secondary hover:bg-white hover:text-dark'}`}
              data-filter={cat.id}
              aria-label={`Filter by ${cat.label}`}
            >
              {cat.label}
            </button>
          ))}
        </div>
      )}
    </div>
  </div>

  <!-- Horizontal Scroll Gallery -->
  <div class="relative group/gallery">
    <!-- Nav Arrows -->
    <button id="cases-prev" class="hidden md:flex absolute left-2 top-1/2 -translate-y-1/2 z-20 w-12 h-12 rounded-full bg-white shadow-lg border border-warm-grey/30 items-center justify-center hover:bg-indigo hover:text-white hover:border-indigo transition-all duration-300 opacity-0 group-hover/gallery:opacity-100 cursor-pointer" aria-label="Vorige">
      <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
    </button>
    <button id="cases-next" class="hidden md:flex absolute right-2 top-1/2 -translate-y-1/2 z-20 w-12 h-12 rounded-full bg-white shadow-lg border border-warm-grey/30 items-center justify-center hover:bg-indigo hover:text-white hover:border-indigo transition-all duration-300 opacity-0 group-hover/gallery:opacity-100 cursor-pointer" aria-label="Volgende">
      <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </button>
    <div id="cases-grid" class="flex gap-6 md:gap-8 px-6 lg:px-10 overflow-x-auto pb-8 scrollbar-hide scroll-smooth select-none">
      {displayCases.map((item) => (
        <div
          class="case-card group block w-[280px] md:w-[380px] shrink-0 interactive"
          data-category={item.category}
          data-id={item.id}
        >
          <!-- Image Card -->
          <div class="relative aspect-[3/4] rounded-2xl overflow-hidden mb-5 bg-dark cursor-pointer case-trigger">
            <img
              src={item.image}
              alt={item.title}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" style="image-rendering: -webkit-optimize-contrast;"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent"></div>
            <span class="absolute top-4 left-4 px-4 py-1.5 rounded-full bg-black/40 backdrop-blur-lg text-[10px] font-bold text-white uppercase tracking-widest shadow-lg">
              {item.tag}
            </span>
            <!-- Expand hint -->
            <div class="absolute bottom-4 right-4 w-8 h-8 rounded-full bg-white/10 backdrop-blur-md border border-white/10 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <svg class="w-3.5 h-3.5 text-white transition-transform duration-300 group-hover:scale-110" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg>
            </div>
          </div>
          
          <!-- Title -->
          <h3 class="font-display text-lg md:text-xl font-bold group-hover:text-indigo transition-colors flex items-center justify-between cursor-pointer case-trigger">
            {item.title}
            <svg class="w-4 h-4 opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </h3>
        </div>
      ))}
    </div>
    
    <!-- Gradient Overlays -->
    <div class="absolute left-0 top-0 bottom-0 w-32 bg-gradient-to-r from-cream to-transparent pointer-events-none z-10 opacity-0 md:opacity-100"></div>
    <div class="absolute right-0 top-0 bottom-0 w-32 bg-gradient-to-l from-cream to-transparent pointer-events-none z-10 opacity-0 md:opacity-100"></div>
  </div>
</section>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .case-card {
    max-width: 380px;
  }

  /* Verborgen tijdens filter — display:none zodat de overige cards
     soepel kunnen herorganiseren via de View Transitions API. */
  .case-card.filtered-out {
    display: none;
  }

  @media (max-width: 767px) {
    .case-card {
      max-width: 280px;
    }
  }

  /* ── Filter animations ─────────────────────────────────
     Cards worden volledig via Web Animations API gestuurd in JS.
     CSS doet alleen het ruwe verbergen + GPU layer hint. Geen CSS
     transitions die met de WAAPI-animaties kunnen vechten. */
  .case-card {
    will-change: transform, opacity;
    backface-visibility: hidden;
  }
</style>

<script>
  // ── Enterprise-grade filter logic ───────────────────────────────────
  // Web Animations API met cancellation. Elke filter-klik is direct
  // responsive: lopende animaties worden gecancelled (na commitStyles
  // zodat de huidige visuele frame behouden blijft) en de nieuwe animatie
  // start vanaf die frame. Geen lock, geen wachtrij, geen flicker.
  //
  // Architectuur:
  //   1. Cancel + cleanup alle in-flight animaties (incl. cards die nog
  //      in een leaving-fixed positie hangen)
  //   2. Capture FIRST rectangles van cards die zichtbaar blijven of nieuw
  //      zichtbaar worden
  //   3. Pin leaving cards op position:fixed bij hun huidige rect zodat ze
  //      niet meer in de layout-flow zitten
  //   4. Update DOM (entering cards: filtered-out class weg)
  //   5. Capture LAST rectangles
  //   6. Run drie animatie-types parallel:
  //        - LEAVING: fade + scale + slide (op fixed-positioned card)
  //        - MOVING:  FLIP transform van first→last
  //        - ENTERING: slide-up + fade van eerste frame
  //
  // NB: gebruik `as` casts ipv generic-syntax op querySelectorAll — Astro's
  // parser verwart de hoekige haken met HTML tags en breekt het script.
  const filterBtns = Array.from(document.querySelectorAll('.filter-btn')) as HTMLButtonElement[];
  const caseCards = Array.from(document.querySelectorAll('.case-card')) as HTMLElement[];
  const grid = document.getElementById('cases-grid');

  // Per-card lopende animatie. WeakMap zodat cards GC'd kunnen worden.
  const cardAnims = new WeakMap<HTMLElement, Animation>();

  // Easing matched aan rest van de site
  const EASING = 'cubic-bezier(0.22, 1, 0.36, 1)';
  const EASING_OUT = 'cubic-bezier(0.4, 0, 1, 1)';

  function clearLeavingStyles(card: HTMLElement) {
    card.style.position = '';
    card.style.left = '';
    card.style.top = '';
    card.style.width = '';
    card.style.height = '';
    card.style.margin = '';
    card.style.zIndex = '';
    card.style.pointerEvents = '';
    delete card.dataset.leaving;
  }

  function applyFilter(filter: string, activeBtn: HTMLButtonElement) {
    // 0. No-op als deze filter al actief is. Voorkomt dat een dubbelklik
    //    op dezelfde knop de filter-logica opnieuw start, lopende animaties
    //    cancelt en de cards in een rare tussenstaat achterlaat.
    if (activeBtn.classList.contains('active')) {
      return;
    }

    // 1. Button state synchroon — instant feedback ongeacht animaties.
    filterBtns.forEach((b) => {
      b.classList.remove('active', 'bg-white', 'text-dark', 'shadow-lg');
      b.classList.add('text-text-secondary');
      b.setAttribute('aria-pressed', 'false');
    });
    activeBtn.classList.add('active', 'bg-white', 'text-dark', 'shadow-lg');
    activeBtn.classList.remove('text-text-secondary');
    activeBtn.setAttribute('aria-pressed', 'true');

    // 2. Bereken doel-zichtbaarheid
    const shouldBeVisible = (card: HTMLElement) => {
      const cat = card.getAttribute('data-category');
      return filter === 'all' || cat === filter;
    };

    // 3. Reduced motion? Schakel direct, klaar.
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      caseCards.forEach((c) => {
        clearLeavingStyles(c);
        c.classList.toggle('filtered-out', !shouldBeVisible(c));
      });
      if (grid) grid.scrollLeft = 0;
      return;
    }

    // 4. CANCEL alle in-flight animaties + freeze huidige visuele staat.
    //    commitStyles bakt de huidige animation values als inline styles in,
    //    zodat na cancel de card zichtbaar blijft op exact die positie.
    caseCards.forEach((card) => {
      const anim = cardAnims.get(card);
      if (anim) {
        try { anim.commitStyles(); } catch {}
        anim.cancel();
        cardAnims.delete(card);
      }
    });

    // 5. Restore in-flight leaving cards naar normale flow.
    //    Een card die nog gepinned was op fixed-positie wordt teruggezet
    //    in de layout zodat de FIRST-meting hieronder klopt.
    caseCards.forEach((card) => {
      if (card.dataset.leaving === 'true') {
        clearLeavingStyles(card);
        // Was bezig met leaving — staat nu visueel ergens halverwege fade.
        // Reset transform/opacity zodat de nieuwe animatie clean kan starten.
        card.style.transform = '';
        card.style.opacity = '';
      }
    });

    // 6. FIRST: capture huidige rectangles van cards die niet hidden zijn.
    const firstRects = new Map<HTMLElement, DOMRect>();
    caseCards.forEach((card) => {
      if (!card.classList.contains('filtered-out')) {
        firstRects.set(card, card.getBoundingClientRect());
      }
    });

    // 7. Pin leaving cards op hun huidige positie (out of flow).
    const leavingCards: HTMLElement[] = [];
    caseCards.forEach((card) => {
      const wasVisible = firstRects.has(card);
      if (wasVisible && !shouldBeVisible(card)) {
        const r = firstRects.get(card)!;
        card.dataset.leaving = 'true';
        card.style.position = 'fixed';
        card.style.left = `${r.left}px`;
        card.style.top = `${r.top}px`;
        card.style.width = `${r.width}px`;
        card.style.height = `${r.height}px`;
        card.style.margin = '0';
        card.style.zIndex = '5';
        card.style.pointerEvents = 'none';
        leavingCards.push(card);
      }
    });

    // 8. Reveal entering cards (toggle filtered-out off).
    caseCards.forEach((card) => {
      if (shouldBeVisible(card)) {
        card.classList.remove('filtered-out');
      }
    });

    // 9. Reset scroll en force reflow.
    if (grid) grid.scrollLeft = 0;
    void grid?.offsetHeight;

    // 10. LAST: capture nieuwe positions van cards die zichtbaar zijn.
    const lastRects = new Map<HTMLElement, DOMRect>();
    caseCards.forEach((card) => {
      if (shouldBeVisible(card)) {
        lastRects.set(card, card.getBoundingClientRect());
      }
    });

    // 11. Animate alles parallel met WAAPI.
    //     Elk type animatie wordt opgeslagen in cardAnims voor cancellation.

    // LEAVING — fade + scale + slide naar onder
    leavingCards.forEach((card) => {
      const anim = card.animate(
        [
          { opacity: 1, transform: 'scale(1) translateY(0)' },
          { opacity: 0, transform: 'scale(0.92) translateY(12px)' },
        ],
        { duration: 280, easing: EASING_OUT, fill: 'forwards' }
      );
      cardAnims.set(card, anim);
      anim.finished
        .then(() => {
          // Animation klaar: card definitief verbergen + cleanup.
          clearLeavingStyles(card);
          card.classList.add('filtered-out');
          cardAnims.delete(card);
        })
        .catch(() => {
          // Cancelled door volgende klik — niks doen, nieuwe applyFilter
          // heeft de cleanup al overgenomen.
        });
    });

    // MOVING (FLIP) en ENTERING
    caseCards.forEach((card) => {
      if (!shouldBeVisible(card)) return;
      const first = firstRects.get(card);
      const last = lastRects.get(card);
      if (!last) return;

      if (first) {
        // MOVING — FLIP transform van first naar last
        const dx = first.left - last.left;
        const dy = first.top - last.top;
        if (Math.abs(dx) < 1 && Math.abs(dy) < 1) return; // staat al goed
        const anim = card.animate(
          [
            { transform: `translate(${dx}px, ${dy}px)` },
            { transform: 'translate(0, 0)' },
          ],
          { duration: 500, easing: EASING, fill: 'both' }
        );
        cardAnims.set(card, anim);
        anim.finished
          .then(() => cardAnims.delete(card))
          .catch(() => {});
      } else {
        // ENTERING — slide-up + fade van eerste frame
        const anim = card.animate(
          [
            { opacity: 0, transform: 'translateY(28px) scale(0.95)' },
            { opacity: 1, transform: 'translateY(0) scale(1)' },
          ],
          { duration: 500, easing: EASING, fill: 'both' }
        );
        cardAnims.set(card, anim);
        anim.finished
          .then(() => cardAnims.delete(card))
          .catch(() => {});
      }
    });
  }

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.getAttribute('data-filter') || 'all';
      applyFilter(filter, btn);
    });
  });

  // Drag to scroll logic
  let isDown = false;
  let startX: number;
  let scrollLeft: number;
  let isDragging = false;

  if (grid) {
    grid.style.cursor = 'grab';

    grid.addEventListener('mousedown', (e) => {
      isDown = true;
      isDragging = false;
      grid.style.cursor = 'grabbing';
      startX = e.pageX - grid.offsetLeft;
      scrollLeft = grid.scrollLeft;
      // Prevent text selection while dragging
      e.preventDefault();
    });
    
    grid.addEventListener('mouseleave', () => {
      isDown = false;
      grid.style.cursor = 'grab';
    });
    
    grid.addEventListener('mouseup', () => {
      isDown = false;
      grid.style.cursor = 'grab';
    });
    
    grid.addEventListener('mousemove', (e) => {
      if (!isDown) return;
      e.preventDefault();
      const x = e.pageX - grid.offsetLeft;
      const walk = (x - startX) * 2;
      
      if (Math.abs(walk) > 5) {
        isDragging = true;
      }
      grid.scrollLeft = scrollLeft - walk;
    });
  }

  // Arrow navigation
  const prevBtn = document.getElementById('cases-prev');
  const nextBtn = document.getElementById('cases-next');
  const scrollAmount = 400;
  prevBtn?.addEventListener('click', () => {
    grid?.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
  });
  nextBtn?.addEventListener('click', () => {
    grid?.scrollBy({ left: scrollAmount, behavior: 'smooth' });
  });

  // Open Modal logic
  document.querySelectorAll('.case-trigger').forEach(trigger => {
    trigger.addEventListener('click', (e) => {
      e.preventDefault();
      
      // Prevent click if we were dragging the carousel
      if (isDragging) return;

      const card = (trigger as HTMLElement).closest('.case-card');
      if (!card) return;

      const caseId = card.getAttribute('data-id');
      if (caseId) {
        window.dispatchEvent(new CustomEvent('open-case', { detail: { id: caseId } }));
      }
    });
  });
</script>
