---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Cases from '../../components/Cases.astro';
import CTA from '../../components/CTA.astro';
---

<Layout title="Maatwerk Websites | Agensea">
  <Navbar />
  
  <main class="bg-cream min-h-screen pt-28 md:pt-36 pb-20 overflow-hidden relative">
    <!-- Background Decor -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
      <div class="mesh-blob w-[600px] h-[600px] bg-indigo/10 top-[-10%] right-[-10%] blur-[120px]"></div>
      <div class="mesh-blob w-[500px] h-[500px] bg-violet/10 bottom-[10%] left-[-10%] blur-[100px]"></div>
    </div>

    <!-- Hero Section -->
    <section class="max-w-7xl mx-auto px-6 lg:px-10 relative z-10 mb-16 md:mb-28">
      <div class="grid lg:grid-cols-12 gap-10 lg:gap-14 items-center">
        <!-- Content -->
        <div class="lg:col-span-7">
          <div class="reveal">
            <span class="inline-flex items-center gap-2 text-xs font-bold text-indigo uppercase tracking-[0.2em] mb-6">
              <span class="w-8 h-[2px] bg-indigo"></span>
              Onze diensten
            </span>
            <h1 class="font-display font-bold text-4xl md:text-5xl lg:text-6xl leading-[1.05] tracking-tight text-dark mb-5">
              Een professionele website <span class="text-indigo">die klanten oplevert.</span>
            </h1>
            <p class="text-base md:text-lg text-text-secondary leading-relaxed mb-8 max-w-xl">
              Je zoekt een website die er strak uitziet én doet wat hij moet doen: overtuigen. Wij bouwen razendsnelle, betrouwbare websites en webshops die perfect aansluiten bij jouw bedrijf.
            </p>
            <div class="flex flex-wrap gap-4">
              <a href="/contact" class="magnetic-btn px-8 mx-0 py-4 bg-dark text-white rounded-xl font-medium hover:bg-indigo transition-colors duration-300">
                Laten we sparren
              </a>
              <a href="#aanpak" class="px-8 py-4 border border-warm-grey/50 rounded-xl font-medium text-dark hover:border-indigo transition-all duration-300">
                Ontdek onze aanpak
              </a>
            </div>
          </div>
        </div>
        <!-- Right Image/Graphic area -->        <div class="lg:col-span-5 reveal" style="transition-delay: 200ms;">
          <div class="w-full bg-white rounded-[2rem] shadow-2xl overflow-hidden border border-white relative">
            <!-- Browser Chrome -->
            <div class="h-9 bg-[#f5f3ef] flex items-center px-4 gap-1.5 border-b border-warm-grey/15">
              <div class="w-2.5 h-2.5 rounded-full bg-[#FF5F57]"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-[#FEBC2E]"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-[#28C840]"></div>
              <div class="ml-3 flex-1 h-5 bg-white/80 rounded-md border border-warm-grey/15 flex items-center px-2">
                <span id="urlText" class="text-[8px] text-text-secondary/40 font-mono transition-opacity duration-300">jouwbedrijf.nl</span>
              </div>
            </div>

            <!-- Layout Container -->
            <div id="layoutContainer" class="p-5 min-h-[260px] relative">
              
              <!-- Layout 1: Corporate -->
              <div class="site-layout active" data-url="jouwbedrijf.nl" id="layout1">
                <div class="space-y-4">
                  <div class="mini-el flex items-center justify-between">
                    <div class="w-14 h-4 bg-dark rounded-sm"></div>
                    <div class="flex gap-3">
                      <div class="w-10 h-2.5 bg-warm-grey/30 rounded-sm"></div>
                      <div class="w-10 h-2.5 bg-warm-grey/30 rounded-sm"></div>
                      <div class="w-12 h-6 bg-indigo rounded-md"></div>
                    </div>
                  </div>
                  <div class="pt-2 pb-1">
                    <div class="mini-el w-3/4 h-4 bg-dark rounded-sm mb-2"></div>
                    <div class="mini-el w-1/2 h-4 bg-indigo/60 rounded-sm mb-3"></div>
                    <div class="mini-el w-full h-2 bg-warm-grey/20 rounded-sm mb-1"></div>
                    <div class="mini-el w-4/5 h-2 bg-warm-grey/20 rounded-sm mb-3"></div>
                    <div class="mini-el w-20 h-7 bg-indigo rounded-lg"></div>
                  </div>
                  <div class="grid grid-cols-3 gap-2">
                    <div class="mini-el bg-cream rounded-xl p-3 border border-warm-grey/15">
                      <div class="w-6 h-6 bg-indigo/10 rounded-lg mb-2"></div>
                      <div class="w-full h-1.5 bg-warm-grey/25 rounded-sm mb-1"></div>
                      <div class="w-2/3 h-1.5 bg-warm-grey/15 rounded-sm"></div>
                    </div>
                    <div class="mini-el bg-cream rounded-xl p-3 border border-warm-grey/15">
                      <div class="w-6 h-6 bg-violet/10 rounded-lg mb-2"></div>
                      <div class="w-full h-1.5 bg-warm-grey/25 rounded-sm mb-1"></div>
                      <div class="w-3/4 h-1.5 bg-warm-grey/15 rounded-sm"></div>
                    </div>
                    <div class="mini-el bg-cream rounded-xl p-3 border border-warm-grey/15">
                      <div class="w-6 h-6 bg-emerald-50 rounded-lg mb-2"></div>
                      <div class="w-full h-1.5 bg-warm-grey/25 rounded-sm mb-1"></div>
                      <div class="w-1/2 h-1.5 bg-warm-grey/15 rounded-sm"></div>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Layout 2: Webshop -->
              <div class="site-layout" data-url="jouwwebshop.nl/producten" id="layout2">
                <div class="space-y-4">
                  <div class="mini-el flex items-center justify-between">
                    <div class="w-14 h-4 bg-dark rounded-sm"></div>
                    <div class="flex gap-2 items-center">
                      <div class="w-8 h-2.5 bg-warm-grey/30 rounded-sm"></div>
                      <div class="w-8 h-2.5 bg-warm-grey/30 rounded-sm"></div>
                      <div class="w-7 h-7 bg-indigo/10 rounded-lg flex items-center justify-center">
                        <div class="w-3.5 h-3 border-2 border-indigo/50 rounded-sm"></div>
                      </div>
                    </div>
                  </div>
                  <div class="mini-el flex gap-2 items-center">
                    <div class="flex-1 h-7 bg-cream border border-warm-grey/20 rounded-lg"></div>
                    <div class="w-16 h-7 bg-indigo/10 rounded-lg"></div>
                  </div>
                  <div class="grid grid-cols-2 gap-3">
                    <div class="mini-el bg-cream rounded-xl border border-warm-grey/15 overflow-hidden">
                      <div class="w-full h-16 bg-indigo/5"></div>
                      <div class="p-2.5">
                        <div class="w-3/4 h-2 bg-warm-grey/25 rounded-sm mb-1.5"></div>
                        <div class="w-1/2 h-2 bg-indigo/40 rounded-sm font-bold"></div>
                      </div>
                    </div>
                    <div class="mini-el bg-cream rounded-xl border border-warm-grey/15 overflow-hidden">
                      <div class="w-full h-16 bg-violet/5"></div>
                      <div class="p-2.5">
                        <div class="w-2/3 h-2 bg-warm-grey/25 rounded-sm mb-1.5"></div>
                        <div class="w-1/3 h-2 bg-indigo/40 rounded-sm"></div>
                      </div>
                    </div>
                    <div class="mini-el bg-cream rounded-xl border border-warm-grey/15 overflow-hidden">
                      <div class="w-full h-16 bg-emerald-50/50"></div>
                      <div class="p-2.5">
                        <div class="w-full h-2 bg-warm-grey/25 rounded-sm mb-1.5"></div>
                        <div class="w-2/5 h-2 bg-indigo/40 rounded-sm"></div>
                      </div>
                    </div>
                    <div class="mini-el bg-cream rounded-xl border border-warm-grey/15 overflow-hidden">
                      <div class="w-full h-16 bg-amber-50/50"></div>
                      <div class="p-2.5">
                        <div class="w-1/2 h-2 bg-warm-grey/25 rounded-sm mb-1.5"></div>
                        <div class="w-1/3 h-2 bg-indigo/40 rounded-sm"></div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Layout 3: Portfolio -->
              <div class="site-layout" data-url="creatief-bureau.nl" id="layout3">
                <div class="space-y-4">
                  <div class="mini-el flex items-center justify-between">
                    <div class="w-10 h-4 bg-dark rounded-sm"></div>
                    <div class="flex gap-4">
                      <div class="w-8 h-2.5 bg-warm-grey/30 rounded-sm"></div>
                      <div class="w-8 h-2.5 bg-warm-grey/30 rounded-sm"></div>
                      <div class="w-8 h-2.5 bg-warm-grey/30 rounded-sm"></div>
                    </div>
                  </div>
                  <div class="mini-el w-full h-28 bg-gradient-to-br from-indigo/10 via-violet/10 to-indigo/5 rounded-xl relative overflow-hidden">
                    <div class="absolute bottom-3 left-3">
                      <div class="w-24 h-3 bg-white/80 rounded-sm mb-1"></div>
                      <div class="w-16 h-2 bg-white/50 rounded-sm"></div>
                    </div>
                  </div>
                  <div class="grid grid-cols-3 gap-2">
                    <div class="mini-el h-14 bg-violet/10 rounded-lg"></div>
                    <div class="mini-el h-14 bg-indigo/10 rounded-lg"></div>
                    <div class="mini-el h-14 bg-emerald-50 rounded-lg"></div>
                  </div>
                  <div class="grid grid-cols-2 gap-2">
                    <div class="mini-el h-10 bg-amber-50 rounded-lg"></div>
                    <div class="mini-el h-10 bg-violet/5 rounded-lg"></div>
                  </div>
                </div>
              </div>

              <!-- Layout 4: Dashboard / SaaS -->
              <div class="site-layout" data-url="app.jouwplatform.nl/dashboard" id="layout4">
                <div class="flex gap-3">
                  <div class="w-10 shrink-0 space-y-3 pt-1">
                    <div class="mini-el w-8 h-8 bg-dark rounded-lg"></div>
                    <div class="mini-el w-6 h-1.5 bg-warm-grey/30 rounded-sm mx-auto"></div>
                    <div class="mini-el w-6 h-1.5 bg-indigo/40 rounded-sm mx-auto"></div>
                    <div class="mini-el w-6 h-1.5 bg-warm-grey/30 rounded-sm mx-auto"></div>
                    <div class="mini-el w-6 h-1.5 bg-warm-grey/30 rounded-sm mx-auto"></div>
                  </div>
                  <div class="flex-1 space-y-3">
                    <div class="mini-el flex gap-2">
                      <div class="flex-1 bg-cream rounded-xl p-3 border border-warm-grey/15">
                        <div class="w-10 h-1.5 bg-warm-grey/20 rounded-sm mb-1.5"></div>
                        <div class="w-12 h-3 bg-indigo/50 rounded-sm"></div>
                      </div>
                      <div class="flex-1 bg-cream rounded-xl p-3 border border-warm-grey/15">
                        <div class="w-10 h-1.5 bg-warm-grey/20 rounded-sm mb-1.5"></div>
                        <div class="w-12 h-3 bg-emerald-400/50 rounded-sm"></div>
                      </div>
                      <div class="flex-1 bg-cream rounded-xl p-3 border border-warm-grey/15">
                        <div class="w-10 h-1.5 bg-warm-grey/20 rounded-sm mb-1.5"></div>
                        <div class="w-12 h-3 bg-violet/50 rounded-sm"></div>
                      </div>
                    </div>
                    <div class="mini-el bg-cream rounded-xl p-3 border border-warm-grey/15">
                      <div class="flex items-end gap-1 h-12">
                        <div class="flex-1 bg-indigo/15 rounded-t-sm" style="height:30%"></div>
                        <div class="flex-1 bg-indigo/20 rounded-t-sm" style="height:50%"></div>
                        <div class="flex-1 bg-indigo/20 rounded-t-sm" style="height:40%"></div>
                        <div class="flex-1 bg-indigo/25 rounded-t-sm" style="height:65%"></div>
                        <div class="flex-1 bg-indigo/30 rounded-t-sm" style="height:55%"></div>
                        <div class="flex-1 bg-indigo/40 rounded-t-sm" style="height:80%"></div>
                        <div class="flex-1 bg-indigo rounded-t-sm" style="height:95%"></div>
                      </div>
                    </div>
                    <div class="mini-el bg-cream rounded-xl p-2.5 border border-warm-grey/15 space-y-2">
                      <div class="flex gap-2">
                        <div class="w-1/4 h-1.5 bg-warm-grey/20 rounded-sm"></div>
                        <div class="w-1/4 h-1.5 bg-warm-grey/20 rounded-sm"></div>
                        <div class="w-1/4 h-1.5 bg-warm-grey/20 rounded-sm"></div>
                        <div class="w-1/4 h-1.5 bg-warm-grey/20 rounded-sm"></div>
                      </div>
                      <div class="flex gap-2">
                        <div class="w-1/4 h-1.5 bg-warm-grey/10 rounded-sm"></div>
                        <div class="w-1/4 h-1.5 bg-warm-grey/10 rounded-sm"></div>
                        <div class="w-1/4 h-1.5 bg-emerald-200 rounded-sm"></div>
                        <div class="w-1/4 h-1.5 bg-warm-grey/10 rounded-sm"></div>
                      </div>
                      <div class="flex gap-2">
                        <div class="w-1/4 h-1.5 bg-warm-grey/10 rounded-sm"></div>
                        <div class="w-1/4 h-1.5 bg-warm-grey/10 rounded-sm"></div>
                        <div class="w-1/4 h-1.5 bg-amber-200 rounded-sm"></div>
                        <div class="w-1/4 h-1.5 bg-warm-grey/10 rounded-sm"></div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Details Section -->
    <section id="aanpak" class="py-24 bg-white relative z-10 w-full rounded-[3rem] shadow-sm mb-24 md:mb-40">
      <div class="max-w-7xl mx-auto px-6 lg:px-10">
        <h2 class="font-display text-4xl leading-tight font-bold mb-16 text-center max-w-2xl mx-auto">Niet zomaar een mooi plaatje, maar een <span class="text-indigo">strategisch fundament.</span></h2>
        
        <div class="grid md:grid-cols-3 gap-8 lg:gap-12">
          <!-- Feature 1 -->
          <div class="p-8 rounded-3xl bg-cream border border-warm-grey/30 hover:border-indigo/30 transition-colors">
            <h3 class="font-bold text-xl mb-4">Razendsnel</h3>
            <p class="text-text-secondary leading-relaxed">Niets is zo frustrerend als een trage website. Wij bouwen op de nieuwste technieken waardoor jouw pagina's direct laden. Goed voor je bezoeker én voor Google.</p>
          </div>
          <!-- Feature 2 -->
          <div class="p-8 rounded-3xl bg-cream border border-warm-grey/30 hover:border-indigo/30 transition-colors">
            <h3 class="font-bold text-xl mb-4">Conversie Gericht</h3>
            <p class="text-text-secondary leading-relaxed">Elk onderdeel is ontworpen om bezoekers te begeleiden naar de volgende stap. Of dat nu een offerte-aanvraag, een belletje of een aankoop is.</p>
          </div>
          <!-- Feature 3 -->
          <div class="p-8 rounded-3xl bg-cream border border-warm-grey/30 hover:border-indigo/30 transition-colors">
            <h3 class="font-bold text-xl mb-4">Meegroeien</h3>
            <p class="text-text-secondary leading-relaxed">Jouw bedrijf staat niet stil. Daarom bouwen we websites die je in de toekomst makkelijk uit kunt breiden met nieuwe pagina's of features.</p>
          </div>
        </div>
      </div>
    </section>

    <Cases />
    <CTA />
  </main>
  
  <Footer />
</Layout>

<style>
  .site-layout {
    position: absolute;
    inset: 0;
    padding: 20px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.6s ease;
  }
  
  .site-layout.active {
    position: relative;
    opacity: 1;
    pointer-events: auto;
  }

  .site-layout .mini-el {
    opacity: 0;
    transform: translateY(8px);
  }

  .site-layout.active .mini-el {
    animation: buildEl 0.5s ease-out forwards;
  }

  .site-layout.active .mini-el:nth-child(1) { animation-delay: 0.1s; }
  .site-layout.active .mini-el:nth-child(2) { animation-delay: 0.3s; }
  .site-layout.active .mini-el:nth-child(3) { animation-delay: 0.5s; }
  .site-layout.active .mini-el:nth-child(4) { animation-delay: 0.7s; }
  .site-layout.active .mini-el:nth-child(5) { animation-delay: 0.9s; }

  /* Deep nested mini-els in sub-containers */
  .site-layout.active .space-y-4 > :nth-child(1) .mini-el,
  .site-layout.active .space-y-4 > .mini-el:nth-child(1),
  .site-layout.active .space-y-3 > .mini-el:nth-child(1) { animation-delay: 0.1s; }

  .site-layout.active .space-y-4 > :nth-child(2) .mini-el,
  .site-layout.active .space-y-4 > .mini-el:nth-child(2),
  .site-layout.active .space-y-3 > .mini-el:nth-child(2) { animation-delay: 0.35s; }

  .site-layout.active .space-y-4 > :nth-child(3) .mini-el,
  .site-layout.active .space-y-4 > .mini-el:nth-child(3),
  .site-layout.active .space-y-3 > .mini-el:nth-child(3) { animation-delay: 0.6s; }

  .site-layout.active .space-y-4 > :nth-child(4) .mini-el,
  .site-layout.active .space-y-4 > .mini-el:nth-child(4),
  .site-layout.active .space-y-3 > .mini-el:nth-child(4) { animation-delay: 0.85s; }

  .site-layout.active .space-y-4 > :nth-child(5) .mini-el,
  .site-layout.active .space-y-4 > .mini-el:nth-child(5),
  .site-layout.active .space-y-3 > .mini-el:nth-child(5) { animation-delay: 1.1s; }

  /* Grid children stagger */
  .site-layout.active .grid > .mini-el:nth-child(1) { animation-delay: 0.6s; }
  .site-layout.active .grid > .mini-el:nth-child(2) { animation-delay: 0.75s; }
  .site-layout.active .grid > .mini-el:nth-child(3) { animation-delay: 0.9s; }
  .site-layout.active .grid > .mini-el:nth-child(4) { animation-delay: 1.05s; }

  .site-layout.fading .mini-el {
    animation: fadeEl 0.4s ease-in forwards !important;
  }

  @keyframes buildEl {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeEl {
    from { opacity: 1; transform: translateY(0); }
    to { opacity: 0; transform: translateY(-4px); }
  }
</style>

<script>
  const observeElements = () => {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
        }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', observeElements);
  } else {
    observeElements();
  }

  // Layout cycler
  const layouts = document.querySelectorAll('.site-layout');
  const urlText = document.getElementById('urlText');
  let current = 0;
  const DISPLAY_TIME = 4000;
  const FADE_TIME = 500;

  function showLayout(index) {
    const layout = layouts[index];
    // Update URL
    if (urlText && layout.dataset.url) {
      urlText.style.opacity = '0';
      setTimeout(() => {
        urlText.textContent = layout.dataset.url;
        urlText.style.opacity = '1';
      }, 200);
    }
    // Reset animations
    layout.querySelectorAll('.mini-el').forEach(el => {
      el.style.animation = 'none';
      el.offsetHeight; // trigger reflow
      el.style.animation = '';
    });
    layout.classList.remove('fading');
    layout.classList.add('active');
  }

  function hideLayout(index) {
    const layout = layouts[index];
    layout.classList.add('fading');
    setTimeout(() => {
      layout.classList.remove('active', 'fading');
    }, FADE_TIME);
  }

  function cycle() {
    hideLayout(current);
    setTimeout(() => {
      current = (current + 1) % layouts.length;
      showLayout(current);
    }, FADE_TIME);
  }

  // Start cycling
  showLayout(0);
  setInterval(cycle, DISPLAY_TIME + FADE_TIME);
</script>
