<section id="contact" class="pt-12 pb-24 md:pt-24 md:pb-40 px-6 lg:px-10">
  <div class="max-w-7xl mx-auto">
    <div class="reveal max-w-3xl mx-auto text-center">
      <span class="inline-flex items-center gap-2 text-xs font-medium text-text-secondary uppercase tracking-[0.2em] mb-6">
        <span class="w-8 h-[1px] bg-indigo"></span>
        Ontdek de mogelijkheden
        <span class="w-8 h-[1px] bg-indigo"></span>
      </span>

      <!-- High-End Blur Reveal Headline -->
      <h2 class="font-display text-4xl md:text-6xl font-bold leading-[1.1] mb-8 blur-reveal-container flex flex-wrap justify-center gap-x-2 md:gap-x-3 w-full items-baseline">
        <span class="blur-word">Klaar</span>
        <span class="blur-word">voor</span>
        <span class="blur-word">de</span>
        <span class="blur-word text-indigo">volgende</span>
        <span class="literal-step text-indigo">stap?</span>
      </h2>

      <p class="text-lg text-text-secondary leading-relaxed mb-12 max-w-xl mx-auto">
        Laten we samen kijken hoe we jouw ambities kunnen waarmaken. Van strategie tot realisatie.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="magnetic-btn px-10 py-4 bg-indigo text-white rounded-xl font-medium text-base hover:bg-indigo-light transition-colors duration-300">
          Neem direct contact op
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="tel:+31681383601" class="magnetic-btn px-10 py-4 border border-warm-grey rounded-xl font-medium text-base text-text-secondary hover:border-dark hover:text-dark transition-all duration-300">
          06 81 38 36 01
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .blur-word {
    display: inline-block;
    opacity: 0;
    filter: blur(8px);
    transform: translateY(20px) translateX(-5px) scale(0.95);
    transition: opacity 0.8s cubic-bezier(0.34, 1.56, 0.4, 1), 
                filter 0.8s cubic-bezier(0.34, 1.56, 0.4, 1), 
                transform 0.8s cubic-bezier(0.34, 1.56, 0.4, 1);
  }
  .blur-word.active {
    opacity: 1;
    filter: blur(0);
    transform: translateY(0) scale(1);
  }

  /* Physical step animation for the final word */
  .literal-step {
    display: inline-block;
    opacity: 0;
    filter: blur(8px);
    transform: translateY(30px) translateX(-20px) rotate(-10deg);
  }
  .literal-step.active {
    animation: stepForward 1.2s cubic-bezier(0.34, 1.56, 0.4, 1) forwards;
  }
  
  @keyframes stepForward {
    0% {
      opacity: 0;
      transform: translateY(30px) translateX(-30px) rotate(-15deg);
      filter: blur(8px);
    }
    40% {
      opacity: 1;
      transform: translateY(-20px) translateX(5px) rotate(5deg) scale(1.1);
      filter: blur(0);
    }
    100% {
      opacity: 1;
      transform: translateY(0) translateX(0) rotate(0deg) scale(1);
      filter: blur(0);
    }
  }
</style>

<script>
  const setupBlurReveal = () => {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting && !entry.target.classList.contains('revealed')) {
          entry.target.classList.add('revealed');
          
          const words = entry.target.querySelectorAll('.blur-word, .literal-step');
          words.forEach((word, index) => {
            setTimeout(() => {
              word.classList.add('active');
            }, index * 100); // Tighter stagger (100ms) for more momentum
          });
        }
      });
    }, { threshold: 0.5 });
    
    document.querySelectorAll('.blur-reveal-container').forEach(el => observer.observe(el));
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupBlurReveal);
  } else {
    setupBlurReveal();
  }
</script>
